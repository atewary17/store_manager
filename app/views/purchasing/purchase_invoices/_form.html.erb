<%# app/views/purchasing/purchase_invoices/_form.html.erb %>
<%= form_with model: [:purchasing, invoice], local: true, id: 'invoice-form' do |f| %>

  <% if invoice.errors.any? %>
    <div class="flash alert" style="margin-bottom:20px">
      <strong><%= invoice.errors.count %> error(s):</strong>
      <ul style="margin-top:6px;padding-left:16px">
        <% invoice.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%# ══════════════════════════════════════════════════════
      SECTION 1 — Supplier & Invoice Details
  ══════════════════════════════════════════════════════ %>
  <div class="form-card" style="max-width:100%;margin-bottom:20px">
    <div class="form-section">
      <div class="form-section-title">Supplier & Invoice Details</div>

      <div class="form-row" style="grid-template-columns:1fr 1fr 1fr">

        <div class="form-group">
          <%= f.label :supplier_id, "Supplier" %>
          <%= f.hidden_field :supplier_id, id: 'supplier_id_field', value: invoice.supplier_id %>
          <div style="position:relative" id="supplier-ac-wrap">
            <input type="text" id="supplier-search-input"
                   placeholder="Search supplier name or GSTIN…"
                   autocomplete="off"
                   value="<%= invoice.supplier&.name %>"
                   style="width:100%;background:var(--bg);border:1px solid var(--border);
                          border-radius:6px;padding:9px 12px;color:var(--text);
                          font-size:13.5px;outline:none">
            <div id="supplier-ac-dropdown"
                 style="display:none;position:absolute;top:100%;left:0;right:0;z-index:9999;
                        background:var(--surface);border:1px solid var(--border);
                        border-radius:6px;box-shadow:var(--shadow-lg);
                        max-height:240px;overflow-y:auto;margin-top:2px"></div>
          </div>
          <div id="supplier-info-strip"
               style="font-family:var(--mono);font-size:10px;color:var(--text-dim);
                      margin-top:4px;min-height:14px">
            <% if invoice.supplier %>
              <% s = invoice.supplier %>
              <%= [s.gstin.presence&.prepend("GSTIN: "), s.state.presence, s.pan.presence&.prepend("PAN: ")].compact.join('  ·  ') %>
            <% end %>
          </div>
          <div style="font-size:11px;color:var(--text-dim);margin-top:4px">
            Not listed?
            <a href="#" onclick="showSupplierPanel(event)" style="color:var(--accent);text-decoration:none">
              Add supplier inline
            </a>
          </div>
        </div>

        <div class="form-group">
          <%= f.label :invoice_number, "Invoice Number" %>
          <%= f.text_field :invoice_number, placeholder: 'e.g. WB2401437256',
                style: 'font-family:var(--mono)', class: 'form-control' %>
          <div class="form-hint">As printed on the supplier invoice — optional</div>
        </div>

        <div class="form-group">
          <%= f.label :invoice_date, "Invoice Date" %>
          <%= f.date_field :invoice_date, class: 'form-control' %>
        </div>
      </div>

      <div class="form-row" style="grid-template-columns:1fr 2fr">
        <div class="form-group">
          <%= f.label :delivery_date, "Delivery Date *" %>
          <%= f.date_field :delivery_date, class: 'form-control',
                value: invoice.delivery_date || Date.today %>
          <% if invoice.errors[:delivery_date].any? %>
            <div class="form-error"><%= invoice.errors[:delivery_date].first %></div>
          <% end %>
        </div>

        <div class="form-group">
          <label>Additional Info
            <button type="button" onclick="addMetaRow()"
                    style="margin-left:8px;background:var(--accent-dim);color:var(--accent);
                           border:1px solid var(--accent);border-radius:4px;padding:2px 10px;
                           font-size:11px;cursor:pointer;font-family:var(--mono)">+ Add Field</button>
          </label>
          <div id="meta-rows" style="display:flex;flex-direction:column;gap:8px;margin-top:6px">
            <% (invoice.metadata || {}).except('irn','ack_number','delivery_number','reverse_charge').each do |key, val| %>
              <div class="meta-row" style="display:flex;gap:8px;align-items:center">
                <input type="text" name="purchase_invoice[metadata][<%= key %>]" value="<%= key %>"
                       placeholder="Key"
                       style="width:140px;background:var(--bg);border:1px solid var(--border);
                              border-radius:5px;padding:7px 10px;color:var(--text);
                              font-family:var(--mono);font-size:12px;outline:none">
                <input type="text" name="purchase_invoice[metadata][<%= key %>]" value="<%= val %>"
                       placeholder="Value"
                       style="flex:1;background:var(--bg);border:1px solid var(--border);
                              border-radius:5px;padding:7px 10px;color:var(--text);
                              font-size:13px;outline:none">
                <button type="button" onclick="this.closest('.meta-row').remove()"
                        style="background:none;border:none;color:var(--danger);cursor:pointer;font-size:16px;padding:4px">×</button>
              </div>
            <% end %>
          </div>
          <div class="form-hint">Store extra details like IRN, ACK number, delivery note, etc.</div>
        </div>
      </div>
    </div>
  </div>

  <%# ══════════════════════════════════════════════════════
      INLINE SUPPLIER PANEL
  ══════════════════════════════════════════════════════ %>
  <div id="supplier-panel"
       style="display:none;background:var(--surface);border:1px solid var(--accent);
              border-radius:10px;padding:20px;margin-bottom:20px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
      <div style="font-family:var(--mono);font-size:11px;letter-spacing:0.1em;
                  text-transform:uppercase;color:var(--accent)">Add / Find Supplier</div>
      <button type="button" onclick="hideSupplierPanel()"
              style="background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:20px;line-height:1;padding:0 4px">×</button>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px">
      <div>
        <label style="display:block;font-size:12px;font-weight:500;color:var(--text-dim);margin-bottom:5px">Name *</label>
        <input type="text" id="sp-name" placeholder="Supplier name"
               style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px 10px;color:var(--text);font-size:13px;outline:none">
      </div>
      <div>
        <label style="display:block;font-size:12px;font-weight:500;color:var(--text-dim);margin-bottom:5px">GSTIN</label>
        <input type="text" id="sp-gstin" placeholder="e.g. 19AAACA3622K1ZS"
               style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px 10px;color:var(--text);font-family:var(--mono);font-size:12px;outline:none">
      </div>
      <div>
        <label style="display:block;font-size:12px;font-weight:500;color:var(--text-dim);margin-bottom:5px">PAN</label>
        <input type="text" id="sp-pan" placeholder="e.g. AAACA3622K"
               style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px 10px;color:var(--text);font-family:var(--mono);font-size:12px;outline:none">
      </div>
      <div>
        <label style="display:block;font-size:12px;font-weight:500;color:var(--text-dim);margin-bottom:5px">State</label>
        <input type="text" id="sp-state" placeholder="e.g. West Bengal"
               style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px 10px;color:var(--text);font-size:13px;outline:none">
      </div>
      <div>
        <label style="display:block;font-size:12px;font-weight:500;color:var(--text-dim);margin-bottom:5px">State Code</label>
        <input type="text" id="sp-state-code" placeholder="e.g. 19"
               style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px 10px;color:var(--text);font-family:var(--mono);font-size:12px;outline:none">
      </div>
      <div style="grid-column:1/-1">
        <label style="display:block;font-size:12px;font-weight:500;color:var(--text-dim);margin-bottom:5px">Address</label>
        <textarea id="sp-address" placeholder="Full address — building, street, city, PIN…"
                  rows="2"
                  style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px 10px;color:var(--text);font-size:12.5px;outline:none;resize:vertical"></textarea>
      </div>
    </div>
    <div id="sp-matches" style="display:none;margin-bottom:14px">
      <div style="font-size:11px;color:var(--text-dim);margin-bottom:6px">Existing suppliers found — click to use:</div>
      <div id="sp-match-list" style="display:flex;flex-wrap:wrap;gap:6px"></div>
    </div>
    <div id="sp-error" style="display:none;color:var(--danger);font-size:12px;margin-bottom:10px"></div>
    <div style="display:flex;gap:10px;align-items:center">
      <button type="button" id="sp-save-btn" onclick="saveSupplierInline()"
              style="background:var(--accent);color:#fff;border:none;border-radius:6px;padding:8px 18px;font-size:13px;font-weight:500;cursor:pointer">
        Save &amp; Use Supplier
      </button>
      <button type="button" onclick="hideSupplierPanel()"
              style="background:transparent;color:var(--text-dim);border:1px solid var(--border);border-radius:6px;padding:8px 16px;font-size:13px;cursor:pointer">Cancel</button>
      <span id="sp-saving" style="display:none;font-size:12px;color:var(--text-dim);font-family:var(--mono)">Saving…</span>
    </div>
  </div>

  <%# ══════════════════════════════════════════════════════
      SECTION 2 — Line Items Grid
  ══════════════════════════════════════════════════════ %>
  <div style="background:var(--surface);border:1px solid var(--border);
              border-radius:10px;overflow:hidden;margin-bottom:20px">

    <div style="padding:14px 20px;border-bottom:1px solid var(--border);
                display:flex;align-items:center;justify-content:space-between">
      <div style="font-family:var(--mono);font-size:11px;letter-spacing:0.1em;
                  text-transform:uppercase;color:var(--text-dim)">Invoice Items</div>
      <button type="button" onclick="addItemRow()"
              style="background:var(--accent-dim);color:var(--accent);border:1px solid var(--accent);
                     border-radius:5px;padding:5px 14px;font-size:12px;cursor:pointer;font-family:var(--mono)">
        + Add Row
      </button>
    </div>

    <%# ── Unmatched items warning banner ── %>
    <div id="unmatched-banner"
         style="display:none;margin-bottom:12px;padding:10px 14px;
                background:rgba(247,97,79,0.08);border:1px solid rgba(247,97,79,0.3);
                border-radius:6px;font-size:12px;color:var(--danger);
                display:flex;align-items:center;gap:8px">
      <span style="background:var(--danger);color:white;width:20px;height:20px;
                   border-radius:50%;display:flex;align-items:center;justify-content:center;
                   font-size:12px;font-weight:700;flex-shrink:0">!</span>
      <span>
        This invoice has <strong id="unmatched-count">0</strong> unmatched product(s).
        Click the red <strong>!</strong> on each item to look up details with AI.
        Stock will be updated on confirmation even for unmatched items.
      </span>
    </div>

    <div style="overflow-x:auto">
      <table style="width:100%;border-collapse:collapse" id="items-table">
        <thead>
          <tr style="background:var(--bg)">
            <%
              ths = [
                ["Product",     "min-width:240px", "left"],
                ["UOM",         "width:55px",       "center"],
                ["Qty",         "width:85px",       "right"],
                ["Disc %",      "width:75px",       "right"],
                ["Unit Rate",   "width:95px",       "right"],
                ["Total (₹)",   "width:105px",      "right"],
                ["CGST %",      "width:65px",       "right"],
                ["SGST %",      "width:65px",       "right"],
                ["",            "width:36px",       "center"],
              ]
            %>
            <% ths.each do |label, w, align| %>
              <th style="padding:9px 10px;text-align:<%= align %>;font-family:var(--mono);
                         font-size:10px;letter-spacing:0.07em;text-transform:uppercase;
                         color:var(--text-dim);border-bottom:1px solid var(--border);<%= w %>">
                <%= label %>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody id="items-tbody">
          <%= f.fields_for :purchase_invoice_items do |item_f| %>
            <%= render 'item_row', f: item_f, item: item_f.object %>
          <% end %>
        </tbody>
      </table>
    </div>

    <div style="padding:12px 20px;border-top:1px solid var(--border);
                display:flex;justify-content:flex-end;gap:32px">
      <div style="text-align:right">
        <div style="font-family:var(--mono);font-size:10px;letter-spacing:0.08em;
                    text-transform:uppercase;color:var(--text-dim);margin-bottom:4px">Total Items</div>
        <div style="font-family:var(--mono);font-size:16px;font-weight:600" id="total-items">0</div>
      </div>
      <div style="text-align:right">
        <div style="font-family:var(--mono);font-size:10px;letter-spacing:0.08em;
                    text-transform:uppercase;color:var(--text-dim);margin-bottom:4px">Grand Total (₹)</div>
        <div style="font-family:var(--mono);font-size:20px;font-weight:700;color:var(--accent)"
             id="grand-total">0.00</div>
      </div>
    </div>
  </div>

  <div style="display:flex;gap:12px;align-items:center">
    <%= f.submit invoice.new_record? ? 'Save Draft' : 'Update Invoice', class: 'btn btn-primary' %>
    <%= link_to 'Cancel',
          invoice.new_record? ? purchasing_purchase_invoices_path : purchasing_purchase_invoice_path(invoice),
          class: 'btn btn-secondary' %>
    <span style="font-size:12px;color:var(--text-dim)">
      Saved as draft. Confirm from detail view to update stock.
    </span>
  </div>

<% end %>

<%# ══════════════════════════════════════════════════════
    ROW TEMPLATE — new blank rows added by JS
══════════════════════════════════════════════════════ %>
<template id="item-row-template">
  <tr data-row="INDEX" style="border-bottom:1px solid var(--border)">
    <td style="padding:8px 12px;min-width:240px">
      <div class="autocomplete-wrap" style="position:relative">
        <input type="hidden"
               name="purchase_invoice[purchase_invoice_items_attributes][INDEX][product_id]"
               class="product-id-input" value="">
        <input type="text" class="product-search-input"
               placeholder="Search by name, code…" autocomplete="off"
               style="width:100%;background:var(--bg);border:1px solid var(--border);
                      border-radius:5px;padding:6px 9px;color:var(--text);font-size:12.5px;outline:none">
        <div class="product-meta-line"
             style="font-family:var(--mono);font-size:10px;color:var(--text-dim);margin-top:2px;min-height:13px"></div>
        <div class="ac-dropdown"
             style="display:none;position:absolute;top:100%;left:0;right:0;z-index:9999;
                    background:var(--surface);border:1px solid var(--border);border-radius:6px;
                    box-shadow:var(--shadow-lg);max-height:260px;overflow-y:auto;margin-top:2px"></div>
      </div>
    </td>
    <td class="uom-cell"
        style="padding:8px 10px;font-family:var(--mono);font-size:11px;color:var(--text-dim);
               white-space:nowrap;text-align:center">—</td>
    <td style="padding:6px 8px">
      <input type="number" class="qty-input"
             name="purchase_invoice[purchase_invoice_items_attributes][INDEX][quantity]"
             placeholder="0" min="0" step="0.001"
             style="width:80px;background:var(--bg);border:1px solid var(--border);
                    border-radius:5px;padding:6px 8px;color:var(--text);
                    font-family:var(--mono);font-size:12.5px;outline:none;text-align:right">
    </td>
    <td style="padding:6px 8px">
      <input type="number" class="discount-input"
             name="purchase_invoice[purchase_invoice_items_attributes][INDEX][metadata][discount_percent]"
             placeholder="0" min="0" max="100" step="0.01"
             style="width:70px;background:var(--bg);border:1px solid var(--border);
                    border-radius:5px;padding:6px 8px;color:var(--text);
                    font-family:var(--mono);font-size:12.5px;outline:none;text-align:right">
    </td>
    <td style="padding:6px 8px;text-align:right;font-family:var(--mono);font-size:12px;color:var(--text-dim)">
      <input type="hidden" class="rate-input"
             name="purchase_invoice[purchase_invoice_items_attributes][INDEX][unit_rate]"
             value="">
      <span class="rate-display">—</span>
    </td>
    <td style="padding:6px 8px">
      <input type="hidden" class="total-input"
             name="purchase_invoice[purchase_invoice_items_attributes][INDEX][total_amount]"
             value="">
      <input type="number" class="total-editable"
             placeholder="0.00" min="0" step="0.01"
             style="width:100px;background:var(--bg);border:1px solid var(--border);
                    border-radius:5px;padding:6px 8px;color:var(--text);
                    font-family:var(--mono);font-size:12.5px;outline:none;text-align:right">
    </td>
    <td style="padding:6px 8px">
      <input type="number" class="cgst-input"
             name="purchase_invoice[purchase_invoice_items_attributes][INDEX][metadata][cgst_percent]"
             placeholder="0" min="0" max="50" step="0.01"
             style="width:58px;background:var(--bg);border:1px solid var(--border);
                    border-radius:5px;padding:6px 7px;color:var(--text);
                    font-family:var(--mono);font-size:11px;outline:none;text-align:right">
    </td>
    <td style="padding:6px 8px">
      <input type="number" class="sgst-input"
             name="purchase_invoice[purchase_invoice_items_attributes][INDEX][metadata][sgst_percent]"
             placeholder="0" min="0" max="50" step="0.01"
             style="width:58px;background:var(--bg);border:1px solid var(--border);
                    border-radius:5px;padding:6px 7px;color:var(--text);
                    font-family:var(--mono);font-size:11px;outline:none;text-align:right">
    </td>
    <td style="padding:6px 8px;text-align:center">
      <button type="button" onclick="deleteRow(this)"
              style="background:none;border:none;color:var(--danger);cursor:pointer;font-size:18px;line-height:1;padding:2px 4px">×</button>
    </td>
  </tr>
</template>

<%# ══════════════════════════════════════════════════════
    JAVASCRIPT
══════════════════════════════════════════════════════ %>
<script>
(function() {

  var rowIndex = document.querySelectorAll('#items-tbody tr[data-row]').length;

  // ══════════════════════════════════════════════════════════════
  //  HELPERS
  // ══════════════════════════════════════════════════════════════
  function escHtml(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function selectedProductIds() {
    var ids = new Set();
    document.querySelectorAll('#items-tbody tr[data-row]').forEach(function(r) {
      if (r.style.display === 'none') return;
      var f = r.querySelector('.product-id-input');
      if (f && f.value) ids.add(String(f.value));
    });
    return ids;
  }

  // Get discount from row 1 (the first visible row)
  function getRow1Discount() {
    var first = document.querySelector('#items-tbody tr[data-row]:not([style*="display:none"])');
    if (!first) return '';
    var d = first.querySelector('.discount-input');
    return d ? d.value : '';
  }

  // ══════════════════════════════════════════════════════════════
  //  ROW CALCULATIONS
  //  User fills: qty, discount%, total_amount
  //  Calculated: unit_rate = total_amount / qty
  // ══════════════════════════════════════════════════════════════
  function recalcRow(row) {
    var qty      = parseFloat(row.querySelector('.qty-input').value)       || 0;
    var total    = parseFloat(row.querySelector('.total-editable').value)  || 0;
    var unitRate = (qty > 0 && total > 0) ? (total / qty) : 0;

    // Sync hidden inputs
    row.querySelector('.total-input').value = total > 0 ? total.toFixed(2) : '';
    row.querySelector('.rate-input').value  = unitRate > 0 ? unitRate.toFixed(4) : '';

    // Update rate display (read-only)
    var rateDisplay = row.querySelector('.rate-display');
    if (rateDisplay) {
      rateDisplay.textContent = unitRate > 0
        ? unitRate.toLocaleString('en-IN', {minimumFractionDigits: 2, maximumFractionDigits: 2})
        : '—';
      rateDisplay.style.color = unitRate > 0 ? 'var(--text)' : 'var(--text-dim)';
    }

    updateGrandTotal();
  }

  function updateGrandTotal() {
    var total = 0, count = 0;
    document.querySelectorAll('#items-tbody tr[data-row]').forEach(function(row) {
      if (row.style.display === 'none') return;
      var t = parseFloat(row.querySelector('.total-input').value) || 0;
      if (t > 0) { total += t; count++; }
    });
    document.getElementById('grand-total').textContent =
      total.toLocaleString('en-IN', {minimumFractionDigits: 2});
    document.getElementById('total-items').textContent = count;
  }

  function wireRowEvents(row) {
    // qty or total changes → recalc unit rate
    row.querySelector('.qty-input').addEventListener('input', function() { recalcRow(row); });
    row.querySelector('.total-editable').addEventListener('input', function() {
      // sync hidden total
      var t = parseFloat(this.value) || 0;
      row.querySelector('.total-input').value = t > 0 ? t.toFixed(2) : '';
      recalcRow(row);
    });

    // discount change on row 1 → push to all subsequent rows
    row.querySelector('.discount-input').addEventListener('input', function() {
      var rows = document.querySelectorAll('#items-tbody tr[data-row]');
      if (row === rows[0]) {
        var val = this.value;
        for (var i = 1; i < rows.length; i++) {
          if (rows[i].style.display === 'none') continue;
          var d = rows[i].querySelector('.discount-input');
          if (d) d.value = val;
        }
      }
    });
  }

  // ══════════════════════════════════════════════════════════════
  //  PRODUCT AUTOCOMPLETE
  // ══════════════════════════════════════════════════════════════
  function setupProductAutocomplete(row) {
    var wrap     = row.querySelector('.autocomplete-wrap');
    if (!wrap) return;
    var input    = wrap.querySelector('.product-search-input');
    var idField  = wrap.querySelector('.product-id-input');
    var dropdown = wrap.querySelector('.ac-dropdown');
    var metaLine = wrap.querySelector('.product-meta-line');
    var uomCell  = row.querySelector('.uom-cell');
    if (!input || !idField || !dropdown) return;

    var timer;
    input.addEventListener('input', function() {
      idField.value = '';
      if (metaLine) metaLine.textContent = '';
      clearTimeout(timer);
      var q = this.value.trim();
      if (q.length < 2) { dropdown.style.display = 'none'; return; }
      timer = setTimeout(function() {
        fetch('/purchasing/purchase_invoices/product_search?q=' + encodeURIComponent(q), {
          headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
          .then(function(r) { return r.json(); })
          .then(function(results) {
            renderProductDropdown(results, wrap, input, idField, dropdown, metaLine, uomCell, row);
          })
          .catch(function() { dropdown.style.display = 'none'; });
      }, 200);
    });

    input.addEventListener('blur', function() {
      setTimeout(function() { dropdown.style.display = 'none'; }, 200);
    });
  }

  function renderProductDropdown(results, wrap, input, idField, dropdown, metaLine, uomCell, row) {
    dropdown.innerHTML = '';
    var used     = selectedProductIds();
    used.delete(String(idField.value));
    var filtered = results.filter(function(p) { return !used.has(String(p.id)); });

    if (filtered.length === 0) {
      dropdown.innerHTML =
        '<div style="padding:10px 14px;color:var(--text-dim);font-size:13px">' +
        (results.length > 0 ? 'All matching products already added' : 'No products found') +
        '</div>';
      dropdown.style.display = 'block';
      return;
    }

    filtered.forEach(function(p) {
      var metaParts = [];
      if (p.material_code) metaParts.push('M: ' + p.material_code);
      if (p.pack_code)     metaParts.push('Pack: ' + p.pack_code);

      var el = document.createElement('div');
      el.style.cssText = 'padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border)';
      el.innerHTML =
        '<div style="font-size:13px;font-weight:500;color:var(--text)">' + escHtml(p.label) + '</div>' +
        (metaParts.length > 0
          ? '<div style="font-family:var(--mono);font-size:10px;color:var(--text-dim);margin-top:2px">' +
              escHtml(metaParts.join('  ·  ')) + '</div>'
          : '');

      el.addEventListener('mouseover', function() { this.style.background = 'var(--border)'; });
      el.addEventListener('mouseout',  function() { this.style.background = ''; });
      el.addEventListener('mousedown', function(e) {
        e.preventDefault();
        input.value   = p.label;
        idField.value = p.id;
        if (uomCell)  uomCell.textContent  = p.uom || '—';
        if (metaLine) metaLine.textContent = metaParts.join('  ·  ');

        // Auto-fill CGST/SGST from product.gst_rate
        if (p.cgst != null) {
          var cgst = row.querySelector('.cgst-input');
          var sgst = row.querySelector('.sgst-input');
          if (cgst) cgst.value = p.cgst;
          if (sgst) sgst.value = p.sgst;
        }
        dropdown.style.display = 'none';
      });
      dropdown.appendChild(el);
    });
    dropdown.style.display = 'block';
  }

  // ══════════════════════════════════════════════════════════════
  //  ADD / DELETE ROWS
  // ══════════════════════════════════════════════════════════════
  window.addItemRow = function() {
    var tmpl = document.getElementById('item-row-template').content.cloneNode(true);
    var row  = tmpl.querySelector('tr');
    var idx  = rowIndex++;
    row.innerHTML = row.innerHTML.replace(/INDEX/g, idx);
    row.setAttribute('data-row', idx);
    document.getElementById('items-tbody').appendChild(row);
    if (typeof wireEnrichTrigger === 'function') wireEnrichTrigger(row);

    // Copy discount from row 1
    var disc = getRow1Discount();
    if (disc) {
      var d = row.querySelector('.discount-input');
      if (d) d.value = disc;
    }

    setupProductAutocomplete(row);
    wireRowEvents(row);
  };

  window.deleteRow = function(btn) {
    var row = btn.closest('tr');
    var di  = row.querySelector('.destroy-input');
    if (di) { di.value = '1'; row.style.display = 'none'; }
    else    { row.remove(); }
    updateGrandTotal();
  };

  // ══════════════════════════════════════════════════════════════
  //  SUPPLIER AUTOCOMPLETE
  // ══════════════════════════════════════════════════════════════
  var supplierDebounce;
  document.getElementById('supplier-search-input').addEventListener('input', function() {
    var q = this.value.trim();
    document.getElementById('supplier_id_field').value = '';
    document.getElementById('supplier-info-strip').textContent = '';
    clearTimeout(supplierDebounce);
    if (q.length < 2) { document.getElementById('supplier-ac-dropdown').style.display = 'none'; return; }
    supplierDebounce = setTimeout(function() {
      fetch('/purchasing/suppliers/search?q=' + encodeURIComponent(q), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(function(results) { renderSupplierDropdown(results); })
        .catch(function() {});
    }, 200);
  });

  document.getElementById('supplier-search-input').addEventListener('blur', function() {
    setTimeout(function() { document.getElementById('supplier-ac-dropdown').style.display = 'none'; }, 200);
  });

  function renderSupplierDropdown(results) {
    var dd = document.getElementById('supplier-ac-dropdown');
    dd.innerHTML = '';
    if (results.length === 0) {
      dd.innerHTML = '<div style="padding:10px 14px;color:var(--text-dim);font-size:13px">No suppliers found — ' +
        '<a href="#" onclick="showSupplierPanel(event)" style="color:var(--accent)">add one</a></div>';
      dd.style.display = 'block'; return;
    }
    results.forEach(function(s) {
      var el = document.createElement('div');
      el.style.cssText = 'padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border)';
      var meta = [s.gstin ? 'GSTIN: ' + s.gstin : null, s.state].filter(Boolean).join('  ·  ');
      el.innerHTML =
        '<div style="font-size:13px;font-weight:500;color:var(--text)">' + escHtml(s.name) + '</div>' +
        (meta ? '<div style="font-family:var(--mono);font-size:10px;color:var(--text-dim);margin-top:2px">' + escHtml(meta) + '</div>' : '');
      el.addEventListener('mouseover', function() { this.style.background = 'var(--border)'; });
      el.addEventListener('mouseout',  function() { this.style.background = ''; });
      el.addEventListener('mousedown', function(e) { e.preventDefault(); selectSupplier(s); dd.style.display = 'none'; });
      dd.appendChild(el);
    });
    dd.style.display = 'block';
  }

  function selectSupplier(s) {
    document.getElementById('supplier-search-input').value = s.name;
    document.getElementById('supplier_id_field').value = s.id;
    var parts = [];
    if (s.gstin)   parts.push('GSTIN: ' + s.gstin);
    if (s.state)   parts.push(s.state);
    if (s.pan)     parts.push('PAN: ' + s.pan);
    if (s.address) parts.push(s.address);
    document.getElementById('supplier-info-strip').textContent = parts.join('  ·  ');
  }

  // ══════════════════════════════════════════════════════════════
  //  INLINE SUPPLIER PANEL
  // ══════════════════════════════════════════════════════════════
  window.showSupplierPanel = function(e) {
    if (e) e.preventDefault();
    var q = document.getElementById('supplier-search-input').value.trim();
    if (q) document.getElementById('sp-name').value = q;
    document.getElementById('supplier-panel').style.display = 'block';
    document.getElementById('sp-name').focus();
  };
  window.hideSupplierPanel = function() {
    document.getElementById('supplier-panel').style.display = 'none';
    document.getElementById('sp-error').style.display = 'none';
    document.getElementById('sp-matches').style.display = 'none';
  };

  var spDebounce;
  document.getElementById('sp-name').addEventListener('input', function() {
    clearTimeout(spDebounce);
    var q = this.value.trim();
    if (q.length < 2) { document.getElementById('sp-matches').style.display = 'none'; return; }
    spDebounce = setTimeout(function() {
      fetch('/purchasing/suppliers/search?q=' + encodeURIComponent(q), { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(function(results) {
          if (!results.length) { document.getElementById('sp-matches').style.display = 'none'; return; }
          var list = document.getElementById('sp-match-list');
          list.innerHTML = '';
          results.forEach(function(s) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.style.cssText = 'background:var(--accent-dim);color:var(--accent);border:1px solid var(--accent);border-radius:5px;padding:5px 12px;font-size:12px;cursor:pointer;font-family:var(--mono)';
            btn.textContent = s.name + (s.gstin ? ' · ' + s.gstin : '');
            btn.addEventListener('click', function() { selectSupplier(s); hideSupplierPanel(); });
            list.appendChild(btn);
          });
          document.getElementById('sp-matches').style.display = 'block';
        });
    }, 300);
  });

  window.saveSupplierInline = function() {
    var name = document.getElementById('sp-name').value.trim();
    var errEl = document.getElementById('sp-error');
    errEl.style.display = 'none';
    if (!name) { errEl.textContent = 'Supplier name is required.'; errEl.style.display = 'block'; return; }
    var savingEl = document.getElementById('sp-saving');
    savingEl.style.display = 'inline';
    document.getElementById('sp-save-btn').disabled = true;
    fetch('/purchasing/suppliers', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json',
                 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content'),
                 'Accept': 'application/json' },
      body: JSON.stringify({ supplier: {
        name:       name,
        gstin:      document.getElementById('sp-gstin').value.trim(),
        pan:        document.getElementById('sp-pan').value.trim(),
        state:      document.getElementById('sp-state').value.trim(),
        state_code: document.getElementById('sp-state-code').value.trim(),
        active:     true,
        metadata:   { address: document.getElementById('sp-address').value.trim() }
      }})
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        savingEl.style.display = 'none';
        document.getElementById('sp-save-btn').disabled = false;
        if (data.errors) { errEl.textContent = data.errors.join(', '); errEl.style.display = 'block'; }
        else { selectSupplier(data); hideSupplierPanel(); }
      })
      .catch(function() {
        savingEl.style.display = 'none';
        document.getElementById('sp-save-btn').disabled = false;
        errEl.textContent = 'Save failed — please try again.';
        errEl.style.display = 'block';
      });
  };

  // ══════════════════════════════════════════════════════════════
  //  METADATA ROWS
  // ══════════════════════════════════════════════════════════════
  window.addMetaRow = function() {
    var ts  = Date.now();
    var div = document.createElement('div');
    div.className = 'meta-row';
    div.style.cssText = 'display:flex;gap:8px;align-items:center';
    div.innerHTML =
      '<input type="text" name="purchase_invoice[metadata][key_' + ts + ']" placeholder="Key" ' +
      'style="width:140px;background:var(--bg);border:1px solid var(--border);border-radius:5px;padding:7px 10px;color:var(--text);font-family:var(--mono);font-size:12px;outline:none">' +
      '<input type="text" name="purchase_invoice[metadata][val_' + ts + ']" placeholder="Value" ' +
      'style="flex:1;background:var(--bg);border:1px solid var(--border);border-radius:5px;padding:7px 10px;color:var(--text);font-size:13px;outline:none">' +
      '<button type="button" onclick="this.closest(\'.meta-row\').remove()" ' +
      'style="background:none;border:none;color:var(--danger);cursor:pointer;font-size:16px;padding:4px">×</button>';
    document.getElementById('meta-rows').appendChild(div);
  };

  // ══════════════════════════════════════════════════════════════
  //  INIT
  // ══════════════════════════════════════════════════════════════
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('#items-tbody tr[data-row]').forEach(function(row) {
      setupProductAutocomplete(row);
      wireRowEvents(row);
    });
    updateGrandTotal();
    updateUnmatchedBanner();
  });

})();
</script>

<%# ══ PRODUCT ENRICHMENT JS ══════════════════════════════════════ %>
<script>
(function() {
  // ── CSS spin animation ──
  if (!document.getElementById('enrich-spin-style')) {
    var style = document.createElement('style');
    style.id = 'enrich-spin-style';
    style.textContent = '@keyframes spin { to { transform: rotate(360deg); } }';
    document.head.appendChild(style);
  }

  // ── Update the unmatched warning banner ──────────────────────
  window.updateUnmatchedBanner = function() {
    var rows     = document.querySelectorAll('#items-tbody tr[data-row]');
    var count    = 0;
    rows.forEach(function(r) {
      if (r.getAttribute('data-unmatched') === 'true' &&
          r.style.display !== 'none') count++;
    });
    var banner = document.getElementById('unmatched-banner');
    var countEl = document.getElementById('unmatched-count');
    if (!banner) return;
    if (count > 0) {
      banner.style.display = 'flex';
      if (countEl) countEl.textContent = count;
    } else {
      banner.style.display = 'none';
    }
  };

  // ── Panel open/close ─────────────────────────────────────────
  window.closeEnrichPanel = function(rowIdx) {
    var panel = document.querySelector('.enrich-panel[data-row="' + rowIdx + '"]');
    if (panel) panel.style.display = 'none';
  };

  // Close panels when clicking outside
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.enrich-panel') && !e.target.closest('.enrich-trigger')) {
      document.querySelectorAll('.enrich-panel').forEach(function(p) {
        p.style.display = 'none';
      });
    }
  });

  // ── Wire enrich triggers (called for each row) ───────────────
  window.wireEnrichTrigger = function(row) {
    var trigger = row.querySelector('.enrich-trigger');
    if (!trigger) return;
    trigger.addEventListener('click', function(e) {
      e.stopPropagation();
      var rowIdx = trigger.getAttribute('data-row');
      var name   = trigger.getAttribute('data-name') || '';
      var code   = trigger.getAttribute('data-code') || '';

      // Close any other open panels first
      document.querySelectorAll('.enrich-panel').forEach(function(p) {
        if (p.getAttribute('data-row') !== rowIdx) p.style.display = 'none';
      });

      var panel = row.querySelector('.enrich-panel[data-row="' + rowIdx + '"]');
      if (!panel) return;

      // Toggle — if already open, close
      if (panel.style.display !== 'none') {
        panel.style.display = 'none';
        return;
      }

      // Show loading state
      panel.style.display = 'block';
      panel.querySelector('.enrich-loading').style.display = 'block';
      panel.querySelector('.enrich-result').style.display  = 'none';
      panel.querySelector('.enrich-error').style.display   = 'none';
      panel.querySelector('.enrich-saved-msg').style.display = 'none';

      // Call enrichment API
      fetchEnrichment(panel, rowIdx, name, code);
    });
  };

  // ── Fetch enrichment from server ─────────────────────────────
  function fetchEnrichment(panel, rowIdx, name, code) {
    var csrfToken = document.querySelector('meta[name="csrf-token"]');
    var token = csrfToken ? csrfToken.getAttribute('content') : '';

    fetch('<%= purchasing_enrich_product_path %>', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': token
      },
      body: JSON.stringify({
        name:              name,
        material_code_hint: code
      })
    })
    .then(function(r) { return r.json(); })
    .then(function(resp) {
      panel.querySelector('.enrich-loading').style.display = 'none';

      if (resp.success) {
        showEnrichResult(panel, rowIdx, name, code, resp);
      } else {
        showEnrichError(panel, resp.error || 'Could not fetch details', resp.images_url);
      }
    })
    .catch(function(err) {
      panel.querySelector('.enrich-loading').style.display = 'none';
      showEnrichError(panel, 'Network error — ' + err.message, null);
    });
  }

  // ── Render enrichment result ──────────────────────────────────
  function showEnrichResult(panel, rowIdx, originalName, originalCode, resp) {
    var d = resp.data;
    var resultEl = panel.querySelector('.enrich-result');
    resultEl.style.display = 'block';

    // Store data on panel for confirm/reject
    panel._enrichData  = d;
    panel._originalName = originalName;
    panel._originalCode = originalCode;
    panel._imagesUrl    = resp.images_url;

    // Confidence badge
    var badge = panel.querySelector('.enrich-confidence-badge');
    var conf  = (d.confidence || 0) * 100;
    var confColor = conf >= 80 ? '#34d98b' : conf >= 50 ? '#f7c34f' : '#f7614f';
    badge.style.background = confColor + '22';
    badge.style.color = confColor;
    badge.style.border = '1px solid ' + confColor + '44';
    badge.textContent = resp.confidence_label + ' (' + Math.round(conf) + '%)';

    // Fields
    var fields = panel.querySelector('.enrich-fields');
    var rows = [
      ['Description',  d.description    || '—'],
      ['Material Code',d.material_code  || '—'],
      ['HSN Code',     d.hsn_code       || '—'],
      ['GST Rate',     d.gst_rate != null ? d.gst_rate + '%' : '—'],
      ['Category',     d.category_guess || '—'],
      ['Brand',        d.brand_guess    || '—'],
      ['Pack Size',    d.pack_size_guess || '—'],
    ];
    fields.innerHTML = rows.map(function(r) {
      return '<div style="display:flex;gap:8px;padding:2px 0">' +
             '<span style="color:var(--text-dim);min-width:110px;flex-shrink:0">' + r[0] + '</span>' +
             '<span style="color:var(--text);font-weight:500">' + escHtml(r[1]) + '</span>' +
             '</div>';
    }).join('');

    // Images link
    if (resp.images_url) {
      panel.querySelector('.enrich-images-link').href = resp.images_url;
    }

    // Wire confirm/reject buttons
    var confirmBtn = panel.querySelector('.enrich-confirm-btn');
    var rejectBtn  = panel.querySelector('.enrich-reject-btn');

    // Remove old listeners by cloning
    var newConfirm = confirmBtn.cloneNode(true);
    var newReject  = rejectBtn.cloneNode(true);
    confirmBtn.parentNode.replaceChild(newConfirm, confirmBtn);
    rejectBtn.parentNode.replaceChild(newReject, rejectBtn);

    newConfirm.addEventListener('click', function() {
      saveEnrichedProduct(panel, rowIdx, 'confirm');
    });
    newReject.addEventListener('click', function() {
      saveEnrichedProduct(panel, rowIdx, 'reject');
    });
  }

  function showEnrichError(panel, errorMsg, imagesUrl) {
    var errorEl = panel.querySelector('.enrich-error');
    errorEl.style.display = 'block';
    errorEl.querySelector('.enrich-error-msg').textContent = errorMsg;
    if (imagesUrl) {
      errorEl.querySelector('.enrich-images-link-error').href = imagesUrl;
      errorEl.querySelector('.enrich-images-link-error').style.display = 'inline';
    } else {
      errorEl.querySelector('.enrich-images-link-error').style.display = 'none';
    }
  }

  // ── Save enriched product (confirm or reject) ─────────────────
  function saveEnrichedProduct(panel, rowIdx, action) {
    var d    = panel._enrichData || {};
    var csrfToken = document.querySelector('meta[name="csrf-token"]');
    var token = csrfToken ? csrfToken.getAttribute('content') : '';

    // Disable both buttons while saving
    panel.querySelectorAll('.enrich-confirm-btn, .enrich-reject-btn').forEach(function(b) {
      b.disabled = true;
      b.style.opacity = '0.5';
    });

    fetch('<%= purchasing_save_enriched_product_path %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token },
      body: JSON.stringify({
        action_taken:     action,
        original_name:    panel._originalName,
        description:      d.description,
        material_code:    d.material_code,
        hsn_code:         d.hsn_code,
        gst_rate:         d.gst_rate,
        category_guess:   d.category_guess,
        brand_guess:      d.brand_guess,
        pack_size_guess:  d.pack_size_guess,
        confidence:       d.confidence,
        ai_notes:         d.notes
      })
    })
    .then(function(r) { return r.json(); })
    .then(function(resp) {
      if (resp.success) {
        // Update the item row: set product_id, clear unmatched state
        var row = document.querySelector('#items-tbody tr[data-row="' + rowIdx + '"]');
        if (row && resp.product_id) {
          var pidInput = row.querySelector('.product-id-input');
          if (pidInput) pidInput.value = resp.product_id;
          row.setAttribute('data-unmatched', 'false');

          // Update the ! button to ⏳ pending badge
          var trigger = row.querySelector('.enrich-trigger');
          if (trigger) {
            trigger.outerHTML = '<span title="AI-enriched — awaiting admin approval" ' +
              'style="flex-shrink:0;width:26px;height:26px;border-radius:50%;' +
              'background:var(--warning);display:flex;align-items:center;' +
              'justify-content:center;font-size:11px;font-weight:700;color:#1a1a1a">⏳</span>';
          }

          // Update search input border
          var searchInput = row.querySelector('.product-search-input');
          if (searchInput) searchInput.style.borderColor = 'var(--warning)';

          // Update meta line
          var metaLine = row.querySelector('.product-meta-line');
          if (metaLine) {
            metaLine.innerHTML = '<span style="color:var(--warning)">Saved — [PENDING APPROVAL]</span>';
          }
        }

        // Show saved message
        var savedMsg = panel.querySelector('.enrich-saved-msg');
        savedMsg.style.display = 'block';
        savedMsg.textContent = resp.message;

        // Hide action buttons
        panel.querySelectorAll('.enrich-confirm-btn, .enrich-reject-btn').forEach(function(b) {
          b.style.display = 'none';
        });

        // Update banner count
        updateUnmatchedBanner();

        // Auto-close panel after 2s
        setTimeout(function() { panel.style.display = 'none'; }, 2000);
      } else {
        panel.querySelectorAll('.enrich-confirm-btn, .enrich-reject-btn').forEach(function(b) {
          b.disabled = false;
          b.style.opacity = '1';
        });
        alert('Could not save product: ' + (resp.error || 'Unknown error'));
      }
    })
    .catch(function(err) {
      alert('Network error: ' + err.message);
    });
  }

  // ── Wire enrichment on existing rows ────────────────────────
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('#items-tbody tr[data-row]').forEach(function(row) {
      wireEnrichTrigger(row);
    });
    updateUnmatchedBanner();
  });

  // ── Utility ─────────────────────────────────────────────────
  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

})();
</script>
