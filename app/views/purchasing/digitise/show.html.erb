<%# app/views/purchasing/digitise/show.html.erb %>
<% content_for :title, "Scan: #{@import.file_name}" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Purchasing</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Digitise', purchasing_digitise_index_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current"><%= @import.file_name %></span>
<% end %>

<% hdr  = @import.parsed_header %>
<% sup  = @import.parsed_supplier %>
<% items = @import.parsed_items %>

<%# ── PROCESSING STATE ── %>
<% if %w[pending processing retrying].include?(@import.status) %>

  <div style="max-width:560px;margin:48px auto">

    <%# Spinner + status %>
    <div style="text-align:center;margin-bottom:32px">
      <div id="spinner" style="width:56px;height:56px;border-radius:50%;border:3px solid var(--border);
                  border-top-color:var(--accent);animation:spin 0.9s linear infinite;
                  margin:0 auto 20px"></div>
      <% if @import.status == 'retrying' %>
        <div id="status-label" style="font-size:17px;font-weight:600;color:var(--warning);margin-bottom:6px">
          Rate limited — waiting to retry…
        </div>
        <div style="font-size:12px;color:var(--text-dim);margin-bottom:4px">
          Free tier limit hit. Next attempt in ~60s.
        </div>
      <% else %>
        <div id="status-label" style="font-size:17px;font-weight:600;color:var(--text);margin-bottom:6px">
          AI is reading your invoice…
        </div>
      <% end %>
      <div style="font-size:12px;color:var(--text-dim);margin-bottom:4px">
        <strong style="font-family:var(--mono);color:var(--accent)"><%= @import.file_name %></strong>
      </div>
      <div id="attempt-label" style="font-size:11px;color:var(--text-dim);margin-bottom:8px">
        Attempt <span id="attempt-num"><%= @import.attempt_count.zero? ? 1 : @import.attempt_count %></span> of <%= DigitiseImportJob::MAX_ATTEMPTS %>
      </div>
      <div style="font-size:11px;color:var(--text-dim);margin-bottom:20px">
        Provider: <span style="font-family:var(--mono);color:var(--accent)">
          <%= ENV['INVOICE_AI_PROVIDER']&.upcase || 'GEMINI' %>
        </span>
      </div>

      <%# Stop button %>
      <%= button_to 'Stop', stop_purchasing_digitise_path(@import), method: :post,
            id: 'stop-btn',
            style: 'background:transparent;border:1px solid var(--border);color:var(--text-dim);
                    font-size:12px;padding:6px 18px;border-radius:6px;cursor:pointer' %>
    </div>

    <%# Attempt log (live-updated) %>
    <div id="attempt-log">
      <% if @import.attempt_log.any? %>
        <div style="font-size:11px;font-weight:600;color:var(--text-dim);text-transform:uppercase;
                    letter-spacing:.06em;margin-bottom:8px">Attempt Log</div>
        <% @import.attempt_log.each do |entry| %>
          <div style="border:1px solid var(--border);border-radius:8px;margin-bottom:10px;overflow:hidden">
            <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;
                        background:var(--surface);border-bottom:1px solid var(--border)">
              <span style="font-size:11px;font-family:var(--mono);color:var(--text-dim)">
                #<%= entry['attempt'] %>
              </span>
              <% if entry['success'] %>
                <span style="font-size:11px;color:var(--success);font-weight:600">✓ Success</span>
              <% else %>
                <span style="font-size:11px;color:var(--danger);font-weight:600">✗ Failed</span>
              <% end %>
              <span style="font-size:11px;color:var(--text-dim);margin-left:auto">
                <%= entry['at'] ? Time.parse(entry['at']).strftime('%H:%M:%S') : '' %>
              </span>
            </div>
            <% if entry['error'].present? %>
              <div style="padding:10px 14px">
                <div style="font-size:11px;color:var(--text-dim);margin-bottom:6px">Error</div>
                <pre style="margin:0;font-size:11px;font-family:var(--mono);color:var(--danger);
                            white-space:pre-wrap;word-break:break-all"><%= entry['error'] %></pre>
              </div>
            <% end %>
            <% if entry['response'].present? %>
              <div style="padding:0 14px 10px">
                <div style="font-size:11px;color:var(--text-dim);margin-bottom:6px">Raw Response</div>
                <pre style="margin:0;padding:8px 10px;background:var(--bg);border:1px solid var(--border);
                            border-radius:6px;font-size:10px;font-family:var(--mono);color:var(--text-dim);
                            max-height:120px;overflow-y:auto;white-space:pre-wrap;word-break:break-all"><%= entry['response'] %></pre>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

  </div>

  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
  <script>
    var MAX_POLL = 60;   // stop polling after 60 × 3s = 3 minutes
    var polls    = 0;
    var pollUrl  = '<%= purchasing_digitise_path(@import, format: :json) %>';

    function renderLog(entries) {
      if (!entries || !entries.length) return;
      var html = '<div style="font-size:11px;font-weight:600;color:var(--text-dim);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Attempt Log</div>';
      entries.forEach(function(e) {
        var successColor = e.success ? 'var(--success)' : 'var(--danger)';
        var successLabel = e.success ? '✓ Success' : '✗ Failed';
        var time = e.at ? new Date(e.at).toLocaleTimeString() : '';
        html += '<div style="border:1px solid var(--border);border-radius:8px;margin-bottom:10px;overflow:hidden">';
        html += '<div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--surface);border-bottom:1px solid var(--border)">';
        html += '<span style="font-size:11px;font-family:var(--mono);color:var(--text-dim)">#' + e.attempt + '</span>';
        html += '<span style="font-size:11px;color:' + successColor + ';font-weight:600">' + successLabel + '</span>';
        html += '<span style="font-size:11px;color:var(--text-dim);margin-left:auto">' + time + '</span>';
        html += '</div>';
        if (e.error) {
          html += '<div style="padding:10px 14px"><div style="font-size:11px;color:var(--text-dim);margin-bottom:6px">Error</div>';
          html += '<pre style="margin:0;font-size:11px;font-family:var(--mono);color:var(--danger);white-space:pre-wrap;word-break:break-all">' + e.error + '</pre></div>';
        }
        if (e.response) {
          html += '<div style="padding:0 14px 10px"><div style="font-size:11px;color:var(--text-dim);margin-bottom:6px">Raw Response</div>';
          html += '<pre style="margin:0;padding:8px 10px;background:var(--bg);border:1px solid var(--border);border-radius:6px;font-size:10px;font-family:var(--mono);color:var(--text-dim);max-height:120px;overflow-y:auto;white-space:pre-wrap;word-break:break-all">' + e.response + '</pre></div>';
        }
        html += '</div>';
      });
      document.getElementById('attempt-log').innerHTML = html;
    }

    (function poll() {
      polls++;
      if (polls > MAX_POLL) {
        document.getElementById('spinner').style.borderTopColor = 'var(--warning)';
        document.getElementById('status-label').textContent = 'Taking longer than expected…';
        document.getElementById('status-label').style.color = 'var(--warning)';
        return;
      }

      setTimeout(function() {
        fetch(pollUrl, { headers: { 'Accept': 'application/json' } })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            // Update attempt number
            if (data.attempt) {
              document.getElementById('attempt-num').textContent = data.attempt;
            }
            // Update log live
            if (data.attempt_log) {
              renderLog(data.attempt_log);
            }
            // retrying = waiting between attempts, update UI but keep polling
            if (data.status === 'retrying') {
              var lbl = document.getElementById('status-label');
              if (lbl) { lbl.textContent = 'Rate limited — waiting to retry…'; lbl.style.color = 'var(--warning)'; }
            }
            if (data.terminal) {
              location.reload();
            } else {
              poll();
            }
          })
          .catch(function() { poll(); });
      }, 3000);
    })();
  </script>

<%# ── STOPPED STATE ── %>
<% elsif @import.status == 'stopped' %>

  <div style="max-width:560px">
    <div class="flash notice" style="margin-bottom:20px">
      <strong>Processing stopped</strong>
      <div style="margin-top:4px;font-size:12px;color:var(--text-dim)">You stopped the AI extraction.</div>
    </div>
    <div style="display:flex;gap:10px">
      <%= button_to 'Try Again', retry_purchasing_digitise_path(@import), method: :post, class: 'btn btn-primary' %>
      <%= link_to 'Upload different file', new_purchasing_digitise_path, class: 'btn btn-secondary' %>
    </div>
  </div>

<%# ── FAILED STATE ── %>
<% elsif @import.status == 'failed' %>

  <div style="max-width:680px">
    <div class="flash alert" style="margin-bottom:20px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
        <strong>AI extraction failed</strong>
        <span style="font-family:var(--mono);font-size:10px;color:var(--text-dim)">
          <%= @import.updated_at.strftime('%d %b %Y, %H:%M') %>
        </span>
      </div>
      <%# Pretty-print if it looks like JSON, otherwise show raw %>
      <% err = @import.error_message.to_s %>
      <% json_match = err.match(/HTTP \d+:\s*(\{.+)/m) %>
      <% if json_match %>
        <div style="margin-bottom:8px;font-size:12px;color:var(--text)">
          <%= err.split(':').first(3).join(':') %>
        </div>
        <pre style="background:var(--bg);border:1px solid var(--border);border-radius:6px;
                    padding:12px 14px;font-size:11px;font-family:var(--mono);color:var(--text-dim);
                    overflow-x:auto;white-space:pre-wrap;word-break:break-all;margin:0"><%= begin; JSON.pretty_generate(JSON.parse(json_match[1])); rescue; json_match[1]; end %></pre>
      <% else %>
        <pre style="background:var(--bg);border:1px solid var(--border);border-radius:6px;
                    padding:12px 14px;font-size:11px;font-family:var(--mono);color:var(--text-dim);
                    overflow-x:auto;white-space:pre-wrap;word-break:break-all;margin:0"><%= err %></pre>
      <% end %>
      <% if err.include?('429') %>
        <div style="margin-top:10px;padding:10px 12px;background:rgba(247,195,79,0.08);
                    border:1px solid rgba(247,195,79,0.3);border-radius:6px;font-size:12px;color:var(--warning)">
          <strong>Rate limit hit.</strong>
          Free tier allows 15 requests/minute. Wait a minute then click Retry — the job will
          automatically retry up to 3 times with backoff.
        </div>
      <% end %>
    </div>
    <%# Attempt log %>
    <% if @import.attempt_log.any? %>
      <div style="margin-bottom:20px">
        <div style="font-size:11px;font-weight:600;color:var(--text-dim);text-transform:uppercase;
                    letter-spacing:.06em;margin-bottom:8px">Attempt Log</div>
        <% @import.attempt_log.each do |entry| %>
          <div style="border:1px solid var(--border);border-radius:8px;margin-bottom:10px;overflow:hidden">
            <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;
                        background:var(--surface);border-bottom:1px solid var(--border)">
              <span style="font-size:11px;font-family:var(--mono);color:var(--text-dim)">#<%= entry['attempt'] %></span>
              <span style="font-size:11px;color:var(--danger);font-weight:600">✗ Failed</span>
              <span style="font-size:11px;color:var(--text-dim);margin-left:auto">
                <%= entry['at'] ? Time.parse(entry['at']).strftime('%H:%M:%S') : '' %>
              </span>
            </div>
            <% if entry['error'].present? %>
              <div style="padding:10px 14px">
                <div style="font-size:11px;color:var(--text-dim);margin-bottom:4px">Error</div>
                <pre style="margin:0;font-size:11px;font-family:var(--mono);color:var(--danger);
                            white-space:pre-wrap;word-break:break-all"><%= entry['error'] %></pre>
              </div>
            <% end %>
            <% if entry['response'].present? %>
              <div style="padding:0 14px 10px">
                <div style="font-size:11px;color:var(--text-dim);margin-bottom:4px">Raw Response</div>
                <pre style="margin:0;padding:8px 10px;background:var(--bg);border:1px solid var(--border);
                            border-radius:6px;font-size:10px;font-family:var(--mono);color:var(--text-dim);
                            max-height:150px;overflow-y:auto;white-space:pre-wrap;word-break:break-all"><%= entry['response'] %></pre>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div style="display:flex;gap:10px">
      <%= button_to 'Retry', retry_purchasing_digitise_path(@import), method: :post,
            class: 'btn btn-primary' %>
      <%= link_to 'Upload different file', new_purchasing_digitise_path, class: 'btn btn-secondary' %>
    </div>
  </div>

<%# ── CONFIRMED STATE ── %>
<% elsif @import.status == 'confirmed' %>

  <div style="max-width:520px;text-align:center;padding:48px 0">
    <div style="font-size:32px;margin-bottom:12px">✓</div>
    <div style="font-size:16px;font-weight:600;color:var(--success);margin-bottom:8px">Invoice saved successfully</div>
    <div style="font-size:13px;color:var(--text-dim);margin-bottom:24px">
      This scan was converted to Purchase Invoice
      <strong style="color:var(--text)">#<%= @import.purchase_invoice_id %></strong>
    </div>
    <%= link_to 'View Invoice', purchasing_purchase_invoice_path(@import.purchase_invoice_id),
          class: 'btn btn-primary' %>
    <%= link_to 'Scan Another', new_purchasing_digitise_path, class: 'btn btn-secondary' %>
  </div>

<%# ── REVIEW STATE — main content ── %>
<% elsif @import.status == 'review' %>

  <style>
    .pv-wrap  { width: 100%; }
    .pv-banner {
      display: flex; align-items: center; gap: 16px;
      background: rgba(79,142,247,0.07);
      border: 1px solid rgba(79,142,247,0.25);
      border-radius: 10px; padding: 14px 20px;
    }
    .pv-banner-icon  { font-size: 26px; flex-shrink: 0; }
    .pv-banner-text  { flex: 1; }
    .pv-banner-title { font-size: 14px; font-weight: 700; color: var(--accent); margin-bottom: 2px; }
    .pv-banner-sub   { font-size: 12px; color: var(--text-dim); }
    /* Full width for the review page */
    .main-content { max-width: 100% !important; }
    .form-card { max-width: 100% !important; }
    .page-content { padding: 20px 24px !important; }
  </style>

  <%= form_with url: confirm_purchasing_digitise_path(@import), method: :post,
        local: true, id: 'confirm-form' do |f| %>

    <%# Review banner %>
    <div class="pv-wrap" style="margin-bottom:20px">
      <div class="pv-banner">
        <div class="pv-banner-icon">🤖</div>
        <div class="pv-banner-text">
          <div class="pv-banner-title">Review AI-extracted data before saving</div>
          <div class="pv-banner-sub">
            Check every field — especially material codes, quantities and totals.
            Edit anything the AI got wrong. Unmatched items can be linked to products after saving.
          </div>
        </div>
        <div style="margin-left:auto;display:flex;gap:10px;flex-shrink:0;align-items:center">
          <%= link_to '← Back', purchasing_digitise_index_path, class: 'btn btn-secondary' %>
          <button type="submit" class="btn btn-primary" id="save-btn">Save as Draft →</button>
        </div>
      </div>
    </div>

    <%# ── SUPPLIER CARD ── %>
    <div class="form-card" style="margin-bottom:18px">
      <div class="form-section">
        <div class="form-section-title">Supplier</div>
        <div class="form-row" style="grid-template-columns:2fr 1fr 1fr;gap:16px">
          <div class="form-group" style="margin-bottom:0">
            <label>Supplier Name</label>
            <input type="text" name="parsed_data[supplier][name]"
                   value="<%= sup['name'] %>" class="form-control">
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label>GSTIN</label>
            <input type="text" name="parsed_data[supplier][gstin]"
                   value="<%= sup['gstin'] %>"
                   class="form-control" style="font-family:var(--mono)">
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label>State</label>
            <input type="text" name="parsed_data[supplier][state]"
                   value="<%= sup['state'] %>" class="form-control">
          </div>
        </div>
      </div>
    </div>

    <%# ── INVOICE HEADER CARD ── %>
    <div class="form-card" style="margin-bottom:18px">
      <div class="form-section">
        <div class="form-section-title">Invoice Details</div>
        <div class="form-row" style="grid-template-columns:1fr 1fr 1fr 1fr;gap:16px;margin-bottom:16px">
          <div class="form-group" style="margin-bottom:0">
            <label>Invoice Number</label>
            <input type="text" name="parsed_data[header][invoice_number]"
                   value="<%= hdr['invoice_number'] %>"
                   class="form-control" style="font-family:var(--mono)">
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label>Invoice Date</label>
            <input type="date" name="parsed_data[header][invoice_date]"
                   value="<%= hdr['invoice_date'] %>" class="form-control">
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label>Delivery Date</label>
            <input type="date" name="parsed_data[header][delivery_date]"
                   value="<%= hdr['delivery_date'] %>" class="form-control">
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label style="color:var(--accent)">📅 Payment Due Date</label>
            <input type="date" name="payment_due_date" class="form-control"
                   style="border-color:rgba(79,142,247,0.5)">
            <div class="form-hint">For credit purchases</div>
          </div>
        </div>
        <div class="form-row" style="grid-template-columns:1fr 1fr 1fr 1fr;gap:16px">
          <div class="form-group" style="margin-bottom:0">
            <label>Delivery / LR No.</label>
            <input type="text" name="parsed_data[header][delivery_number]"
                   value="<%= hdr['delivery_number'].presence || hdr['lr_number'] %>"
                   class="form-control" style="font-family:var(--mono)">
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label>Place of Supply</label>
            <input type="text" name="parsed_data[header][place_of_supply]"
                   value="<%= hdr['place_of_supply'] %>"
                   class="form-control">
          </div>
          <div class="form-group" style="margin-bottom:0">
            <label>Grand Total (Rs.)</label>
            <input type="number" name="parsed_data[header][total_amount]"
                   value="<%= hdr['total_amount'] %>"
                   class="form-control" style="font-family:var(--mono);font-weight:600;color:var(--accent)" step="0.01">
          </div>
        </div>
      </div>
    </div>

    <%# ── LINE ITEMS CARD ── %>
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;
                margin-bottom:18px;overflow:hidden">
      <div style="padding:13px 18px;border-bottom:1px solid var(--border);
                  display:flex;align-items:center;justify-content:space-between">
        <span style="font-family:var(--mono);font-size:11px;letter-spacing:.1em;
                     text-transform:uppercase;color:var(--text-dim)">
          Line Items
          <span style="color:var(--accent);margin-left:6px">(<%= items.size %>)</span>
        </span>
        <span style="font-size:11px;color:var(--text-dim)">
          ⚠ <span style="color:var(--warning);font-weight:600">UNMATCHED</span>
          items need product linking after saving
        </span>
      </div>

      <div style="overflow-x:auto;width:100%">
        <table style="width:100%;border-collapse:collapse;font-size:12px;table-layout:auto">
          <thead>
            <tr style="background:var(--bg)">
              <% [
                ['#',            '36px',  'center'],
                ['Material Code','130px', 'left'],
                ['Description',  'auto',  'left'],
                ['HSN',          '72px',  'center'],
                ['Qty',          '80px',  'right'],
                ['UOM',          '60px',  'center'],
                ['Rate/Unit',    '90px',  'right'],
                ['Disc%',        '70px',  'right'],
                ['Disc Rs.',     '80px',  'right'],
                ['Taxable',      '90px',  'right'],
                ['GST%',         '54px',  'center'],
                ['Total (Rs.)',  '100px', 'right'],
              ].each do |lbl, w, align| %>
                <th style="min-width:<%= w %>;padding:8px 8px;text-align:<%= align %>;
                           font-family:var(--mono);font-size:10px;letter-spacing:.07em;
                           text-transform:uppercase;color:var(--text-dim);
                           border-bottom:1px solid var(--border);white-space:nowrap"><%= lbl %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% items.each_with_index do |item, idx| %>
              <%
                clean_code   = sanitise_material_code(item['material_code'].to_s)
                matched_prod = clean_code.present? ? @product_by_code&.[](clean_code) : nil
                matched      = matched_prod.present?
                prod_uom     = matched_prod&.base_uom&.name.presence
                display_uom  = prod_uom || item['unit'].presence || '—'
                disc_pct     = item['discount_percent'].to_f
                disc_amt     = item['discount_amount'].to_f
              %>
              <tr style="border-bottom:1px solid var(--border);
                         <%= matched ? '' : 'background:rgba(247,195,79,0.03)' %>">

                <%# # %>
                <td style="padding:8px;text-align:center;font-family:var(--mono);
                           color:var(--text-dim);font-size:11px;white-space:nowrap">
                  <%= item['sr_no'] || (idx + 1) %>
                </td>

                <%# Material Code %>
                <td style="padding:8px">
                  <input type="text"
                         name="parsed_data[items][<%= idx %>][material_code]"
                         value="<%= clean_code %>"
                         class="form-control" style="font-family:var(--mono);font-size:11px;width:120px">
                  <% if matched %>
                    <div style="font-size:9px;color:var(--success);margin-top:2px;font-family:var(--mono)">
                      ✓ matched
                    </div>
                  <% else %>
                    <div style="font-size:9px;color:var(--warning);margin-top:2px;font-family:var(--mono);font-weight:700">
                      UNMATCHED
                    </div>
                  <% end %>
                </td>

                <%# Description %>
                <td style="padding:8px">
                  <input type="text"
                         name="parsed_data[items][<%= idx %>][description]"
                         value="<%= item['description'] %>"
                         class="form-control" style="font-size:12px;min-width:180px">
                  <% if item['pack_size'].present? %>
                    <div style="font-size:10px;color:var(--text-dim);margin-top:2px;font-family:var(--mono)">
                      <%= item['pack_size'] %> × <%= item['num_packs'] %>
                    </div>
                  <% end %>
                </td>

                <%# HSN %>
                <td style="padding:8px;text-align:center;font-family:var(--mono);font-size:11px;
                           color:var(--text-dim);white-space:nowrap">
                  <%= item['hsn_code'].presence || '—' %>
                </td>

                <%# Qty %>
                <td style="padding:8px;text-align:right">
                  <input type="number"
                         name="parsed_data[items][<%= idx %>][quantity]"
                         value="<%= item['quantity'] %>"
                         class="form-control" style="text-align:right;font-family:var(--mono);width:72px"
                         step="0.001">
                </td>

                <%# UOM — from product table if matched, else AI value %>
                <td style="padding:8px;text-align:center;font-family:var(--mono);font-size:11px;
                           white-space:nowrap">
                  <span style="color:<%= prod_uom ? 'var(--success)' : 'var(--text-dim)' %>"
                        title="<%= prod_uom ? 'From product table' : 'From invoice' %>">
                    <%= display_uom %>
                  </span>
                  <input type="hidden" name="parsed_data[items][<%= idx %>][unit]"
                         value="<%= display_uom %>">
                </td>

                <%# Rate/Unit %>
                <td style="padding:8px;text-align:right;font-family:var(--mono);font-size:11px;
                           color:var(--text-dim);white-space:nowrap">
                  <%= item['unit_rate'].to_f > 0 ? number_with_precision(item['unit_rate'], precision: 2, delimiter: ',') : '—' %>
                </td>

                <%# Disc% — editable %>
                <td style="padding:8px;text-align:right">
                  <input type="number"
                         name="parsed_data[items][<%= idx %>][discount_percent]"
                         value="<%= disc_pct > 0 ? disc_pct : '' %>"
                         class="form-control disc-pct-input" style="text-align:right;font-family:var(--mono);width:60px;font-size:11px"
                         step="0.01" min="0" placeholder="0"
                         data-idx="<%= idx %>">
                </td>

                <%# Disc Rs. — editable %>
                <td style="padding:8px;text-align:right">
                  <input type="number"
                         name="parsed_data[items][<%= idx %>][discount_amount]"
                         value="<%= disc_amt > 0 ? disc_amt : '' %>"
                         class="form-control disc-amt-input" style="text-align:right;font-family:var(--mono);width:72px;font-size:11px"
                         step="0.01" min="0" placeholder="0.00"
                         data-idx="<%= idx %>"
                         data-value="<%= item['value'].to_f %>">
                </td>

                <%# Taxable %>
                <td style="padding:8px;text-align:right;font-family:var(--mono);font-size:11px;
                           white-space:nowrap">
                  <%= item['taxable_amount'].to_f > 0 ? number_with_precision(item['taxable_amount'], precision: 2, delimiter: ',') : '—' %>
                </td>

                <%# GST% %>
                <td style="padding:8px;text-align:center;font-family:var(--mono);font-size:11px;
                           white-space:nowrap">
                  <% gst = item['cgst_percent'].to_f + item['sgst_percent'].to_f + item['igst_percent'].to_f %>
                  <span style="color:<%= gst > 0 ? 'var(--text)' : 'var(--text-dim)' %>">
                    <%= gst > 0 ? "#{gst.to_i}%" : '—' %>
                  </span>
                </td>

                <%# Total %>
                <td style="padding:8px;text-align:right">
                  <input type="number"
                         name="parsed_data[items][<%= idx %>][total_amount]"
                         value="<%= item['total_amount'] %>"
                         class="form-control" style="text-align:right;font-family:var(--mono);
                                                     font-weight:600;width:92px;font-size:11px"
                         step="0.01">
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <%# Summary footer %>
      <div style="padding:14px 20px;border-top:1px solid var(--border);
                  display:flex;justify-content:flex-end;gap:28px;flex-wrap:wrap">
        <% taxable_total = hdr['total_taxable_amount'].to_f %>
        <% if taxable_total > 0 %>
          <div style="text-align:right">
            <div style="font-size:10px;color:var(--text-dim);font-family:var(--mono);
                        text-transform:uppercase;letter-spacing:.07em;margin-bottom:3px">Taxable</div>
            <div style="font-family:var(--mono);font-size:15px;color:var(--text)">
              Rs. <%= number_with_precision(taxable_total, precision: 2, delimiter: ',') %>
            </div>
          </div>
        <% end %>
        <% line_disc_total = items.sum { |i| i['discount_amount'].to_f } %>
        <% if line_disc_total > 0 %>
          <div style="text-align:right">
            <div style="font-size:10px;color:var(--text-dim);font-family:var(--mono);
                        text-transform:uppercase;letter-spacing:.07em;margin-bottom:3px">Total Disc.</div>
            <div style="font-family:var(--mono);font-size:15px;color:var(--warning)">
              — Rs. <%= number_with_precision(line_disc_total, precision: 2, delimiter: ',') %>
            </div>
          </div>
        <% end %>
        <% cgst_total = hdr['total_cgst'].to_f; sgst_total = hdr['total_sgst'].to_f %>
        <% if cgst_total + sgst_total > 0 %>
          <div style="text-align:right">
            <div style="font-size:10px;color:var(--text-dim);font-family:var(--mono);
                        text-transform:uppercase;letter-spacing:.07em;margin-bottom:3px">CGST + SGST</div>
            <div style="font-family:var(--mono);font-size:15px;color:var(--text)">
              Rs. <%= number_with_precision(cgst_total + sgst_total, precision: 2, delimiter: ',') %>
            </div>
          </div>
        <% end %>
        <div style="text-align:right">
          <div style="font-size:10px;color:var(--text-dim);font-family:var(--mono);
                      text-transform:uppercase;letter-spacing:.07em;margin-bottom:3px">Grand Total</div>
          <div style="font-family:var(--mono);font-size:22px;font-weight:700;color:var(--accent)">
            Rs. <%= number_with_precision(hdr['total_amount'], precision: 2, delimiter: ',') %>
          </div>
        </div>
      </div>
    </div>

    <%# Amount in words (read-only info) %>
    <% if hdr['amount_in_words'].present? %>
      <div style="font-size:12px;color:var(--text-dim);margin-bottom:16px;font-style:italic">
        In words: <%= hdr['amount_in_words'] %>
      </div>
    <% end %>

    <%# Submit bar %>
    <div style="display:flex;gap:12px;align-items:center;padding:20px 0">
      <button type="submit" class="btn btn-primary" id="save-btn-bottom">
        Save as Draft Invoice →
      </button>
      <%= link_to 'Cancel', purchasing_digitise_index_path, class: 'btn btn-secondary' %>
      <span style="font-size:12px;color:var(--text-dim)">
        Saved as draft. Confirm from the invoice detail page to update stock.
      </span>
    </div>

  <% end %>

<% end %>
