<%# app/views/purchasing/suppliers/index.html.erb %>
<% content_for :title, "Suppliers" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Purchasing</span>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Suppliers</span>
<% end %>

<div class="page-header">
  <div>
    <div class="page-title">Suppliers</div>
    <div class="page-subtitle">Paint and hardware suppliers</div>
  </div>
  <div class="actions">
    <%= link_to '+ New Supplier', new_purchasing_supplier_path, class: 'btn btn-primary' %>
  </div>
</div>

<div class="table-wrap">
  <% if @suppliers.any? %>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>GSTIN</th>
          <th>PAN</th>
          <th>State</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @suppliers.each do |s| %>
          <tr>
            <td style="font-weight:600"><%= s.name %></td>
            <td style="font-family:var(--mono);font-size:12px;color:var(--text-dim)">
              <%= s.gstin.presence || '—' %>
            </td>
            <td style="font-family:var(--mono);font-size:12px;color:var(--text-dim)">
              <%= s.pan.presence || '—' %>
            </td>
            <td style="font-size:13px;color:var(--text-dim)">
              <%= s.state.presence || '—' %>
            </td>
            <td>
              <span class="badge <%= s.active? ? 'badge-active' : 'badge-inactive' %>">
                <%= s.active? ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td>
              <div class="actions">
                <%= link_to 'Edit', edit_purchasing_supplier_path(s),
                      class: 'btn btn-secondary btn-sm' %>
                <%= button_to 'Delete', purchasing_supplier_path(s),
                      method: :delete,
                      class: 'btn btn-danger btn-sm',
                      form: { style: 'margin:0;display:inline' },
                      data: { turbo_confirm: "Delete #{s.name}?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <p>No suppliers yet.</p>
      <div style="margin-top:16px">
        <%= link_to 'Add First Supplier', new_purchasing_supplier_path, class: 'btn btn-primary' %>
      </div>
    </div>
  <% end %>
</div>
