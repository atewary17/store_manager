<%# app/views/purchasing/suppliers/index.html.erb %>
<% content_for :title, "Suppliers" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Trade Relations</span>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Suppliers</span>
<% end %>

<div class="page-header">
  <div>
    <div class="page-title">Suppliers</div>
    <div class="page-subtitle">Paint and hardware suppliers</div>
  </div>
  <%= link_to '+ New Supplier', new_purchasing_supplier_path, class: 'btn btn-primary' %>
</div>

<%# Stats %>
<div class="stats-row" style="grid-template-columns:repeat(4,1fr)">
  <div class="stat-card">
    <div class="stat-label">Total Suppliers</div>
    <div class="stat-value accent"><%= @total_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Active</div>
    <div class="stat-value success"><%= @active_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Purchased</div>
    <div class="stat-value" style="font-size:18px">
      ₹<%= number_with_delimiter(@total_invoiced.round(0)) %>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Payable</div>
    <div class="stat-value" style="font-size:18px;color:var(--warning)">
      ₹<%= number_with_delimiter(@total_outstanding.round(0)) %>
    </div>
  </div>
</div>

<div class="table-wrap">
  <% if @suppliers.any? %>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>GSTIN</th>
          <th>PAN</th>
          <th>State</th>
          <th style="text-align:right">Invoices</th>
          <th style="text-align:right">Total Purchased</th>
          <th style="text-align:right">Outstanding</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @suppliers.each do |s| %>
          <%
            s_invoiced    = s.purchase_invoices.confirmed.sum(:total_amount).to_f
            s_paid        = s.purchase_invoices.confirmed.joins(:purchase_payments)
                             .sum('purchase_payments.amount').to_f
            s_outstanding = (s_invoiced - s_paid).round(2)
          %>
          <tr>
            <td>
              <%= link_to s.name, purchasing_supplier_path(s), style: "font-weight:600" %>
            </td>
            <td style="font-family:var(--mono);font-size:12px;color:var(--text-dim)">
              <%= s.gstin.presence || '—' %>
            </td>
            <td style="font-family:var(--mono);font-size:12px;color:var(--text-dim)">
              <%= s.pan.presence || '—' %>
            </td>
            <td style="font-size:13px;color:var(--text-dim)"><%= s.state.presence || '—' %></td>
            <td style="text-align:right;font-family:var(--mono)">
              <%= s.purchase_invoices.confirmed.count %>
            </td>
            <td style="text-align:right;font-family:var(--mono)">
              ₹<%= number_with_delimiter(s_invoiced.round(0)) %>
            </td>
            <td style="text-align:right;font-family:var(--mono);
                       color:<%= s_outstanding > 0 ? 'var(--warning)' : 'var(--text-dim)' %>">
              ₹<%= number_with_delimiter(s_outstanding) %>
            </td>
            <td>
              <span class="badge <%= s.active? ? 'badge-active' : 'badge-inactive' %>">
                <%= s.active? ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td>
              <div class="actions">
                <%= link_to 'View', purchasing_supplier_path(s), class: 'btn btn-secondary btn-sm' %>
                <%= link_to 'Edit', edit_purchasing_supplier_path(s), class: 'btn btn-secondary btn-sm' %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <p>No suppliers yet.</p>
      <div style="margin-top:16px">
        <%= link_to 'Add First Supplier', new_purchasing_supplier_path, class: 'btn btn-primary' %>
      </div>
    </div>
  <% end %>
</div>
