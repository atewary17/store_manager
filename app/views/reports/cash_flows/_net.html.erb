<%# app/views/reports/cash_flows/_net.html.erb %>

<%# Hero KPIs %>
<div class="stats-row" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-label">Total Inflow</div>
    <div class="stat-value" style="color:var(--success)">₹<%= number_with_delimiter(@total_inflow.round(0)) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Outflow</div>
    <div class="stat-value" style="color:var(--danger)">₹<%= number_with_delimiter(@total_outflow.round(0)) %></div>
  </div>
  <div class="stat-card" style="border-color:<%= @net_flow >= 0 ? 'var(--success)' : 'var(--danger)' %>">
    <div class="stat-label">Net Cash Flow</div>
    <div class="stat-value" style="font-size:26px;color:<%= @net_flow >= 0 ? 'var(--success)' : 'var(--danger)' %>">
      <%= @net_flow >= 0 ? '+' : '' %>₹<%= number_with_delimiter(@net_flow.abs.round(0)) %>
    </div>
    <div style="font-size:11px;color:var(--text-dim);margin-top:4px">
      <%= @net_flow >= 0 ? 'Positive — more in than out' : 'Negative — more out than in' %>
    </div>
  </div>
</div>

<%# Stacked bar + net line chart %>
<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;
            padding:20px;margin-bottom:24px">
  <div id="chart-net-flow" style="height:320px"></div>
</div>

<%# Monthly summary table %>
<div class="table-wrap">
  <div style="padding:12px 18px;border-bottom:1px solid var(--border)">
    <span style="font-family:var(--mono);font-size:10px;letter-spacing:.1em;
                 text-transform:uppercase;color:var(--text-dim)">
      Monthly breakdown
    </span>
  </div>
  <table>
    <thead>
      <tr>
        <th>Month</th>
        <th style="text-align:right">Inflow (₹)</th>
        <th style="text-align:right">Outflow (₹)</th>
        <th style="text-align:right">Net (₹)</th>
        <th style="text-align:right">Flow</th>
      </tr>
    </thead>
    <tbody>
      <% if @monthly.any? %>
        <% @monthly.each do |r| %>
          <tr>
            <td style="font-family:var(--mono);font-size:12px;font-weight:500">
              <%= r[:month].strftime('%B %Y') %>
            </td>
            <td style="text-align:right;font-family:var(--mono);color:var(--success)">
              <%= number_with_delimiter(r[:inflow]) %>
            </td>
            <td style="text-align:right;font-family:var(--mono);color:var(--danger)">
              <%= number_with_delimiter(r[:outflow]) %>
            </td>
            <td style="text-align:right;font-family:var(--mono);font-weight:700;
                       color:<%= r[:net] >= 0 ? 'var(--success)' : 'var(--danger)' %>">
              <%= r[:net] >= 0 ? '+' : '' %><%= number_with_delimiter(r[:net]) %>
            </td>
            <td style="text-align:right">
              <% pct = r[:inflow] > 0 ? (r[:net] / r[:inflow] * 100).round(0) : 0 %>
              <span style="font-family:var(--mono);font-size:10px;padding:2px 7px;border-radius:4px;
                           background:<%= r[:net] >= 0 ? 'rgba(52,217,139,0.12)' : 'rgba(247,97,79,0.12)' %>;
                           color:<%= r[:net] >= 0 ? 'var(--success)' : 'var(--danger)' %>">
                <%= r[:net] >= 0 ? '+' : '' %><%= pct %>%
              </span>
            </td>
          </tr>
        <% end %>
        <tr style="background:var(--bg);font-weight:700">
          <td style="font-family:var(--mono);font-size:12px">Total</td>
          <td style="text-align:right;font-family:var(--mono);color:var(--success)">
            <%= number_with_delimiter(@total_inflow) %>
          </td>
          <td style="text-align:right;font-family:var(--mono);color:var(--danger)">
            <%= number_with_delimiter(@total_outflow) %>
          </td>
          <td style="text-align:right;font-family:var(--mono);font-weight:700;
                     color:<%= @net_flow >= 0 ? 'var(--success)' : 'var(--danger)' %>">
            <%= @net_flow >= 0 ? '+' : '' %><%= number_with_delimiter(@net_flow) %>
          </td>
          <td></td>
        </tr>
      <% else %>
        <tr><td colspan="5" style="text-align:center;padding:40px;color:var(--text-dim)">
          No transactions in this period.
        </td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  var labels  = <%= raw @chart_labels.to_json %>;
  var inflow  = <%= raw @chart_inflow.to_json %>;
  var outflow = <%= raw @chart_outflow.to_json %>;
  var net     = <%= raw @chart_net.to_json %>;

  var chart = initChart('chart-net-flow');
  if (!chart) return;

  chart.setOption(Object.assign({}, EC_DARK, {
    title: { text: 'Daily inflow vs outflow vs net', left: 'left', top: 8 },
    legend: { right: 16, top: 8, textStyle: { color: EC_COLORS.textDim, fontSize: 11 } },
    tooltip: Object.assign({}, EC_DARK.tooltip, {
      trigger: 'axis',
      formatter: function(params) {
        var s = '<b>' + params[0].name + '</b><br/>';
        params.forEach(function(p) { s += p.marker + p.seriesName + ': ' + inr(p.value) + '<br/>'; });
        return s;
      }
    }),
    xAxis: Object.assign({}, EC_DARK.xAxis, {
      type: 'category', data: labels,
      axisLabel: { color: EC_COLORS.textDim, fontSize: 10, rotate: labels.length > 14 ? 30 : 0 }
    }),
    yAxis: Object.assign({}, EC_DARK.yAxis, {
      axisLabel: { formatter: function(v) { return inr(v); }, color: EC_COLORS.textDim, fontSize: 10 }
    }),
    series: [
      {
        name: 'Inflow', type: 'bar', data: inflow, barMaxWidth: 20, stack: 'flow',
        itemStyle: { color: 'rgba(52,217,139,0.75)', borderRadius: [2,2,0,0] }
      },
      {
        name: 'Outflow', type: 'bar', data: outflow.map(function(v){ return -v; }),
        barMaxWidth: 20, stack: 'flow',
        itemStyle: { color: 'rgba(247,97,79,0.75)', borderRadius: [0,0,2,2] }
      },
      {
        name: 'Net', type: 'line', data: net, smooth: true,
        symbol: 'circle', symbolSize: 5,
        lineStyle: { color: '#4f8ef7', width: 2 },
        itemStyle: { color: '#4f8ef7' },
        areaStyle: {
          color: new echarts.graphic.LinearGradient(0,0,0,1,
            [{offset:0, color:'rgba(79,142,247,0.25)'},{offset:1, color:'rgba(79,142,247,0)'}])
        }
      }
    ]
  }));
});
</script>
