<%# app/views/reports/purchases/_summary.html.erb %>

<div class="stats-row" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-label">Total Spend</div>
    <div class="stat-value accent">₹<%= number_with_delimiter(@total_spend.round(0)) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Invoices Received</div>
    <div class="stat-value"><%= @invoice_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Avg Invoice Value</div>
    <div class="stat-value" style="font-size:18px">₹<%= number_with_delimiter(@avg_invoice.round(0)) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">GST Paid</div>
    <div class="stat-value" style="font-size:18px;color:var(--warning)">₹<%= number_with_delimiter(@total_tax.round(0)) %></div>
  </div>
</div>
<div class="stats-row" style="grid-template-columns:1fr 1fr;margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-label">Amount Paid</div>
    <div class="stat-value success" style="font-size:18px">₹<%= number_with_delimiter(@total_paid.round(0)) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Still Outstanding</div>
    <div class="stat-value" style="font-size:18px;color:<%= @total_outstanding > 0 ? 'var(--danger)' : 'var(--success)' %>">
      ₹<%= number_with_delimiter(@total_outstanding.round(0)) %>
    </div>
  </div>
</div>

<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;
            padding:20px;margin-bottom:24px">
  <div id="chart-purchase-summary" style="height:280px"></div>
</div>

<div class="table-wrap">
  <div style="padding:12px 18px;border-bottom:1px solid var(--border)">
    <span style="font-family:var(--mono);font-size:10px;letter-spacing:.1em;
                 text-transform:uppercase;color:var(--text-dim)">
      Breakdown by <%= @group_by.titleize %>
    </span>
  </div>
  <table>
    <thead>
      <tr>
        <th>Period</th>
        <th style="text-align:right">Invoices</th>
        <th style="text-align:right">Spend (₹)</th>
        <th style="text-align:right">Tax (₹)</th>
        <th style="text-align:right">Taxable (₹)</th>
      </tr>
    </thead>
    <tbody>
      <% if @breakdown.any? %>
        <% @breakdown.each do |row| %>
          <tr>
            <td style="font-family:var(--mono);font-size:12px">
              <% label = case @group_by
                         when 'day'  then row.period.strftime('%d %b %Y')
                         when 'week' then "Week of #{row.period.strftime('%d %b %Y')}"
                         else             row.period.strftime('%B %Y')
                         end %>
              <%= label %>
            </td>
            <td style="text-align:right;font-family:var(--mono)"><%= row.inv_count %></td>
            <td style="text-align:right;font-family:var(--mono);color:var(--accent)">
              <%= number_with_delimiter(row.spend.to_f.round(2)) %>
            </td>
            <td style="text-align:right;font-family:var(--mono);color:var(--warning)">
              <%= number_with_delimiter(row.tax_total.to_f.round(2)) %>
            </td>
            <td style="text-align:right;font-family:var(--mono)">
              <%= number_with_delimiter((row.spend.to_f - row.tax_total.to_f).round(2)) %>
            </td>
          </tr>
        <% end %>
        <tr style="background:var(--bg);font-weight:700">
          <td style="font-family:var(--mono);font-size:12px">Total</td>
          <td style="text-align:right;font-family:var(--mono)"><%= @invoice_count %></td>
          <td style="text-align:right;font-family:var(--mono);color:var(--accent)">
            <%= number_with_delimiter(@total_spend) %>
          </td>
          <td style="text-align:right;font-family:var(--mono);color:var(--warning)">
            <%= number_with_delimiter(@total_tax) %>
          </td>
          <td style="text-align:right;font-family:var(--mono)">
            <%= number_with_delimiter(@total_taxable) %>
          </td>
        </tr>
      <% else %>
        <tr><td colspan="5" style="text-align:center;padding:40px;color:var(--text-dim)">
          No purchases in this period.
        </td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  var chart = initChart('chart-purchase-summary');
  if (!chart) return;
  var labels = <%= raw @chart_labels.to_json %>;
  var data   = <%= raw @chart_data.to_json %>;
  chart.setOption(Object.assign({}, EC_DARK, {
    title: { text: 'Spend over period', left: 'left', top: 8 },
    tooltip: Object.assign({}, EC_DARK.tooltip, {
      trigger: 'axis',
      formatter: function(p) { return '<b>' + p[0].name + '</b><br/>' + inr(p[0].value); }
    }),
    xAxis: Object.assign({}, EC_DARK.xAxis, {
      type: 'category', data: labels,
      axisLabel: { color: EC_COLORS.textDim, fontSize: 11, rotate: labels.length > 10 ? 30 : 0 }
    }),
    yAxis: Object.assign({}, EC_DARK.yAxis, {
      axisLabel: { formatter: function(v) { return inr(v); }, color: EC_COLORS.textDim, fontSize: 10 }
    }),
    series: [{
      type: 'bar', data: data, name: 'Spend', barMaxWidth: 48,
      itemStyle: {
        borderRadius: [4,4,0,0],
        color: new echarts.graphic.LinearGradient(0,0,0,1,
          [{offset:0, color:'#9b7cf7'},{offset:1, color:'#3d1e7a'}])
      },
      emphasis: { itemStyle: { color: '#b49cfc' } },
      label: {
        show: data.length <= 12, position: 'top',
        formatter: function(p) { return inr(p.value); },
        color: EC_COLORS.textDim, fontSize: 10
      }
    }]
  }));
});
</script>
