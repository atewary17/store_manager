<%# app/views/reports/purchases/_by_supplier.html.erb %>

<div class="stats-row" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-label">Total Spend</div>
    <div class="stat-value accent">₹<%= number_with_delimiter(@total_spend.round(0)) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Suppliers</div>
    <div class="stat-value"><%= @rows.size %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Top Supplier</div>
    <div class="stat-value" style="font-size:16px;color:var(--warning)">
      <%= @rows.first&.dig(:name)&.truncate(18) || '—' %>
    </div>
  </div>
</div>

<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;
            padding:20px;margin-bottom:24px">
  <div id="chart-by-supplier" style="height:260px"></div>
</div>

<div class="table-wrap">
  <div style="padding:12px 18px;border-bottom:1px solid var(--border)">
    <span style="font-family:var(--mono);font-size:10px;letter-spacing:.1em;
                 text-transform:uppercase;color:var(--text-dim)">
      All suppliers — sorted by spend
    </span>
  </div>
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Supplier</th>
        <th>GSTIN</th>
        <th style="text-align:right">Invoices</th>
        <th style="text-align:right">Invoiced (₹)</th>
        <th style="text-align:right">Paid (₹)</th>
        <th style="text-align:right">Outstanding (₹)</th>
        <th>Last Purchase</th>
      </tr>
    </thead>
    <tbody>
      <% if @rows.any? %>
        <% @rows.each_with_index do |r, i| %>
          <tr>
            <td style="font-family:var(--mono);font-size:11px;color:var(--text-dim)"><%= i + 1 %></td>
            <td style="font-weight:500">
              <%= r[:name] %>
              <% if i == 0 %>
                <span style="font-family:var(--mono);font-size:9px;background:rgba(247,195,79,0.15);
                             color:var(--warning);padding:1px 5px;border-radius:3px;margin-left:4px">
                  TOP
                </span>
              <% end %>
            </td>
            <td style="font-family:var(--mono);font-size:11px;color:var(--text-dim)">
              <%= r[:gstin].presence || '—' %>
            </td>
            <td style="text-align:right;font-family:var(--mono)"><%= r[:inv_count] %></td>
            <td style="text-align:right;font-family:var(--mono);color:var(--accent)">
              <%= number_with_delimiter(r[:invoiced]) %>
            </td>
            <td style="text-align:right;font-family:var(--mono);color:var(--success)">
              <%= number_with_delimiter(r[:paid]) %>
            </td>
            <td style="text-align:right;font-family:var(--mono);
                       color:<%= r[:outstanding] > 0 ? 'var(--danger)' : 'var(--text-dim)' %>">
              <%= number_with_delimiter(r[:outstanding]) %>
            </td>
            <td style="font-size:12px;color:var(--text-dim);font-family:var(--mono)">
              <%= r[:last_purchase]&.strftime('%d %b %Y') || '—' %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr><td colspan="8" style="text-align:center;padding:40px;color:var(--text-dim)">
          No purchases in this period.
        </td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  var chart   = initChart('chart-by-supplier');
  if (!chart) return;
  var labels  = <%= raw @chart_labels.to_json %>;
  var data    = <%= raw @chart_data.to_json %>;
  var palette = ['#9b7cf7','#4f8ef7','#34d98b','#f7c34f','#f7614f'];
  chart.setOption(Object.assign({}, EC_DARK, {
    title: { text: 'Top 5 suppliers by spend', left: 'left', top: 8 },
    grid: { left: 140, right: 80, top: 48, bottom: 16, containLabel: false },
    tooltip: Object.assign({}, EC_DARK.tooltip, {
      trigger: 'axis', axisPointer: { type: 'shadow' },
      formatter: function(p) { return '<b>' + p[0].name + '</b><br/>' + inr(p[0].value); }
    }),
    xAxis: { type: 'value',
             axisLabel: { formatter: function(v) { return inr(v); }, color: EC_COLORS.textDim, fontSize: 10 },
             splitLine: { lineStyle: { color: EC_COLORS.border, type: 'dashed' } } },
    yAxis: { type: 'category', data: labels.slice().reverse(),
             axisLabel: { color: EC_COLORS.text, fontSize: 12,
                          formatter: function(v) { return v.length > 18 ? v.slice(0,18)+'…' : v; } },
             axisLine: { show: false }, axisTick: { show: false } },
    series: [{
      type: 'bar', data: data.slice().reverse(), name: 'Spend',
      barMaxWidth: 32,
      itemStyle: { borderRadius: [0,4,4,0],
                   color: function(p) { return palette[p.dataIndex % palette.length]; } },
      label: { show: true, position: 'right',
               formatter: function(p) { return inr(p.value); },
               color: EC_COLORS.text, fontSize: 11 }
    }]
  }));
});
</script>
