<%# app/views/setup/shade_catalogues/import_show.html.erb %>
<% content_for :title, "Shade Import ##{@import.id}" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Setup</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Shade Catalogue', setup_shade_catalogues_path %>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Imports', import_setup_shade_catalogues_path %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">#<%= @import.id %></span>
<% end %>

<div class="page-header">
  <div>
    <div class="page-title"><%= @import.file_name %></div>
    <div class="page-subtitle">
      Uploaded by <%= @import.user.full_name %> ·
      <%= @import.created_at.strftime('%d %b %Y, %H:%M') %> ·
      Category: <strong><%= @import.product_category&.name %></strong>
    </div>
  </div>
  <div class="actions">
    <% if @import.has_errors? %>
      <%= link_to 'Download Error Report',
            shade_catalogue_import_download_errors_setup_shade_catalogue_path(@import),
            class: 'btn btn-danger' %>
    <% end %>
    <%= link_to '← Back', import_setup_shade_catalogues_path, class: 'btn btn-secondary' %>
  </div>
</div>

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-label">Status</div>
    <div class="stat-value">
      <span class="badge <%= status_badge_class(@import.status) %>"><%= @import.status.humanize %></span>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Rows</div>
    <div class="stat-value accent"><%= @import.total_rows %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Created</div>
    <div class="stat-value success"><%= @import.success_count - @import.update_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Updated</div>
    <div class="stat-value" style="color:var(--accent)"><%= @import.update_count %></div>
  </div>
</div>

<% if @import.has_errors? %>
  <div style="margin-bottom:24px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
      <div style="font-family:var(--mono);font-size:11px;color:var(--danger);letter-spacing:0.08em;text-transform:uppercase">
        <%= @import.error_count %> Errors
      </div>
      <%= link_to 'Download Error Report ↓',
            shade_catalogue_import_download_errors_setup_shade_catalogue_path(@import),
            class: 'btn btn-danger btn-sm' %>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Row</th>
            <th>Shade Code</th>
            <th>Shade Name</th>
            <th>Manufacturer</th>
            <th>Error</th>
          </tr>
        </thead>
        <tbody>
          <% @import.error_rows.first(20).each do |row| %>
          <tr>
            <td style="font-family:var(--mono)">#<%= row['row_number'] %></td>
            <td style="font-family:var(--mono)"><%= row['shade_code'] %></td>
            <td><%= row['shade_name'] %></td>
            <td><%= row['manufacturer'] %></td>
            <td style="color:var(--danger);font-size:12px"><%= row['error'] %></td>
          </tr>
          <% end %>
          <% if @import.error_rows.size > 20 %>
          <tr>
            <td colspan="5" style="color:var(--text-dim);font-size:12px;text-align:center">
              + <%= @import.error_rows.size - 20 %> more — download the full report
            </td>
          </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<% if @import.pending? || @import.processing? %>
  <div style="padding:20px;background:var(--accent-dim);border-radius:8px;border:1px solid var(--border);text-align:center;font-size:13px;color:var(--text-dim)">
    ⏳ Processing in background — refresh this page to check status
    <script>
      setTimeout(function() { window.location.reload(); }, 5000);
    </script>
  </div>
<% end %>
