<%# app/views/setup/shade_catalogues/import_show.html.erb %>
<% content_for :title, "Import ##{@import.id}" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Setup</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Shade Catalogue', setup_shade_catalogues_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Imports', import_setup_shade_catalogues_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Import #<%= @import.id %></span>
<% end %>

<%= render 'setup/shared/master_styles' %>

<div class="page-header">
  <div>
    <div class="page-title"><%= @import.file_name %></div>
    <div style="display:flex;gap:10px;align-items:center;margin-top:6px">
      <span class="badge <%= status_badge_class(@import.status) %>">
        <%= @import.status.humanize %>
      </span>
      <span style="font-family:var(--mono);font-size:11px;color:var(--text-dim)">
        <%= @import.created_at.strftime('%d %b %Y, %H:%M') %>
      </span>
    </div>
  </div>
  <div class="actions">
    <% if @import.has_errors? %>
      <%= link_to 'Download Errors ↓',
            import_download_errors_setup_shade_catalogue_path(@import),
            class: 'btn btn-danger' %>
    <% end %>
    <%= link_to '← Back', import_setup_shade_catalogues_path, class: 'btn btn-secondary' %>
  </div>
</div>

<%# Summary stats %>
<div class="stats-row" style="grid-template-columns:repeat(5,1fr);margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-label">Category</div>
    <div style="font-size:14px;font-weight:500;margin-top:4px;color:var(--text)">
      <%= @import.product_category&.name || '—' %>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Rows</div>
    <div class="stat-value" style="font-size:22px"><%= @import.total_rows %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Created</div>
    <div class="stat-value" style="font-size:22px;color:var(--success)">
      <%= @import.success_count - @import.update_count %>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Updated</div>
    <div class="stat-value" style="font-size:22px;color:var(--accent)">
      <%= @import.update_count %>
    </div>
  </div>
  <div class="stat-card" style="<%= @import.error_count > 0 ? 'border-color:rgba(247,97,79,0.4)' : '' %>">
    <div class="stat-label">Errors</div>
    <div class="stat-value" style="font-size:22px;color:<%= @import.error_count > 0 ? 'var(--danger)' : 'var(--text-dim)' %>">
      <%= @import.error_count %>
    </div>
  </div>
</div>

<%# Error rows %>
<% if @import.has_errors? && @import.error_rows.present? %>
  <div class="table-wrap">
    <div style="padding:14px 20px;border-bottom:1px solid var(--border)">
      <span style="font-family:var(--mono);font-size:11px;text-transform:uppercase;
                   letter-spacing:0.1em;color:var(--danger)">
        Error Rows (<%= @import.error_count %>)
      </span>
    </div>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Error</th>
          <th>shade_code</th>
          <th>shade_name</th>
          <th>manufacturer</th>
          <th>colour_family</th>
        </tr>
      </thead>
      <tbody>
        <% @import.error_rows.each do |row| %>
          <tr>
            <td style="font-family:var(--mono);font-size:12px;color:var(--text-dim)">
              <%= row['row_number'] %>
            </td>
            <td style="color:var(--danger);font-size:12px"><%= row['error'] %></td>
            <td style="font-family:var(--mono);font-size:12px"><%= row['shade_code'] %></td>
            <td style="font-size:12px"><%= row['shade_name'] %></td>
            <td style="font-size:12px;color:var(--text-dim)"><%= row['manufacturer'] %></td>
            <td style="font-size:12px;color:var(--text-dim)"><%= row['colour_family'] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% elsif @import.status == 'pending' || @import.status == 'processing' %>
  <div class="detail-card" style="padding:32px;text-align:center;color:var(--text-dim)">
    <div style="font-size:14px;margin-bottom:6px">Import is still processing…</div>
    <div style="font-size:12px">Refresh the page in a few seconds to see results.</div>
    <script>setTimeout(function(){ location.reload(); }, 4000);</script>
  </div>
<% else %>
  <div class="detail-card" style="padding:32px;text-align:center;color:var(--text-dim)">
    <div style="font-size:14px;margin-bottom:4px;color:var(--success)">✓ No errors</div>
    <div style="font-size:12px">All rows imported successfully.</div>
  </div>
<% end %>
