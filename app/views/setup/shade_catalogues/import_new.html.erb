<%# app/views/setup/shade_catalogues/import_new.html.erb %>
<% content_for :title, "Import Shades" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Setup</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Shade Catalogue', setup_shade_catalogues_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Imports', import_setup_shade_catalogues_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">New Import</span>
<% end %>

<%= render 'setup/shared/master_styles' %>

<div class="page-header">
  <div>
    <div class="page-title">Import Shade Catalogue</div>
    <div class="page-subtitle">Upload an Excel file to create or update shades in bulk</div>
  </div>
  <div class="actions">
    <%= link_to 'Download Template', template_setup_shade_catalogues_path, class: 'btn btn-secondary' %>
    <%= link_to '← Back', import_setup_shade_catalogues_path, class: 'btn btn-secondary' %>
  </div>
</div>

<div class="form-card" style="max-width:560px">
  <div class="form-section">
    <div class="form-section-title">Upload File</div>

    <%= form_with url: import_setup_shade_catalogues_path, method: :post,
          multipart: true, local: true do |f| %>

      <div class="form-group">
        <%= f.label :product_category_id, "Paint Category *" %>
        <%= f.select :product_category_id,
              @paint_categories.map { |c| [c.name, c.id] },
              { include_blank: '— Select category —' },
              { class: 'form-control' } %>
        <div class="form-hint">All shades in this file will be assigned to this category.</div>
      </div>

      <div class="form-group">
        <%= f.label :file, "Excel File (.xlsx) *" %>
        <%= f.file_field :file, accept: '.xlsx',
              class: 'form-control',
              style: 'padding:7px 12px' %>
        <div class="form-hint">Maximum file size: 10MB. Only .xlsx format supported.</div>
      </div>

      <div style="display:flex;gap:10px;margin-top:8px">
        <%= f.submit 'Start Import', class: 'btn btn-primary' %>
        <%= link_to 'Cancel', import_setup_shade_catalogues_path, class: 'btn btn-secondary' %>
      </div>
    <% end %>
  </div>

  <div class="form-section" style="background:rgba(79,142,247,0.04)">
    <div class="form-section-title">File Format</div>
    <div style="font-size:13px;color:var(--text-dim);line-height:1.7">
      <div style="margin-bottom:8px">Your file should have these columns (row 1 = headers):</div>
      <table style="width:100%;border-collapse:collapse;font-size:12px">
        <thead>
          <tr style="border-bottom:1px solid var(--border)">
            <th style="text-align:left;padding:4px 8px;font-family:var(--mono);color:var(--text-dim)">Column</th>
            <th style="text-align:left;padding:4px 8px;font-family:var(--mono);color:var(--text-dim)">Required</th>
            <th style="text-align:left;padding:4px 8px;font-family:var(--mono);color:var(--text-dim)">Notes</th>
          </tr>
        </thead>
        <tbody>
          <% [
            ['shade_code',    'Yes', 'Unique per category. Auto-uppercased.'],
            ['shade_name',    'Yes', 'Full descriptive name.'],
            ['manufacturer',  'No',  'Brand name e.g. Asian Paints.'],
            ['colour_family', 'No',  'e.g. Blues, Whites, Neutrals.'],
            ['notes',         'No',  'Any special notes.'],
            ['active',        'No',  'true/false. Defaults to true.'],
          ].each do |col, req, note| %>
            <tr style="border-bottom:1px solid var(--border)">
              <td style="padding:5px 8px;font-family:var(--mono);font-size:11px;color:var(--accent)"><%= col %></td>
              <td style="padding:5px 8px;font-size:11px;color:<%= req=='Yes' ? 'var(--danger)' : 'var(--text-dim)' %>"><%= req %></td>
              <td style="padding:5px 8px;font-size:12px"><%= note %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <div style="margin-top:10px;font-size:11px">
        Rows 1–3 are skipped automatically when using the template (they contain header/description rows).
      </div>
    </div>
  </div>
</div>
