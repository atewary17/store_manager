<%# app/views/setup/brands/_form.html.erb %>
<%= render 'setup/shared/master_styles' %>

<div class="form-card">
  <% if brand.errors.any? %>
    <div class="alert alert-danger" style="margin-bottom:24px">
      <strong><%= brand.errors.count %> error(s):</strong>
      <ul style="margin:8px 0 0 16px">
        <% brand.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [:setup, brand], local: true do |f| %>
    <div class="form-section">
      <div class="form-section-title">Brand Details</div>

      <div class="form-row">
        <div class="form-group">
          <%= f.label :name, "Brand Name *" %>
          <%= f.text_field :name,
                placeholder: 'e.g. Asian Paints, Berger Paints',
                class: brand.errors[:name].any? ? 'form-control input-error' : 'form-control' %>
          <% if brand.errors[:name].any? %>
            <div class="form-error"><%= brand.errors[:name].first %></div>
          <% end %>
        </div>

        <div class="form-group">
          <%= f.label :short_name, "Short Name / Abbreviation" %>
          <%= f.text_field :short_name,
                placeholder: 'e.g. AP, Berger, JSW',
                style: 'font-family:var(--mono)',
                class: 'form-control' %>
          <div class="form-hint">Optional — used in compact displays and reports</div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group" style="flex:2">
          <%= f.label :description, "Description" %>
          <%= f.text_area :description,
                placeholder: 'e.g. Leading Indian paint manufacturer. Tinting system: Colour Next.',
                rows: 3,
                class: 'form-control' %>
        </div>

        <div class="form-group" style="flex:0.5">
          <%= f.label :active, "Status" %>
          <div class="toggle-wrap" style="margin-top:6px">
            <%= f.check_box :active, class: 'toggle-input', id: 'brand_active' %>
            <%= f.label :active, class: 'toggle-label' do %>
              <span class="toggle-on">Active</span>
              <span class="toggle-off">Inactive</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="form-actions">
      <%= f.submit brand.new_record? ? 'Create Brand' : 'Update Brand', class: 'btn btn-primary' %>
      <%= link_to 'Cancel', setup_brands_path, class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
