<%# app/views/setup/products/show.html.erb %>
<% content_for :title, @product.display_name %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Setup</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Products', setup_products_path %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current"><%= @product.brand&.name || 'No Brand' %></span>
<% end %>

<div class="page-header">
  <div>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
      <span class="badge badge-plan"><%= @product.product_category.name %></span>
      <span class="badge <%= @product.active? ? 'badge-active' : 'badge-inactive' %>">
        <%= @product.active? ? 'active' : 'inactive' %>
      </span>
    </div>
    <div class="page-title"><%= @product.brand&.name || '—' %></div>
    <div class="page-subtitle" style="font-size:14px;margin-top:4px;max-width:560px">
      <%= @product.description %>
    </div>
  </div>
  <div class="actions">
    <%= link_to 'Edit', edit_setup_product_path(@product), class: 'btn btn-secondary' %>
    <%= button_to 'Delete', setup_product_path(@product),
          method: :delete,
          class: 'btn btn-danger',
          form: { style: 'margin:0' },
          data: { confirm: "Delete this product? This cannot be undone." } %>
  </div>
</div>

<div class="detail-card">
  <div class="detail-section">
    <div class="detail-section-title">Classification</div>
    <div class="detail-grid">
      <div class="detail-field">
        <label>Category</label>
        <div class="value">
          <%= link_to @product.product_category.name,
                setup_product_category_path(@product.product_category) %>
        </div>
      </div>
      <div class="detail-field">
        <label>Base UOM</label>
        <div class="value">
          <%= @product.base_uom.name %>
          <span style="font-family:var(--mono);font-size:11px;color:var(--text-dim);margin-left:4px">
            (<%= @product.base_uom.short_name %>)
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="detail-section">
    <div class="detail-section-title">Product Details</div>
    <div class="detail-grid">
      <div class="detail-field">
        <label>Brand</label>
        <div class="value"><%= @product.brand&.name || '—' %></div>
      </div>
      <div class="detail-field">
        <label>Pack Code</label>
        <div class="value mono"><%= @product.pack_code.presence || '—' %></div>
      </div>
      <div class="detail-field" style="grid-column:span 2">
        <label>Description</label>
        <div class="value"><%= @product.description %></div>
      </div>
    </div>
  </div>

  <div class="detail-section">
    <div class="detail-section-title">Codes & Identifiers</div>
    <div class="detail-grid">
      <div class="detail-field">
        <label>Material Code</label>
        <div class="value mono"><%= @product.material_code.presence || '—' %></div>
      </div>
      <div class="detail-field">
        <label>Product Code</label>
        <div class="value mono"><%= @product.product_code.presence || '—' %></div>
      </div>
    </div>
  </div>

  <div class="detail-section">
    <div class="detail-section-title">Tax & Pricing</div>
    <div class="detail-grid">
      <div class="detail-field">
        <label>HSN Code</label>
        <div class="value mono"><%= @product.hsn_code.presence || '—' %></div>
      </div>
      <div class="detail-field">
        <label>GST Rate</label>
        <div class="value">
          <span style="font-family:var(--mono);font-size:14px;font-weight:600;
                       color:<%= @product.gst_rate == 0 ? 'var(--success)' : 'var(--warning)' %>">
            <%= @product.gst_rate %>%
          </span>
        </div>
      </div>
      <% if Product.column_names.include?('mrp') && @product.mrp.present? %>
        <div class="detail-field">
          <label>MRP</label>
          <div class="value mono">₹ <%= number_with_precision(@product.mrp, precision: 2, delimiter: ',') %></div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Org enrolments — superadmin only %>
  <% if current_user.super_admin? %>
    <% org_products = @product.organisation_products.includes(:organisation) %>
    <div class="detail-section">
      <div class="detail-section-title">
        Organisation Catalogue
        <span style="font-size:11px;font-weight:400;color:var(--text-dim);margin-left:8px">
          orgs that have this product enrolled
        </span>
      </div>
      <% if org_products.any? %>
        <div style="display:flex;flex-wrap:wrap;gap:8px">
          <% org_products.each do |op| %>
            <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;
                         padding:5px 10px;border-radius:6px;
                         background:<%= op.active? ? 'rgba(79,142,247,0.1)' : 'rgba(122,131,153,0.1)' %>;
                         border:1px solid <%= op.active? ? 'rgba(79,142,247,0.3)' : 'var(--border)' %>;
                         color:<%= op.active? ? 'var(--accent)' : 'var(--text-dim)' %>">
              <%= op.organisation.name %>
              <% unless op.active? %>
                <span style="font-size:10px;opacity:0.7">(inactive)</span>
              <% end %>
              <% if op.mrp.present? %>
                <span style="font-family:var(--mono);font-size:10px;color:var(--text-dim)">
                  MRP ₹<%= op.mrp %>
                </span>
              <% end %>
            </span>
          <% end %>
        </div>
      <% else %>
        <div style="font-size:13px;color:var(--text-dim);font-style:italic">
          Not enrolled in any organisation's catalogue yet.
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<div style="margin-top:20px;display:flex;gap:10px">
  <%= link_to '← Back to Products', setup_products_path, class: 'btn btn-secondary' %>
  <% if current_user.super_admin? %>
    <%= link_to 'View Register', product_register_setup_products_path, class: 'btn btn-secondary' %>
  <% end %>
</div>
