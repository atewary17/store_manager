<%# app/views/setup/products/show.html.erb %>
<% content_for :title, @product.display_name %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Setup</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Products', setup_products_path %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current"><%= @product.brand&.name || 'No Brand' %></span>
<% end %>

<%
  meta        = @product.metadata || {}
  is_pending  = !@product.active? && meta['source'] == 'ai_enrichment'
  is_tintable = meta['tint'].to_s == 'true'
  known_meta  = %w[tint family_colour canister_volume_ml source validation_status
                   ai_confidence ai_brand_guess ai_category_guess ai_notes
                   original_name created_at created_by_org approved_by approved_at
                   needs_review ai_pack_size_guess ai_hsn_code ai_gst_rate]
  custom_meta = meta.reject { |k, _| known_meta.include?(k) }
%>

<div class="page-header">
  <div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap">
      <span class="badge badge-plan"><%= @product.product_category&.name %></span>
      <span class="badge <%= @product.active? ? 'badge-active' : 'badge-inactive' %>">
        <%= @product.active? ? 'Active' : 'Inactive' %>
      </span>
      <% if is_tintable %>
        <span style="font-size:10px;padding:2px 8px;border-radius:10px;font-weight:600;
                     background:rgba(79,142,247,0.12);color:var(--accent);
                     font-family:var(--mono)">🎨 Tintable</span>
      <% end %>
      <% if is_pending %>
        <span style="font-size:10px;padding:2px 8px;border-radius:10px;font-weight:600;
                     background:rgba(247,195,79,0.12);color:var(--warning);
                     font-family:var(--mono)">⏳ Pending Review</span>
      <% end %>
    </div>
    <div class="page-title"><%= @product.brand&.name || '—' %></div>
    <div class="page-subtitle" style="font-size:14px;margin-top:4px;max-width:600px">
      <%= @product.description %>
    </div>
  </div>
  <div class="actions">
    <%= link_to 'Edit', edit_setup_product_path(@product), class: 'btn btn-secondary' %>
    <% if current_user.super_admin? && is_pending %>
      <%= button_to '✅ Approve',
            approve_pending_setup_products_path(@product),
            method: :post,
            class: 'btn btn-secondary',
            style: 'color:var(--success);border-color:var(--success)',
            form: { style: 'margin:0' },
            data: { turbo_confirm: "Approve #{@product.description}? It will become fully active." } %>
    <% end %>
    <%= button_to 'Delete', setup_product_path(@product),
          method: :delete,
          class: 'btn btn-danger',
          form: { style: 'margin:0' },
          data: { confirm: "Delete this product? This cannot be undone." } %>
  </div>
</div>

<div class="detail-card">

  <%# ── Classification ── %>
  <div class="detail-section">
    <div class="detail-section-title">Classification</div>
    <div class="detail-grid">
      <div class="detail-field">
        <label>Category</label>
        <div class="value">
          <%= link_to @product.product_category.name,
                setup_product_category_path(@product.product_category) %>
        </div>
      </div>
      <div class="detail-field">
        <label>Base UOM</label>
        <div class="value">
          <%= @product.base_uom.name %>
          <span style="font-family:var(--mono);font-size:11px;color:var(--text-dim);margin-left:4px">
            (<%= @product.base_uom.short_name %>)
          </span>
        </div>
      </div>
    </div>
  </div>

  <%# ── Product Details ── %>
  <div class="detail-section">
    <div class="detail-section-title">Product Details</div>
    <div class="detail-grid">
      <div class="detail-field">
        <label>Brand</label>
        <div class="value"><%= @product.brand&.name || '—' %></div>
      </div>
      <div class="detail-field">
        <label>Pack Code</label>
        <div class="value mono"><%= @product.pack_code.presence || '—' %></div>
      </div>
      <div class="detail-field" style="grid-column:span 2">
        <label>Description</label>
        <div class="value"><%= @product.description %></div>
      </div>
      <% if is_pending && meta['original_name'].present? && meta['original_name'] != @product.description %>
        <div class="detail-field" style="grid-column:span 2">
          <label>Original Invoice Name</label>
          <div class="value" style="color:var(--text-dim);font-style:italic">
            "<%= meta['original_name'] %>"
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Codes & Identifiers ── %>
  <div class="detail-section">
    <div class="detail-section-title">Codes &amp; Identifiers</div>
    <div class="detail-grid">
      <div class="detail-field">
        <label>Material Code</label>
        <div class="value mono"><%= @product.material_code.presence || '—' %></div>
      </div>
      <div class="detail-field">
        <label>Product Code</label>
        <div class="value mono"><%= @product.product_code.presence || '—' %></div>
      </div>
    </div>
  </div>

  <%# ── Tax & Pricing ── %>
  <div class="detail-section">
    <div class="detail-section-title">Tax &amp; Pricing</div>
    <div class="detail-grid">
      <div class="detail-field">
        <label>HSN Code</label>
        <div class="value mono"><%= @product.hsn_code.presence || '—' %></div>
      </div>
      <div class="detail-field">
        <label>GST Rate</label>
        <div class="value">
          <span style="font-family:var(--mono);font-size:14px;font-weight:600;
                       color:<%= @product.gst_rate == 0 ? 'var(--success)' : 'var(--warning)' %>">
            <%= @product.gst_rate %>%
          </span>
        </div>
      </div>
      <% if Product.column_names.include?('mrp') && @product.mrp.present? %>
        <div class="detail-field">
          <label>MRP</label>
          <div class="value mono">
            ₹ <%= number_with_precision(@product.mrp, precision: 2, delimiter: ',') %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Metadata ── %>
  <% if meta.any? %>
    <div class="detail-section">
      <div class="detail-section-title">Metadata</div>

      <%# Tinting machine block %>
      <% if is_tintable || meta['family_colour'].present? || meta['canister_volume_ml'].present? %>
        <div style="background:rgba(79,142,247,0.04);border:1px solid rgba(79,142,247,0.15);
                    border-radius:10px;padding:14px 16px;margin-bottom:14px">
          <div style="font-size:11px;font-weight:600;color:var(--accent);
                      text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">
            🎨 Tinting Machine
          </div>
          <div class="detail-grid">
            <div class="detail-field">
              <label>Tintable</label>
              <div class="value">
                <% if meta['tint'].to_s == 'true' %>
                  <span style="color:var(--success);font-weight:600">✓ Yes</span>
                <% elsif meta['tint'].to_s == 'false' %>
                  <span style="color:var(--text-dim)">No</span>
                <% else %>
                  <span style="color:var(--text-dim)">—</span>
                <% end %>
              </div>
            </div>
            <% if meta['family_colour'].present? %>
              <div class="detail-field">
                <label>Family Colour</label>
                <div class="value" style="display:flex;align-items:center;gap:8px">
                  <%
                    fc = meta['family_colour'].to_s.downcase
                    dot_color = fc.include?('black') ? '#333333' :
                                fc.include?('white') ? '#eeeeee' :
                                fc.include?('red')   ? '#e74c3c' :
                                fc.include?('blue')  ? '#3498db' :
                                fc.include?('green') ? '#2ecc71' :
                                fc.include?('yellow')? '#f1c40f' :
                                fc.include?('gold')  ? '#d4a017' :
                                fc.include?('amber') ? '#c17f24' :
                                fc.include?('brown') ? '#795548' :
                                fc.include?('orange')? '#e67e22' :
                                fc.include?('grey') || fc.include?('gray') ? '#9e9e9e' :
                                '#4f8ef7'
                  %>
                  <span style="width:14px;height:14px;border-radius:50%;
                               background:<%= dot_color %>;border:1px solid var(--border);
                               flex-shrink:0"></span>
                  <span><%= meta['family_colour'] %></span>
                </div>
              </div>
            <% end %>
            <% if meta['canister_volume_ml'].present? %>
              <div class="detail-field">
                <label>Canister Volume</label>
                <div class="value mono"><%= meta['canister_volume_ml'] %> ml</div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# AI enrichment block %>
      <% ai_keys = %w[source validation_status ai_confidence ai_brand_guess
                      ai_category_guess ai_notes original_name] %>
      <% if ai_keys.any? { |k| meta[k].present? } %>
        <div style="background:rgba(247,195,79,0.05);border:1px solid rgba(247,195,79,0.2);
                    border-radius:10px;padding:14px 16px;margin-bottom:14px">
          <div style="font-size:11px;font-weight:600;color:var(--warning);
                      text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">
            🤖 AI Enrichment
          </div>
          <div class="detail-grid">
            <% if meta['source'].present? %>
              <div class="detail-field">
                <label>Source</label>
                <div class="value mono" style="font-size:12px"><%= meta['source'] %></div>
              </div>
            <% end %>
            <% if meta['validation_status'].present? %>
              <div class="detail-field">
                <label>Validation Status</label>
                <div class="value">
                  <% vs_color = case meta['validation_status']
                     when 'approved'         then 'var(--success)'
                     when 'pending'          then 'var(--warning)'
                     when 'needs_validation' then 'var(--danger)'
                     else                        'var(--text-dim)'
                     end %>
                  <span style="font-family:var(--mono);font-size:11px;font-weight:600;
                               padding:2px 8px;border-radius:4px;
                               background:<%= vs_color %>22;color:<%= vs_color %>">
                    <%= meta['validation_status'].humanize %>
                  </span>
                </div>
              </div>
            <% end %>
            <% if meta['ai_confidence'].present? %>
              <div class="detail-field">
                <label>AI Confidence</label>
                <div class="value">
                  <% conf = (meta['ai_confidence'].to_f * 100).round %>
                  <% cc   = conf >= 80 ? 'var(--success)' : conf >= 50 ? 'var(--warning)' : 'var(--danger)' %>
                  <div style="display:flex;align-items:center;gap:8px">
                    <div style="width:80px;height:5px;background:var(--border);
                                border-radius:3px;overflow:hidden">
                      <div style="height:100%;width:<%= conf %>%;
                                  background:<%= cc %>;border-radius:3px"></div>
                    </div>
                    <span style="font-family:var(--mono);font-size:12px;
                                 font-weight:600;color:<%= cc %>"><%= conf %>%</span>
                  </div>
                </div>
              </div>
            <% end %>
            <% if meta['ai_brand_guess'].present? %>
              <div class="detail-field">
                <label>AI Brand Guess</label>
                <div class="value" style="color:var(--text-dim)"><%= meta['ai_brand_guess'] %></div>
              </div>
            <% end %>
            <% if meta['ai_category_guess'].present? %>
              <div class="detail-field">
                <label>AI Category Guess</label>
                <div class="value" style="color:var(--text-dim)"><%= meta['ai_category_guess'] %></div>
              </div>
            <% end %>
            <% if meta['ai_notes'].present? %>
              <div class="detail-field" style="grid-column:span 2">
                <label>AI Notes</label>
                <div class="value" style="color:var(--text-dim);font-style:italic">
                  "<%= meta['ai_notes'] %>"
                </div>
              </div>
            <% end %>
          </div>
          <% if meta['approved_by'].present? %>
            <div style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border);
                        font-size:11px;color:var(--text-dim)">
              Approved by User #<%= meta['approved_by'] %>
              <% if meta['approved_at'].present? %>
                on <%= Time.parse(meta['approved_at']).strftime('%d %b %Y') rescue meta['approved_at'] %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Custom metadata %>
      <% if custom_meta.any? %>
        <div>
          <div style="font-size:11px;font-weight:600;color:var(--text-dim);
                      text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">
            Custom Fields
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:8px">
            <% custom_meta.each do |key, val| %>
              <div style="padding:6px 12px;background:var(--bg);border:1px solid var(--border);
                          border-radius:6px;font-size:12px">
                <span style="color:var(--text-dim);margin-right:6px;
                             font-family:var(--mono);font-size:11px"><%= key %>:</span>
                <span style="color:var(--text);font-weight:500"><%= val %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  <% end %>

  <%# ── Organisation Catalogue (superadmin) ── %>
  <% if current_user.super_admin? %>
    <% org_products = @product.organisation_products.includes(:organisation) %>
    <div class="detail-section">
      <div class="detail-section-title">
        Organisation Catalogue
        <span style="font-size:11px;font-weight:400;color:var(--text-dim);margin-left:8px">
          orgs that have this product enrolled
        </span>
      </div>
      <% if org_products.any? %>
        <div style="display:flex;flex-wrap:wrap;gap:8px">
          <% org_products.each do |op| %>
            <span style="display:inline-flex;align-items:center;gap:6px;font-size:12px;
                         padding:5px 10px;border-radius:6px;
                         background:<%= op.active? ? 'rgba(79,142,247,0.1)' : 'rgba(122,131,153,0.1)' %>;
                         border:1px solid <%= op.active? ? 'rgba(79,142,247,0.3)' : 'var(--border)' %>;
                         color:<%= op.active? ? 'var(--accent)' : 'var(--text-dim)' %>">
              <%= op.organisation.name %>
              <% unless op.active? %>
                <span style="font-size:10px;opacity:0.7">(inactive)</span>
              <% end %>
              <% if op.mrp.present? %>
                <span style="font-family:var(--mono);font-size:10px;color:var(--text-dim)">
                  MRP ₹<%= op.mrp %>
                </span>
              <% end %>
              <% if op.internal_code.present? %>
                <span style="font-family:var(--mono);font-size:10px;color:var(--text-dim)">
                  · <%= op.internal_code %>
                </span>
              <% end %>
            </span>
          <% end %>
        </div>
      <% else %>
        <div style="font-size:13px;color:var(--text-dim);font-style:italic">
          Not enrolled in any organisation's catalogue yet.
        </div>
      <% end %>
    </div>
  <% end %>

</div>

<div style="margin-top:20px;display:flex;gap:10px">
  <%= link_to '← Back to Products', setup_products_path, class: 'btn btn-secondary' %>
  <% if current_user.super_admin? %>
    <%= link_to 'View Register', product_register_setup_products_path, class: 'btn btn-secondary' %>
  <% end %>
</div>
