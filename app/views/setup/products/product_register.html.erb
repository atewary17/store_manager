<%# app/views/setup/products/product_register.html.erb %>
<% content_for :title, "Product Register" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Setup</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Products', setup_products_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Product Register</span>
<% end %>

<%= render 'setup/shared/master_styles' %>

<div class="page-header">
  <div>
    <div class="page-title">Product Register</div>
    <div class="page-subtitle">All master products across every organisation — superadmin view</div>
  </div>
  <div class="actions">
    <%= link_to setup_products_path, class: 'btn btn-secondary' do %>
      ← My Org Products
    <% end %>
    <%= link_to product_register_export_setup_products_path(format: :xlsx), class: 'btn btn-secondary' do %>
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      Export All
    <% end %>
    <%= link_to new_setup_product_path, class: 'btn btn-primary' do %>
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      New Product
    <% end %>
  </div>
</div>

<%= render 'setup/shared/nav_tabs' %>

<%# ── Stats row ── %>
<div class="stats-row" style="grid-template-columns:repeat(5,1fr);margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-label">Total Products</div>
    <div class="stat-value accent"><%= @total_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Active</div>
    <div class="stat-value success"><%= @active_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Inactive</div>
    <div class="stat-value" style="color:var(--danger)"><%= @inactive_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Enrolled in ≥1 Org</div>
    <div class="stat-value success"><%= @enrolled_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Not Used by Any Org</div>
    <div class="stat-value" style="color:var(--text-dim)"><%= @unenrolled_count %></div>
  </div>
</div>

<%# ── Filters ── %>
<div class="filter-bar" style="flex-wrap:wrap">
  <div class="search-input-wrap">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" class="search-input"
           placeholder="Search brand, description, code..." id="productSearch">
  </div>

  <%= form_with url: product_register_setup_products_path, method: :get, local: true,
        style: 'display:flex;gap:8px;align-items:center;flex-wrap:wrap' do |f| %>
    <%= f.select :category_id,
          options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
          { include_blank: 'All Categories' },
          style: "background:var(--surface);border:1px solid var(--border);border-radius:6px;
                  padding:8px 12px;color:var(--text);font-size:13px;outline:none" %>
    <%= f.select :brand_id,
          options_from_collection_for_select(@brands, :id, :name, params[:brand_id]),
          { include_blank: 'All Brands' },
          style: "background:var(--surface);border:1px solid var(--border);border-radius:6px;
                  padding:8px 12px;color:var(--text);font-size:13px;outline:none" %>
    <%= f.select :status,
          [['All Statuses', ''], ['Active', 'active'], ['Inactive', 'inactive']],
          { selected: params[:status] },
          style: "background:var(--surface);border:1px solid var(--border);border-radius:6px;
                  padding:8px 12px;color:var(--text);font-size:13px;outline:none" %>
    <select name="org_id" onchange="this.form.submit()"
            style="background:var(--surface);border:1px solid var(--border);border-radius:6px;
                   padding:8px 12px;color:var(--text);font-size:13px;outline:none">
      <option value="">All Organisations</option>
      <% @orgs.each do |org| %>
        <option value="<%= org.id %>" <%= 'selected' if params[:org_id] == org.id.to_s %>>
          <%= org.name %>
        </option>
      <% end %>
    </select>
    <%= f.select :per_page,
          [['25 / page', 25], ['50 / page', 50], ['75 / page', 75]],
          { selected: @per_page },
          style: "background:var(--surface);border:1px solid var(--border);border-radius:6px;
                  padding:8px 12px;color:var(--text);font-size:13px;outline:none" %>
    <%= f.submit 'Filter', class: 'btn btn-secondary btn-sm' %>
    <% if params[:category_id].present? || params[:brand_id].present? || params[:status].present? || params[:org_id].present? %>
      <%= link_to 'Clear', product_register_setup_products_path, class: 'btn btn-secondary btn-sm' %>
    <% end %>
  <% end %>
</div>

<%# ── Table ── %>
<div class="table-wrap">
  <% if @products.any? %>
    <table id="productTable">
      <thead>
        <tr>
          <th>Brand &amp; Description</th>
          <th>Category</th>
          <th>Pack</th>
          <th>GST</th>
          <th>UOM</th>
          <th>Status</th>
          <th style="text-align:center">Orgs Using</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <%
            org_products   = product.organisation_products
            active_orgs    = org_products.count(&:active?)
            total_orgs     = org_products.size
            next if params[:org_id].present? &&
                    org_products.none? { |op| op.organisation_id.to_s == params[:org_id] }
          %>
          <tr>
            <%# Brand & Description %>
            <td style="max-width:260px">
              <div style="font-weight:500;font-size:13px">
                <%= product.brand&.name || '—' %>
              </div>
              <div style="font-size:12px;color:var(--text-dim);margin-top:2px;line-height:1.4">
                <%= link_to product.description.truncate(70), setup_product_path(product),
                      style: 'color:inherit;text-decoration:none' %>
              </div>
              <% if product.material_code.present? %>
                <div style="font-family:var(--mono);font-size:10px;color:var(--text-dim);margin-top:2px">
                  M: <%= product.material_code %>
                </div>
              <% end %>
            </td>

            <%# Category %>
            <td>
              <span class="badge badge-plan" style="font-size:10px">
                <%= product.product_category.name %>
              </span>
            </td>

            <%# Pack %>
            <td style="font-family:var(--mono);font-size:12px;color:var(--text-dim)">
              <%= product.pack_code.presence || '—' %>
            </td>

            <%# GST %>
            <td>
              <span style="font-family:var(--mono);font-size:12px;
                           background:<%= product.gst_rate == 0 ? 'rgba(52,217,139,0.1)' : 'rgba(247,195,79,0.1)' %>;
                           color:<%= product.gst_rate == 0 ? 'var(--success)' : 'var(--warning)' %>;
                           padding:2px 6px;border-radius:4px">
                <%= product.gst_rate %>%
              </span>
            </td>

            <%# UOM %>
            <td>
              <span style="font-family:var(--mono);font-size:11px;background:var(--bg);
                           border:1px solid var(--border);padding:2px 6px;border-radius:4px">
                <%= product.base_uom.short_name %>
              </span>
            </td>

            <%# Status %>
            <td>
              <span class="badge <%= product.active? ? 'badge-active' : 'badge-inactive' %>">
                <%= product.active? ? 'active' : 'inactive' %>
              </span>
            </td>

            <%# Orgs Using — count only %>
            <td style="text-align:center">
              <% if total_orgs > 0 %>
                <span title="<%= org_products.map { |op| op.organisation.name }.join(', ') %>"
                      style="font-family:var(--mono);font-size:13px;font-weight:600;
                             padding:3px 10px;border-radius:12px;cursor:default;
                             background:<%= active_orgs > 0 ? 'rgba(79,142,247,0.12)' : 'rgba(122,131,153,0.1)' %>;
                             color:<%= active_orgs > 0 ? 'var(--accent)' : 'var(--text-dim)' %>;
                             border:1px solid <%= active_orgs > 0 ? 'rgba(79,142,247,0.25)' : 'var(--border)' %>">
                  <%= active_orgs %><% if active_orgs < total_orgs %><span style="font-size:10px;opacity:0.6"> / <%= total_orgs %></span><% end %>
                </span>
              <% else %>
                <span style="font-size:11px;color:var(--text-dim)">—</span>
              <% end %>
            </td>

            <%# Actions %>
            <td>
              <div class="actions">
                <%= link_to 'View', setup_product_path(product), class: 'btn btn-secondary btn-sm' %>
                <%= link_to 'Edit', edit_setup_product_path(product), class: 'btn btn-secondary btn-sm' %>
                <%= button_to 'Delete', setup_product_path(product), method: :delete,
                      class: 'btn btn-danger btn-sm',
                      form: { style: 'margin:0;display:inline' },
                      data: { turbo_confirm: "Delete \"#{product.description}\"? This cannot be undone." } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <p>No products found.</p>
    </div>
  <% end %>
</div>

<%# ── Pagination ── %>
<% if @total_pages > 1 %>
  <div style="display:flex;align-items:center;justify-content:space-between;
              margin-top:16px;font-size:13px;color:var(--text-dim)">
    <span>
      Showing <%= ((@page - 1) * @per_page) + 1 %>–<%= [(@page * @per_page), @filtered_count].min %>
      of <%= @filtered_count %> products
    </span>
    <div style="display:flex;gap:6px;align-items:center">
      <% if @page > 1 %>
        <%= link_to '← Prev',
              product_register_setup_products_path(page: @page - 1, per_page: @per_page,
                category_id: params[:category_id], brand_id: params[:brand_id],
                status: params[:status], org_id: params[:org_id]),
              class: 'btn btn-secondary btn-sm' %>
      <% end %>
      <% ([[@page - 2, 1].max, 1].max..[[@page + 2, @total_pages].min, @total_pages].min).each do |p| %>
        <% if p == @page %>
          <span style="padding:5px 10px;background:var(--accent);color:#fff;
                       border-radius:6px;font-size:12px;font-weight:600"><%= p %></span>
        <% else %>
          <%= link_to p,
                product_register_setup_products_path(page: p, per_page: @per_page,
                  category_id: params[:category_id], brand_id: params[:brand_id],
                  status: params[:status], org_id: params[:org_id]),
                style: "padding:5px 10px;background:var(--surface);border:1px solid var(--border);
                        color:var(--text);border-radius:6px;font-size:12px;text-decoration:none" %>
        <% end %>
      <% end %>
      <% if @page < @total_pages %>
        <%= link_to 'Next →',
              product_register_setup_products_path(page: @page + 1, per_page: @per_page,
                category_id: params[:category_id], brand_id: params[:brand_id],
                status: params[:status], org_id: params[:org_id]),
              class: 'btn btn-secondary btn-sm' %>
      <% end %>
    </div>
  </div>
<% end %>

<script>
  document.getElementById('productSearch').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('#productTable tbody tr').forEach(row => {
      row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  });
</script>

<%# ══ UNMATCHED / PENDING PRODUCTS SECTION ══════════════════════ %>
<% if @pending_count > 0 %>
<div style="margin-top:36px">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
    <div style="font-size:16px;font-weight:600;color:var(--text)">Unmatched Products — Pending Review</div>
    <span style="font-family:var(--mono);font-size:11px;padding:2px 10px;border-radius:10px;
                 background:rgba(247,97,79,0.12);color:var(--danger);font-weight:600">
      <%= @pending_count %> pending
    </span>
  </div>

  <div style="margin-bottom:12px;padding:10px 14px;background:rgba(247,195,79,0.08);
              border:1px solid rgba(247,195,79,0.3);border-radius:6px;font-size:12px;
              color:var(--text-dim)">
    These products were created by the AI enrichment engine when purchase invoice items could not be matched.
    Review each one and <strong style="color:var(--success)">Approve</strong> to make it live,
    or <strong style="color:var(--accent)">Edit &amp; Approve</strong> to correct details first.
    Stock is already being tracked for these products.
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Description</th>
          <th>Material Code</th>
          <th>HSN</th>
          <th>GST</th>
          <th>Category</th>
          <th>Organisation</th>
          <th>AI Confidence</th>
          <th>Status</th>
          <th>Stock Qty</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @pending_products.each do |p| %>
          <% vs       = p.metadata['validation_status'] || 'pending' %>
          <% conf     = ((p.metadata['ai_confidence'].to_f) * 100).round %>
          <% orgs     = p.organisation_products.map { |op| op.organisation&.name }.compact %>
          <% stock    = StockLevel.where(product_id: p.id).sum(:quantity).to_f %>
          <tr>
            <td>
              <div style="font-weight:500"><%= p.description %></div>
              <% if p.brand.present? %>
                <div style="font-size:11px;color:var(--text-dim);margin-top:2px">
                  🏷 <%= p.brand.name %>
                </div>
              <% elsif p.metadata['ai_brand_guess'].present? %>
                <div style="font-size:11px;color:var(--warning);margin-top:2px">
                  🏷 <%= p.metadata['ai_brand_guess'] %>
                  <em style="font-size:10px">(AI guess — set on Edit)</em>
                </div>
              <% end %>
              <% if p.metadata['original_name'].present? && p.metadata['original_name'] != p.description %>
                <div style="font-size:11px;color:var(--text-dim);font-style:italic;margin-top:2px">
                  From invoice: "<%= p.metadata['original_name'] %>"
                </div>
              <% end %>
              <% if p.metadata['ai_notes'].present? %>
                <div style="font-size:10px;color:var(--text-dim);margin-top:2px">
                  📝 <%= p.metadata['ai_notes'] %>
                </div>
              <% end %>
            </td>
            <td style="font-family:var(--mono);font-size:12px"><%= p.material_code.presence || '—' %></td>
            <td style="font-family:var(--mono);font-size:12px"><%= p.hsn_code.presence || '—' %></td>
            <td style="font-family:var(--mono);font-size:12px;text-align:right"><%= p.gst_rate.to_f.round(0) %>%</td>
            <td style="font-size:12px">
              <%= p.product_category&.name || p.metadata['ai_category_guess'].presence || '—' %>
              <% if p.product_category.nil? %>
                <span style="font-size:9px;color:var(--warning);font-weight:600;display:block;margin-top:1px">⚠ needs review</span>
              <% end %>
            </td>
            <td style="font-size:11px">
              <% orgs.each do |org_name| %>
                <span style="font-size:10px;padding:1px 6px;border-radius:3px;
                             background:var(--accent-dim);color:var(--accent);
                             font-family:var(--mono);display:inline-block;margin:1px">
                  <%= org_name %>
                </span>
              <% end %>
            </td>
            <td style="text-align:center">
              <% conf_color = conf >= 80 ? 'var(--success)' : conf >= 50 ? 'var(--warning)' : 'var(--danger)' %>
              <span style="font-family:var(--mono);font-size:12px;font-weight:600;color:<%= conf_color %>">
                <%= conf %>%
              </span>
            </td>
            <td>
              <% badge_bg    = vs == 'needs_validation' ? 'rgba(247,195,79,0.12)' : 'rgba(247,97,79,0.12)' %>
              <% badge_color = vs == 'needs_validation' ? 'var(--warning)'       : 'var(--danger)' %>
              <span style="font-family:var(--mono);font-size:10px;padding:2px 7px;border-radius:3px;
                           text-transform:uppercase;letter-spacing:.05em;
                           background:<%= badge_bg %>;color:<%= badge_color %>">
                <%= vs.humanize %>
              </span>
            </td>
            <td style="font-family:var(--mono);font-size:12px;text-align:right;
                       color:<%= stock > 0 ? 'var(--success)' : 'var(--text-dim)' %>">
              <%= stock > 0 ? number_with_precision(stock, precision: 2, delimiter: ',') : '—' %>
            </td>
            <td style="font-family:var(--mono);font-size:11px;color:var(--text-dim)">
              <%= p.created_at.strftime('%d %b %Y') %>
            </td>
            <td>
              <div style="display:flex;gap:6px;flex-wrap:nowrap">
                <%= button_to '✅ Approve',
                      approve_pending_setup_products_path(p),
                      method: :post,
                      class: 'btn btn-secondary btn-sm',
                      style: 'color:var(--success);border-color:var(--success);white-space:nowrap',
                      data: { turbo_confirm: "Approve #{p.description}? It will become fully active and appear in sales searches." } %>
                <%= link_to '✏️ Edit',
                      edit_setup_product_path(p),
                      class: 'btn btn-secondary btn-sm',
                      style: 'white-space:nowrap' %>
                <% if stock <= 0 %>
                  <%= button_to '🗑 Delete',
                        reject_pending_setup_products_path(p),
                        method: :delete,
                        class: 'btn btn-secondary btn-sm',
                        style: 'color:var(--danger);border-color:var(--danger);white-space:nowrap',
                        data: { turbo_confirm: "Delete #{p.description}? This cannot be undone." } %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<% end %>
