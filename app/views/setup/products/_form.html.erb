<%# app/views/setup/products/_form.html.erb %>
<% if product.errors.any? %>
  <div class="flash alert" style="margin:20px 24px 0">
    <strong><%= product.errors.count %> error(s):</strong>
    <ul style="margin-top:6px;padding-left:16px">
      <% product.errors.full_messages.each do |msg| %>
        <li style="margin-top:2px"><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="form-section">
  <div class="form-section-title">Classification</div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :product_category_id, "Category *" %>
      <%= f.select :product_category_id,
            options_from_collection_for_select(@categories, :id, :name, product.product_category_id),
            { include_blank: '— Select category —' } %>
      <% if product.errors[:product_category].any? %>
        <div class="form-error"><%= product.errors[:product_category].first %></div>
      <% end %>
    </div>

    <div class="form-group">
      <%= f.label :base_uom_id, "Base Unit of Measure *" %>
      <%= f.select :base_uom_id,
            options_from_collection_for_select(@uoms, :id, :display, product.base_uom_id),
            { include_blank: '— Select UOM —' } %>
      <div class="form-hint">Default unit this product is sold/purchased in</div>
      <% if product.errors[:base_uom].any? %>
        <div class="form-error"><%= product.errors[:base_uom].first %></div>
      <% end %>
    </div>
  </div>
</div>

<div class="form-section">
  <div class="form-section-title">Product Details</div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :brand_id, "Brand *" %>
      <% if @brands.empty? %>
        <div class="alert" style="color:var(--warning);background:var(--warning-dim);
                                  border-radius:6px;padding:8px 12px;font-size:13px;margin-top:4px">
          No brands set up yet.
          <%= link_to 'Add a brand first', new_setup_brand_path, target: '_blank' %>
          then refresh this page.
        </div>
      <% else %>
        <%= f.select :brand_id,
              options_from_collection_for_select(@brands, :id, :name, product.brand_id),
              { include_blank: '— Select brand —' },
              { class: product.errors[:brand].any? ? 'form-control input-error' : 'form-control' } %>
        <div class="form-hint">
          Not listed? <%= link_to 'Add brand', new_setup_brand_path, target: '_blank' %> then refresh.
        </div>
      <% end %>
      <% if product.errors[:brand].any? %>
        <div class="form-error"><%= product.errors[:brand].first %></div>
      <% end %>
    </div>

    <div class="form-group">
      <%= f.label :pack_code, "Pack Code" %>
      <%= f.text_field :pack_code,
            placeholder: 'e.g. 1L, 4L, 20L, 50Kg',
            style: 'font-family:var(--mono)',
            class: 'form-control' %>
      <div class="form-hint">Size or pack variant of this product</div>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :description, "Description *" %>
    <%= f.text_area :description,
          placeholder: 'Full product description (colour, finish, grade, etc.)',
          rows: 3,
          class: product.errors[:description].any? ? 'form-control input-error' : 'form-control' %>
    <% if product.errors[:description].any? %>
      <div class="form-error"><%= product.errors[:description].first %></div>
    <% end %>
  </div>
</div>

<div class="form-section">
  <div class="form-section-title">Codes & Identifiers</div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :material_code, "Material Code" %>
      <%= f.text_field :material_code,
            placeholder: "Manufacturer's code",
            style: 'font-family:var(--mono);letter-spacing:0.04em',
            class: product.errors[:material_code].any? ? 'form-control input-error' : 'form-control' %>
      <div class="form-hint">Unique code from manufacturer (optional)</div>
      <% if product.errors[:material_code].any? %>
        <div class="form-error"><%= product.errors[:material_code].first %></div>
      <% end %>
    </div>

    <div class="form-group">
      <%= f.label :product_code, "Product Code" %>
      <%= f.text_field :product_code,
            placeholder: 'Your internal code',
            style: 'font-family:var(--mono);letter-spacing:0.04em',
            class: product.errors[:product_code].any? ? 'form-control input-error' : 'form-control' %>
      <div class="form-hint">Your own internal reference code (optional)</div>
      <% if product.errors[:product_code].any? %>
        <div class="form-error"><%= product.errors[:product_code].first %></div>
      <% end %>
    </div>
  </div>
</div>

<div class="form-section">
  <div class="form-section-title">Tax & Pricing</div>

  <div class="form-row">
    <div class="form-group">
      <%= f.label :hsn_code, "HSN Code" %>
      <%= f.text_field :hsn_code,
            placeholder: 'e.g. 3208, 3209',
            style: 'font-family:var(--mono);letter-spacing:0.08em',
            maxlength: 8,
            class: 'form-control' %>
      <div class="form-hint">
        HSN code for GST classification
        <a href="https://www.cbic.gov.in" target="_blank"
           style="color:var(--accent);margin-left:4px;font-size:11px">lookup ↗</a>
      </div>
    </div>

    <div class="form-group">
      <%= f.label :gst_rate, "GST Rate *" %>
      <%= f.select :gst_rate,
            [['0% — Exempt', 0.0],
             ['5% — Essential goods', 5.0],
             ['12% — Standard goods', 12.0],
             ['18% — Standard goods', 18.0],
             ['28% — Luxury goods', 28.0]],
            { selected: product.gst_rate || 18.0 },
            { class: 'form-control' } %>
      <% if product.errors[:gst_rate].any? %>
        <div class="form-error"><%= product.errors[:gst_rate].first %></div>
      <% end %>
    </div>

    <% if Product.column_names.include?('mrp') %>
      <div class="form-group">
        <%= f.label :mrp, "MRP (₹)" %>
        <%= f.number_field :mrp,
              placeholder: '0.00',
              step: '0.01',
              min: '0',
              style: 'font-family:var(--mono)',
              class: 'form-control' %>
        <div class="form-hint">Max retail price — optional</div>
        <% if product.errors[:mrp].any? %>
          <div class="form-error"><%= product.errors[:mrp].first %></div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="form-section">
  <div class="form-section-title">Status</div>
  <div class="form-group" style="max-width:240px">
    <%= f.label :active, "Status" %>
    <%= f.select :active, [['Active', true], ['Inactive', false]],
          { selected: product.active },
          { class: 'form-control' } %>
    <div class="form-hint">Inactive products won't appear on invoices</div>
  </div>
</div>

<%# ── Metadata section ── %>
<div class="form-section">
  <div class="form-section-title">
    Metadata
    <span style="font-size:11px;font-weight:400;color:var(--text-dim);margin-left:8px">
      Key-value pairs — used for tinting, AI enrichment, custom attributes
    </span>
  </div>

  <%
    meta            = product.metadata || {}
    # Well-known keys shown as dedicated fields
    known_meta_keys = %w[tint family_colour canister_volume_ml source validation_status
                         ai_confidence ai_brand_guess ai_category_guess ai_notes original_name]
  %>

  <%# ── Tinting machine fields ── %>
  <div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;
              padding:14px 16px;margin-bottom:14px">
    <div style="font-size:11px;font-weight:600;color:var(--accent);
                text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px">
      🎨 Tinting Machine
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Tintable?</label>
        <select name="product[metadata][tint]" class="form-control">
          <option value="" <%= 'selected' if meta['tint'].blank? %>>— not set —</option>
          <option value="true"  <%= 'selected' if meta['tint'].to_s == 'true' %>>Yes — colorant/tint product</option>
          <option value="false" <%= 'selected' if meta['tint'].to_s == 'false' %>>No</option>
        </select>
        <div class="form-hint">Set to Yes for colorants that can be loaded into the tinting machine</div>
      </div>
      <div class="form-group">
        <label class="form-label">Family Colour</label>
        <input type="text" name="product[metadata][family_colour]"
               value="<%= meta['family_colour'] %>"
               placeholder="e.g. Red Oxide, Burnt Amber, Black"
               class="form-control">
        <div class="form-hint">Colour family shown in tinting machine UI</div>
      </div>
      <div class="form-group">
        <label class="form-label">Canister Volume (ml)</label>
        <input type="number" name="product[metadata][canister_volume_ml]"
               value="<%= meta['canister_volume_ml'] %>"
               placeholder="e.g. 500, 1000"
               min="50" step="50"
               class="form-control" style="font-family:var(--mono)">
        <div class="form-hint">Default ml loaded per can — derived from pack_code if blank</div>
      </div>
    </div>
  </div>

  <%# ── AI Enrichment fields (read-ish — show if present) ── %>
  <% if meta['source'].present? || meta['validation_status'].present? %>
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;
                padding:14px 16px;margin-bottom:14px">
      <div style="font-size:11px;font-weight:600;color:var(--warning);
                  text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px">
        🤖 AI Enrichment
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Source</label>
          <input type="text" name="product[metadata][source]"
                 value="<%= meta['source'] %>"
                 class="form-control" style="font-family:var(--mono)">
        </div>
        <div class="form-group">
          <label class="form-label">Validation Status</label>
          <select name="product[metadata][validation_status]" class="form-control">
            <option value="" <%= 'selected' if meta['validation_status'].blank? %>>— not set —</option>
            <option value="pending"          <%= 'selected' if meta['validation_status'] == 'pending' %>>Pending</option>
            <option value="approved"         <%= 'selected' if meta['validation_status'] == 'approved' %>>Approved</option>
            <option value="needs_validation" <%= 'selected' if meta['validation_status'] == 'needs_validation' %>>Needs Validation</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">AI Confidence</label>
          <input type="number" name="product[metadata][ai_confidence]"
                 value="<%= meta['ai_confidence'] %>"
                 placeholder="0.0 – 1.0" min="0" max="1" step="0.01"
                 class="form-control" style="font-family:var(--mono)">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">AI Brand Guess</label>
          <input type="text" name="product[metadata][ai_brand_guess]"
                 value="<%= meta['ai_brand_guess'] %>"
                 class="form-control">
        </div>
        <div class="form-group">
          <label class="form-label">AI Category Guess</label>
          <input type="text" name="product[metadata][ai_category_guess]"
                 value="<%= meta['ai_category_guess'] %>"
                 class="form-control">
        </div>
        <div class="form-group">
          <label class="form-label">Original Invoice Name</label>
          <input type="text" name="product[metadata][original_name]"
                 value="<%= meta['original_name'] %>"
                 class="form-control">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">AI Notes</label>
        <input type="text" name="product[metadata][ai_notes]"
               value="<%= meta['ai_notes'] %>"
               class="form-control">
      </div>
    </div>
  <% end %>

  <%# ── Custom / extra metadata key-value pairs ── %>
  <div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;
              padding:14px 16px">
    <div style="font-size:11px;font-weight:600;color:var(--text-dim);
                text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px">
      Custom Fields
      <span style="font-size:10px;font-weight:400;text-transform:none;margin-left:6px">
        — any extra key-value pairs
      </span>
    </div>
    <div id="custom-meta-rows">
      <%
        custom_meta = meta.reject { |k, _| known_meta_keys.include?(k) ||
                                           k.start_with?('created', 'approved', 'created_by') }
      %>
      <% custom_meta.each do |key, val| %>
        <div class="custom-meta-row"
             style="display:flex;gap:8px;align-items:center;margin-bottom:8px">
          <input type="text"
                 name="product[metadata_custom_keys][]"
                 value="<%= key %>"
                 placeholder="key"
                 class="form-control"
                 style="max-width:200px;font-family:var(--mono);font-size:12px">
          <input type="text"
                 name="product[metadata_custom_values][]"
                 value="<%= val %>"
                 placeholder="value"
                 class="form-control"
                 style="font-size:12px">
          <button type="button"
                  onclick="this.closest('.custom-meta-row').remove()"
                  style="background:none;border:none;color:var(--danger);
                         cursor:pointer;font-size:18px;padding:0 4px;flex-shrink:0">×</button>
        </div>
      <% end %>
    </div>
    <button type="button" onclick="addCustomMeta()"
            style="font-size:12px;padding:6px 14px;border-radius:6px;
                   border:1px dashed var(--border);background:none;
                   color:var(--text-dim);cursor:pointer;margin-top:4px">
      + Add custom field
    </button>
  </div>
</div>

<script>
function addCustomMeta() {
  var row = document.createElement('div');
  row.className = 'custom-meta-row';
  row.style.cssText = 'display:flex;gap:8px;align-items:center;margin-bottom:8px';
  row.innerHTML =
    '<input type="text" name="product[metadata_custom_keys][]" placeholder="key" ' +
    'class="form-control" style="max-width:200px;font-family:var(--mono);font-size:12px">' +
    '<input type="text" name="product[metadata_custom_values][]" placeholder="value" ' +
    'class="form-control" style="font-size:12px">' +
    '<button type="button" onclick="this.closest('.custom-meta-row').remove()" ' +
    'style="background:none;border:none;color:var(--danger);cursor:pointer;font-size:18px;' +
    'padding:0 4px;flex-shrink:0">×</button>';
  document.getElementById('custom-meta-rows').appendChild(row);
}
</script>

<%# Superadmin-only: manage which orgs have this product in their catalogue %>
<% if defined?(@all_orgs) && @all_orgs.present? %>
  <div class="form-section">
    <div class="form-section-title">
      Organisation Catalogue
      <span style="font-size:11px;font-weight:400;color:var(--text-dim);margin-left:8px">
        superadmin only — tick orgs that should see this product
      </span>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px">
      <% @all_orgs.each do |org| %>
        <label style="display:flex;align-items:center;gap:8px;padding:10px 12px;
                      background:var(--bg);border:1px solid var(--border);border-radius:8px;
                      cursor:pointer;font-size:13px">
          <input type="checkbox"
                 name="enrol_org_ids[]"
                 value="<%= org.id %>"
                 <%= 'checked' if @enrolled_org_ids.include?(org.id) %>
                 style="width:15px;height:15px;accent-color:var(--accent)">
          <span style="color:var(--text)"><%= org.name %></span>
        </label>
      <% end %>
    </div>
    <div class="form-hint" style="margin-top:8px">
      Unchecking an org marks their enrolment inactive — history is preserved.
    </div>
  </div>
<% end %>
