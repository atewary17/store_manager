<%# app/views/setup/product_imports/index.html.erb %>
<% content_for :title, "Imports" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Setup</span>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Imports</span>
<% end %>

<%= render 'setup/shared/master_styles' %>

<%= render 'setup/shared/nav_tabs' %>

<div class="actions" style="margin-bottom:24px;display:flex;gap:12px">
  <%= link_to '+ Import Products', new_setup_product_import_path, class: 'btn btn-primary' %>
  <%= link_to '+ Import Shades',   import_new_setup_shade_catalogues_path, class: 'btn btn-secondary' %>
</div>

<%# ── Product Imports ── %>
<div style="margin-bottom:32px">
  <div style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px">Product Imports</div>
  <div class="table-wrap">
    <% if @product_imports.any? %>
      <table>
        <thead>
          <tr>
            <th>File</th>
            <th>Uploaded By</th>
            <th>Date</th>
            <th>Status</th>
            <th>Total</th>
            <th>Created</th>
            <th>Updated</th>
            <th>Errors</th>
            <th>Size</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @product_imports.each do |imp| %>
            <tr>
              <td style="font-family:var(--mono);font-size:12px"><%= imp.file_name %></td>
              <td><%= imp.user.full_name %></td>
              <td style="font-family:var(--mono);font-size:12px">
                <%= imp.created_at.strftime('%d %b %Y, %H:%M') %>
              </td>
              <td>
                <span class="badge <%= status_badge_class(imp.status) %>">
                  <%= imp.status.humanize %>
                </span>
              </td>
              <td style="font-family:var(--mono)"><%= imp.total_rows %></td>
              <td style="font-family:var(--mono);color:var(--success)">
                <%= imp.success_count - imp.update_count %>
              </td>
              <td style="font-family:var(--mono);color:var(--accent)"><%= imp.update_count %></td>
              <td>
                <% if imp.error_count > 0 %>
                  <span style="color:var(--danger);font-family:var(--mono)"><%= imp.error_count %></span>
                <% else %>
                  <span style="color:var(--text-dim)">—</span>
                <% end %>
              </td>
              <td style="font-family:var(--mono);font-size:12px"><%= imp.file_size_human %></td>
              <td>
                <%= link_to 'View', setup_product_import_path(imp), class: 'btn btn-secondary btn-sm' %>
                <% if imp.has_errors? %>
                  <%= link_to 'Errors ↓', download_errors_setup_product_import_path(imp),
                        class: 'btn btn-danger btn-sm' %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state">
        <p>No product imports yet. <%= link_to 'Start your first import', new_setup_product_import_path %>.</p>
      </div>
    <% end %>
  </div>
</div>

<%# ── Shade Catalogue Imports ── %>
<div>
  <div style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px">Shade Catalogue Imports</div>
  <div class="table-wrap">
    <% if @shade_imports.any? %>
      <table>
        <thead>
          <tr>
            <th>File</th>
            <th>Category</th>
            <th>Uploaded By</th>
            <th>Date</th>
            <th>Status</th>
            <th>Total</th>
            <th>Created</th>
            <th>Updated</th>
            <th>Errors</th>
            <th>Size</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @shade_imports.each do |imp| %>
            <tr>
              <td style="font-family:var(--mono);font-size:12px"><%= imp.file_name %></td>
              <td><%= imp.product_category&.name %></td>
              <td><%= imp.user.full_name %></td>
              <td style="font-family:var(--mono);font-size:12px">
                <%= imp.created_at.strftime('%d %b %Y, %H:%M') %>
              </td>
              <td>
                <span class="badge <%= status_badge_class(imp.status) %>">
                  <%= imp.status.humanize %>
                </span>
              </td>
              <td style="font-family:var(--mono)"><%= imp.total_rows %></td>
              <td style="font-family:var(--mono);color:var(--success)">
                <%= imp.success_count - imp.update_count %>
              </td>
              <td style="font-family:var(--mono);color:var(--accent)"><%= imp.update_count %></td>
              <td>
                <% if imp.error_count > 0 %>
                  <span style="color:var(--danger);font-family:var(--mono)"><%= imp.error_count %></span>
                <% else %>
                  <span style="color:var(--text-dim)">—</span>
                <% end %>
              </td>
              <td style="font-family:var(--mono);font-size:12px"><%= imp.file_size_human %></td>
              <td>
                <%= link_to 'View', import_show_setup_shade_catalogue_path(imp),
                      class: 'btn btn-secondary btn-sm' %>
                <% if imp.has_errors? %>
                  <%= link_to 'Errors ↓', import_download_errors_setup_shade_catalogue_path(imp),
                        class: 'btn btn-danger btn-sm' %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state">
        <p>No shade imports yet. <%= link_to 'Start your first shade import', import_new_setup_shade_catalogues_path %>.</p>
      </div>
    <% end %>
  </div>
</div>
