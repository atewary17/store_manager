<%# app/views/setup/price_list_rows/import.html.erb %>
<% content_for :title, "Import Price List" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Setup</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Price List', setup_price_list_rows_path %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Import</span>
<% end %>

<%= render 'setup/shared/master_styles' %>

<div class="page-header">
  <div class="page-title">Import Price List</div>
  <%= link_to '← Back', setup_price_list_rows_path, class: 'btn btn-secondary' %>
</div>

<div class="detail-card" style="max-width:640px">

  <%# ── Before you upload ── %>
  <div style="margin-bottom:20px;padding:14px;background:var(--accent-dim);
              border-radius:8px;border:1px solid var(--border)">
    <div style="font-size:13px;color:var(--text);margin-bottom:8px;font-weight:500">
      Before uploading
    </div>
    <ul style="font-size:12px;color:var(--text-dim);padding-left:16px;line-height:1.9">
      <li>
        Download the
        <%= link_to 'import template', template_setup_price_list_rows_path %>
        — it shows the required column layout with example data
      </li>
      <li>Rows 2 and 3 in the template are guide rows — delete them or leave them, the importer skips them automatically</li>
      <li><code>product_base_name</code> and <code>dealer_price</code> are the only required columns</li>
      <li><code>prod_code</code>, <code>shade_code</code>, and <code>pack_code</code> are treated as text — leading zeros are preserved</li>
      <li>All imported rows start with <strong>match_status = pending</strong> — the background job links them to catalogue products</li>
      <li>The effective date you enter below is applied to every row unless the file has its own <code>effective_date</code> column</li>
    </ul>
  </div>

  <%# ── Column guide ── %>
  <div style="margin-bottom:20px;padding:14px;background:var(--bg);
              border-radius:8px;border:1px solid var(--border)">
    <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;
                color:var(--text-dim);margin-bottom:10px;font-family:var(--mono)">
      Column Guide
    </div>
    <table style="width:100%;border-collapse:collapse;font-size:11px">
      <thead>
        <tr style="border-bottom:1px solid var(--border)">
          <th style="text-align:left;padding:4px 8px;color:var(--text-dim)">Column</th>
          <th style="text-align:left;padding:4px 8px;color:var(--text-dim)">Required</th>
          <th style="text-align:left;padding:4px 8px;color:var(--text-dim)">Notes</th>
        </tr>
      </thead>
      <tbody>
        <% [
          ['brand',             false, 'Reference only — not stored'],
          ['product_base_name', true,  'Full product line name from price list'],
          ['prod_code',         false, '4-digit code — text, leading zeros kept'],
          ['shade_name',        false, 'Human-readable shade name'],
          ['shade_code',        false, 'Shade code e.g. 0912, 0W06 — text'],
          ['dpl_group',         false, 'Dealer price list group number'],
          ['pack_size_litres',  false, 'Pack volume in litres e.g. 0.500, 1.000'],
          ['pack_code',         false, 'Pack variant code e.g. 150, 210 — text'],
          ['dealer_price',      true,  'Number only — no ₹ symbol or commas'],
          ['effective_date',    false, 'Overrides the form date if present (YYYY-MM-DD)'],
        ].each do |col, required, note| %>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:5px 8px;font-family:var(--mono);color:var(--accent)"><%= col %></td>
            <td style="padding:5px 8px">
              <% if required %>
                <span style="font-size:10px;padding:1px 6px;border-radius:3px;
                             background:rgba(192,0,0,0.08);color:#C00000;font-weight:600">
                  required
                </span>
              <% else %>
                <span style="font-size:10px;padding:1px 6px;border-radius:3px;
                             background:rgba(55,86,35,0.08);color:#375623">
                  optional
                </span>
              <% end %>
            </td>
            <td style="padding:5px 8px;color:var(--text-dim)"><%= note %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%# ── Upload form ── %>
  <%= form_with url: import_setup_price_list_rows_path, multipart: true,
        method: :post, local: true do |f| %>

    <div class="form-group">
      <%= f.label :effective_date, "Effective Date *" %>
      <%= f.date_field :effective_date,
            value: params[:effective_date] || Date.today.to_s,
            required: true,
            class: 'form-control',
            style: 'max-width:200px;font-family:var(--mono)' %>
      <div class="form-hint">
        Applied to all rows — override per-row by adding an
        <code>effective_date</code> column in the file
      </div>
    </div>

    <div class="form-group" style="margin-top:16px">
      <label>Excel File (.xlsx) *</label>
      <input type="file" name="file" accept=".xlsx" required
             style="display:block;width:100%;padding:10px;background:var(--bg);
                    border:1px solid var(--border);border-radius:6px;color:var(--text);
                    font-family:var(--mono);font-size:13px;cursor:pointer">
      <div class="form-hint">
        Maximum recommended: 5,000 rows per file.
        Use the
        <%= link_to 'import template', template_setup_price_list_rows_path %>
        if you're unsure of the format.
      </div>
    </div>

    <%# Warn if rows for this date already exist %>
    <% if @effective_dates.any? %>
      <div style="margin-top:12px;padding:10px 14px;background:var(--bg);
                  border-radius:6px;border:1px solid var(--border);font-size:12px;
                  color:var(--text-dim)">
        Existing price list dates:
        <% @effective_dates.each do |d| %>
          <span style="display:inline-block;margin-left:6px;font-family:var(--mono);
                       color:var(--accent)"><%= d.strftime('%d %b %Y') %></span>
        <% end %>
      </div>
    <% end %>

    <div style="margin-top:20px;display:flex;gap:10px">
      <%= f.submit 'Upload & Import', class: 'btn btn-primary' %>
      <%= link_to 'Cancel', setup_price_list_rows_path, class: 'btn btn-secondary' %>
    </div>
  <% end %>

</div>

<%# ── Recent import history ── %>
<% if @recent_imports.any? %>
  <div style="max-width:860px;margin-top:32px">
    <div style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px">
      Recent Price List Imports
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>File</th>
            <th>Uploaded By</th>
            <th>Date</th>
            <th>Effective Date</th>
            <th style="color:var(--success)">Added</th>
            <th style="color:var(--accent)">Updated</th>
            <th style="color:var(--text-dim)">Skipped</th>
            <th style="color:var(--danger)">Errors</th>
            <th>Size</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @recent_imports.each do |imp| %>
            <tr>
              <td style="font-family:var(--mono);font-size:12px"><%= imp.file_name %></td>
              <td><%= imp.user.full_name %></td>
              <td style="font-family:var(--mono);font-size:12px;white-space:nowrap">
                <%= imp.created_at.strftime('%d %b %Y, %H:%M') %>
              </td>
              <td style="font-family:var(--mono);font-size:12px">
                <%= imp.effective_date ? imp.effective_date.strftime('%d %b %Y') : '—' %>
              </td>
              <td style="font-family:var(--mono);color:var(--success)">
                <%= imp.success_count > 0 ? imp.success_count : '—' %>
              </td>
              <td style="font-family:var(--mono);color:var(--accent)">
                <%= imp.update_count > 0 ? imp.update_count : '—' %>
              </td>
              <td style="font-family:var(--mono);color:var(--text-dim)">
                <%= imp.skip_count > 0 ? imp.skip_count : '—' %>
              </td>
              <td>
                <% if imp.has_errors? %>
                  <span style="color:var(--danger);font-family:var(--mono)"><%= imp.error_count %></span>
                <% else %>
                  <span style="color:var(--text-dim)">—</span>
                <% end %>
              </td>
              <td style="font-family:var(--mono);font-size:12px"><%= imp.file_size_human %></td>
              <td>
                <%= link_to 'View', import_show_setup_price_list_rows_path(imp),
                      class: 'btn btn-secondary btn-sm' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
