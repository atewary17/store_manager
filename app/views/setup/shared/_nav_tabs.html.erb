<%# app/views/setup/shared/_nav_tabs.html.erb %>
<div class="setup-tabs">

  <%= link_to setup_brands_path,
        class: "setup-tab #{controller_name == 'brands' ? 'active' : ''}" do %>
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
      <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
      <line x1="7" y1="7" x2="7.01" y2="7"/>
    </svg>
    Brands
    <span class="setup-tab-count"><%= Brand.cached_count %></span>
  <% end %>

  <%= link_to setup_uoms_path,
        class: "setup-tab #{controller_name == 'uoms' ? 'active' : ''}" do %>
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
      <path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/>
    </svg>
    Units of Measure
    <span class="setup-tab-count"><%= Uom.cached_count %></span>
  <% end %>

  <%= link_to setup_product_categories_path,
        class: "setup-tab #{controller_name == 'product_categories' ? 'active' : ''}" do %>
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
      <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
    </svg>
    Product Categories
    <span class="setup-tab-count"><%= ProductCategory.cached_count %></span>
  <% end %>

  <%= link_to setup_products_path,
        class: "setup-tab #{controller_name == 'products' ? 'active' : ''}" do %>
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
      <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
      <line x1="12" y1="22.08" x2="12" y2="12"/>
    </svg>
    Products
    <span class="setup-tab-count"><%= Product.cached_count %></span>
  <% end %>

  <%= link_to setup_shade_catalogues_path,
        class: "setup-tab #{controller_name == 'shade_catalogues' ? 'active' : ''}" do %>
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      <path d="M2 12h20"/>
    </svg>
    Shade Catalogue
    <span class="setup-tab-count"><%= ActiveRecord::Base.connection.table_exists?(:shade_catalogues) ? ShadeCatalogue.cached_count : 0 %></span>
  <% end %>

  <%= link_to setup_product_imports_path,
        class: "setup-tab #{controller_name == 'product_imports' ? 'active' : ''}" do %>
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
      <polyline points="17 8 12 3 7 8"/>
      <line x1="12" y1="3" x2="12" y2="15"/>
    </svg>
    Imports
    <span class="setup-tab-count"><%= ProductImport.count + ShadeCatalogueImport.count %></span>
  <% end %>

</div>
