<%# app/views/setup/shared/_master_styles.html.erb %>
<style>
  /* ── SETUP TABS ── */
  .setup-tabs {
    display: flex;
    align-items: center;
    gap: 2px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 4px;
    margin-bottom: 16px;
    width: fit-content;
    max-width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .setup-tabs::-webkit-scrollbar { display: none; }
  .setup-tab {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 16px;
    border-radius: 7px;
    font-size: 12.5px;
    font-weight: 500;
    text-decoration: none;
    color: var(--text-dim);
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
    border: 1px solid transparent;
  }
  .setup-tab:hover {
    color: var(--text);
    background: var(--border);
  }
  .setup-tab.active {
    background: var(--accent-dim);
    color: var(--accent);
    border-color: rgba(79,142,247,0.25);
  }
  .setup-tab svg { opacity: 0.6; flex-shrink: 0; transition: opacity 0.15s; }
  .setup-tab:hover svg { opacity: 0.9; }
  .setup-tab.active svg { opacity: 1; }
  .setup-tab-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--border);
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    padding: 1px 7px;
    border-radius: 20px;
    min-width: 22px;
    line-height: 1.6;
    transition: background 0.15s, color 0.15s;
  }
  .setup-tab.active .setup-tab-count {
    background: rgba(79,142,247,0.18);
    color: var(--accent);
  }
</style>
