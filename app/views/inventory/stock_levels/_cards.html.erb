<%# app/views/inventory/stock_levels/_cards.html.erb %>
<% levels.each do |level| %>
  <% p = level.product %>
  <% last_date = last_entry[level.product_id] %>
  <%
    qty    = level.quantity
    in_stk = qty > 0
    low    = qty > 0 && qty <= 5
    status_color  = in_stk ? (low ? 'var(--warning)' : 'var(--success)') : 'var(--danger)'
    status_label  = in_stk ? (low ? 'Low stock' : 'In stock') : 'Out of stock'
    status_dot_bg = in_stk ? (low ? '#f7c34f' : '#34d98b') : '#f7614f'
    qty_fmt = number_with_precision(qty, precision: 3, strip_insignificant_zeros: true)
  %>
  <div class="sl-card" data-level-id="<%= level.id %>"
       style="background:var(--surface);border:1px solid var(--border);border-radius:12px;
              padding:16px 18px;display:flex;flex-direction:column;gap:10px;position:relative;
              transition:border-color .15s">
    <%# Top row: brand + category badge %>
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px">
      <div style="flex:1;min-width:0">
        <div style="font-weight:600;font-size:13px;color:var(--text);margin-bottom:2px;
                    white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
          <%= p.brand&.name || '—' %>
          <% if p.pack_code.present? %>
            <span style="font-family:var(--mono);font-size:11px;color:var(--text-dim);
                         font-weight:400;margin-left:4px"><%= p.pack_code %></span>
          <% end %>
          <% if !p.active? && p.metadata&.dig('source') == 'ai_enrichment' %>
            <span style="font-size:9px;font-weight:700;padding:1px 5px;border-radius:3px;
                         background:rgba(247,195,79,0.15);color:var(--warning);
                         margin-left:5px;vertical-align:middle;font-family:var(--mono)">
              PENDING
            </span>
          <% end %>
        </div>
        <div style="font-size:12px;color:var(--text-dim);line-height:1.4;
                    overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">
          <%= p.description %>
        </div>
      </div>
      <span style="flex-shrink:0;font-size:10px;font-weight:600;padding:3px 8px;border-radius:5px;
                   background:rgba(79,142,247,0.1);color:var(--accent);white-space:nowrap">
        <%= p.product_category&.name %>
      </span>
    </div>

    <%# Material code %>
    <% if p.material_code.present? %>
      <div style="font-family:var(--mono);font-size:10px;color:var(--text-dim);
                  background:var(--bg);border:1px solid var(--border);border-radius:4px;
                  padding:2px 7px;display:inline-block;width:fit-content">
        <%= p.material_code %>
      </div>
    <% end %>

    <%# Divider %>
    <div style="border-top:1px solid var(--border)"></div>

    <%# Qty row with +/- buttons %>
    <div style="display:flex;align-items:center;justify-content:space-between;gap:8px">
      <div style="display:flex;align-items:center;gap:10px">
        <%# Minus button %>
        <button class="sl-adj-btn" data-id="<%= level.id %>" data-delta="-1"
                data-url="<%= quick_adjust_inventory_stock_level_path(level) %>"
                <%= 'disabled' if stock_locked %>
                style="width:30px;height:30px;border-radius:8px;border:1px solid var(--border);
                       background:var(--bg);color:<%= stock_locked ? 'var(--muted)' : 'var(--text)' %>;
                       font-size:16px;cursor:<%= stock_locked ? 'not-allowed' : 'pointer' %>;
                       display:flex;align-items:center;justify-content:center;flex-shrink:0;
                       transition:background .1s,border-color .1s;
                       opacity:<%= stock_locked ? '0.4' : '1' %>"
                title="<%= stock_locked ? 'Stock updates are locked' : 'Remove 1' %>">−</button>

        <%# Qty display %>
        <div style="text-align:center;min-width:64px">
          <div class="sl-qty-val" style="font-family:var(--mono);font-size:22px;font-weight:700;
                                          color:<%= status_color %>;line-height:1">
            <%= qty_fmt %>
          </div>
          <div style="font-size:11px;color:var(--text-dim);margin-top:1px;font-family:var(--mono)">
            <%= p.base_uom&.short_name %>
          </div>
        </div>

        <%# Plus button %>
        <button class="sl-adj-btn" data-id="<%= level.id %>" data-delta="+1"
                data-url="<%= quick_adjust_inventory_stock_level_path(level) %>"
                <%= 'disabled' if stock_locked %>
                style="width:30px;height:30px;border-radius:8px;border:1px solid var(--border);
                       background:var(--bg);color:<%= stock_locked ? 'var(--muted)' : 'var(--text)' %>;
                       font-size:16px;cursor:<%= stock_locked ? 'not-allowed' : 'pointer' %>;
                       display:flex;align-items:center;justify-content:center;flex-shrink:0;
                       transition:background .1s,border-color .1s;
                       opacity:<%= stock_locked ? '0.4' : '1' %>"
                title="<%= stock_locked ? 'Stock updates are locked' : 'Add 1' %>">+</button>
      </div>

      <%# Status dot + label %>
      <div style="display:flex;align-items:center;gap:5px">
        <span style="width:8px;height:8px;border-radius:50%;background:<%= status_dot_bg %>;
                     flex-shrink:0" class="sl-status-dot"></span>
        <span class="sl-status-label" style="font-size:11px;color:<%= status_color %>;font-weight:500">
          <%= status_label %>
        </span>
      </div>
    </div>

    <%# Footer: avg cost + last entry date + ledger link %>
    <div style="display:flex;align-items:center;justify-content:space-between;
                font-size:11px;color:var(--text-dim);flex-wrap:wrap;gap:4px">
      <div style="display:flex;gap:12px;font-family:var(--mono)">
        <% if level.avg_cost.to_f > 0 %>
          <span>Avg ₹<%= number_with_precision(level.avg_cost, precision: 2) %></span>
        <% end %>
        <% if last_date %>
          <span>Last: <%= last_date.strftime('%d %b %y') %></span>
        <% end %>
      </div>
      <%= link_to 'Ledger →',
            ledger_inventory_opening_stock_path(product_id: p.id),
            style: "font-size:11px;color:var(--accent);text-decoration:none;white-space:nowrap" %>
    </div>
  </div>
<% end %>
