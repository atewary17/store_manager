<%# app/views/inventory/stock_levels/index.html.erb %>
<% content_for :title, "Stock Dashboard" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Inventory</span>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Stock Dashboard</span>
<% end %>

<div class="page-header">
  <div>
    <div class="page-title">Stock Dashboard</div>
    <div class="page-subtitle"><%= @organisation.name %></div>
  </div>
  <div class="actions">
    <%# View toggle %>
    <div style="display:flex;border:1px solid var(--border);border-radius:7px;overflow:hidden">
      <button id="btn-card-view" onclick="setView('card')"
              style="padding:7px 12px;border:none;cursor:pointer;display:flex;align-items:center;
                     gap:5px;font-size:12px;transition:background .15s">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Cards
      </button>
      <button id="btn-list-view" onclick="setView('list')"
              style="padding:7px 12px;border:none;border-left:1px solid var(--border);cursor:pointer;
                     display:flex;align-items:center;gap:5px;font-size:12px;transition:background .15s">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
          <line x1="8" y1="18" x2="21" y2="18"/>
          <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/>
          <line x1="3" y1="18" x2="3.01" y2="18"/>
        </svg>
        List
      </button>
    </div>
    <%= link_to export_inventory_stock_levels_path(format: :xlsx,
                  **request.query_parameters.slice('category_id','brand_id','q','stock_status','sort')),
              class: 'btn btn-secondary' do %>
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      Export Stock
    <% end %>
    <%= link_to new_inventory_opening_stock_path, class: 'btn btn-primary' do %>
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Opening Stock
    <% end %>
  </div>
</div>

<%# ── Stats ── %>
<div class="stats-row" style="grid-template-columns:repeat(5,1fr);margin-bottom:20px">
  <div class="stat-card">
    <div class="stat-label">Total Products</div>
    <div class="stat-value accent"><%= @total_products %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Units in Stock</div>
    <div class="stat-value" style="color:var(--accent)">
      <%= number_with_delimiter(@total_units.to_i) %>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-label">In Stock</div>
    <div class="stat-value" style="color:var(--success)"><%= @in_stock_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Out of Stock</div>
    <div class="stat-value" style="color:var(--danger)"><%= @out_of_stock_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Stock Value (₹)</div>
    <div class="stat-value" style="font-size:18px"><%= number_with_delimiter(@total_value.to_i) %></div>
  </div>
</div>

<%# ── Filters ── %>
<div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:20px">
  <div style="position:relative;flex:1;min-width:200px;max-width:300px">
    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"
         viewBox="0 0 24 24" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);
         color:var(--text-dim);pointer-events:none">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" id="sl-search" value="<%= params[:q] %>"
           placeholder="Search brand, product, code..."
           style="width:100%;padding:8px 12px 8px 30px;background:var(--surface);
                  border:1px solid var(--border);border-radius:6px;color:var(--text);
                  font-size:13px;outline:none;box-sizing:border-box">
  </div>

  <%= form_with url: inventory_stock_levels_path, method: :get, local: true,
        id: 'sl-filter-form', style: 'display:contents' do |f| %>
    <input type="hidden" name="q" id="sl-q-hidden" value="<%= params[:q] %>">
    <input type="hidden" name="view" id="sl-view-hidden" value="<%= params[:view] || 'card' %>">
    <%= f.select :category_id,
          options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
          { include_blank: 'All Categories' },
          { class: 'form-control', style: 'width:170px', onchange: 'this.form.submit()' } %>
    <%= f.select :brand_id,
          options_from_collection_for_select(@brands, :id, :name, params[:brand_id]),
          { include_blank: 'All Brands' },
          { class: 'form-control', style: 'width:150px', onchange: 'this.form.submit()' } %>
    <%= f.select :stock_status,
          [['All Stock',''],['In Stock','in_stock'],['Out of Stock','out_of_stock'],['Low Stock (≤5)','low_stock']],
          { selected: params[:stock_status] },
          { class: 'form-control', style: 'width:150px', onchange: 'this.form.submit()' } %>
    <%= f.select :sort,
          [['Sort: Name','name'],['Sort: Qty ↑','qty_asc'],['Sort: Qty ↓','qty_desc'],
           ['Sort: Latest Entry','entry_latest'],['Sort: Oldest Entry','entry_oldest']],
          { selected: params[:sort] || 'name' },
          { class: 'form-control', style: 'width:160px', onchange: 'this.form.submit()' } %>
    <% if params[:category_id].present? || params[:brand_id].present? ||
          params[:stock_status].present? || params[:q].present? %>
      <%= link_to 'Clear', inventory_stock_levels_path(view: params[:view]), class: 'btn btn-secondary btn-sm' %>
    <% end %>
  <% end %>
</div>

<% if @stock_locked %>
  <div style="display:flex;align-items:center;gap:10px;padding:11px 16px;margin-bottom:16px;
              background:rgba(247,97,79,0.07);border:1px solid rgba(247,97,79,0.25);
              border-radius:10px;font-size:13px">
    <svg width="15" height="15" fill="none" stroke="var(--danger)" stroke-width="2" viewBox="0 0 24 24"
         style="flex-shrink:0">
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
    </svg>
    <span style="color:var(--danger);font-weight:600">Stock updates are locked</span>
    <span style="color:var(--text-dim)">— manual ± adjustments are disabled by your administrator.</span>
    <% if current_user.admin? || current_user.owner? || current_user.super_admin? %>
      <%= link_to 'Manage in Profile →', profile_path,
            style: 'margin-left:auto;font-size:12px;color:var(--danger);
                    text-decoration:none;white-space:nowrap;font-weight:500' %>
    <% end %>
  </div>
<% end %>

<% if @levels.any? %>

  <%# ── Card view ── %>
  <div id="view-card">
    <div id="sl-grid" style="display:grid;
         grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
         gap:14px;margin-bottom:16px">
      <%= render 'inventory/stock_levels/cards', levels: @levels, last_entry: @last_entry,
                                                 stock_locked: @stock_locked %>
    </div>
    <% if @has_more %>
      <div id="sl-sentinel" style="height:40px;display:flex;align-items:center;
           justify-content:center;color:var(--text-dim);font-size:13px">
        <span id="sl-loading-txt">Loading more…</span>
      </div>
    <% end %>
  </div>

  <%# ── List view ── %>
  <div id="view-list" style="display:none">
    <div id="sl-list-wrap">
      <%= render 'inventory/stock_levels/list', levels: @levels, last_entry: @last_entry,
                                               stock_locked: @stock_locked %>
    </div>
    <% if @has_more %>
      <div id="sl-sentinel-list" style="height:40px;display:flex;align-items:center;
           justify-content:center;color:var(--text-dim);font-size:13px">
        <span id="sl-loading-list-txt">Loading more…</span>
      </div>
    <% end %>
  </div>

  <div style="font-size:12px;color:var(--text-dim);text-align:center;margin-top:8px">
    Showing <span id="sl-shown-count"><%= @levels.size %></span> of <%= @total_products %> products
  </div>

<% else %>
  <div class="empty-state">
    <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="1"
         viewBox="0 0 24 24" style="color:var(--muted);margin:0 auto 12px;display:block">
      <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
    </svg>
    <p>No stock data yet.</p>
    <div style="margin-top:16px">
      <%= link_to 'Enter Opening Stock', new_inventory_opening_stock_path, class: 'btn btn-primary' %>
    </div>
  </div>
<% end %>

<%# Toast %>
<div id="sl-toast" style="position:fixed;bottom:24px;right:24px;padding:10px 18px;
     background:var(--surface);border:1px solid var(--border);border-radius:8px;
     font-size:13px;color:var(--text);box-shadow:0 4px 16px rgba(0,0,0,0.2);
     display:none;z-index:9999"></div>

<style>
  #btn-card-view, #btn-list-view {
    background: var(--bg);
    color: var(--text-dim);
  }
  #btn-card-view.active, #btn-list-view.active {
    background: var(--accent);
    color: #fff;
  }
  .sl-adj-btn:hover  { background: var(--muted) !important; border-color: var(--accent) !important; }
  .sl-adj-btn:active { transform: scale(.93); }
  .sl-adj-btn:disabled { opacity: .4; cursor: not-allowed; }
  .sl-card:hover { border-color: var(--accent) !important; }
  .sl-card.adjusting { opacity: .7; pointer-events: none; }
</style>

<script>
(function() {
  var csrf       = document.querySelector('meta[name="csrf-token"]')?.content;
  var currentPage = <%= @page %>;
  var hasMore     = <%= @has_more ? 'true' : 'false' %>;
  var loading     = false;
  var baseUrl     = '<%= inventory_stock_levels_path %>';
  var currentParams = new URLSearchParams(window.location.search);

  // ── View toggle — persisted in localStorage + hidden input ──
  var savedView = localStorage.getItem('sl-view') || '<%= params[:view] || 'card' %>';
  function setView(v) {
    savedView = v;
    localStorage.setItem('sl-view', v);
    document.getElementById('sl-view-hidden').value = v;
    document.getElementById('view-card').style.display = v === 'card' ? '' : 'none';
    document.getElementById('view-list').style.display = v === 'list' ? '' : 'none';
    document.getElementById('btn-card-view').classList.toggle('active', v === 'card');
    document.getElementById('btn-list-view').classList.toggle('active', v === 'list');
  }
  window.setView = setView;
  setView(savedView);

  // ── Toast ──
  function toast(msg, ok) {
    var el = document.getElementById('sl-toast');
    el.textContent = msg;
    el.style.color = ok === false ? 'var(--danger)' : ok ? 'var(--success)' : 'var(--text)';
    el.style.display = 'block'; el.style.opacity = '1';
    clearTimeout(el._t);
    el._t = setTimeout(function() { el.style.display = 'none'; }, 2200);
  }

  // ── Shared adjust handler — works for both card and list views ──
  function handleAdjust(btn) {
    var card  = btn.closest('.sl-card');
    var url   = btn.dataset.url;
    var delta = btn.dataset.delta;
    if (!card || !url) return;

    card.classList.add('adjusting');
    card.querySelectorAll('.sl-adj-btn').forEach(function(b) { b.disabled = true; });

    var fd = new FormData();
    fd.append('delta', delta);
    fd.append('authenticity_token', csrf);

    fetch(url, { method: 'POST', body: fd, headers: { 'Accept': 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        card.classList.remove('adjusting');
        card.querySelectorAll('.sl-adj-btn').forEach(function(b) { b.disabled = false; });

        if (data.error) { toast(data.error, false); return; }

        // Update qty value in this card/row
        var qtyEl = card.querySelector('.sl-qty-val');
        if (qtyEl) qtyEl.textContent = data.qty_fmt;

        // Update status dot + label (card view only)
        var dot   = card.querySelector('.sl-status-dot');
        var label = card.querySelector('.sl-status-label');
        if (dot && label) {
          var low = data.qty > 0 && data.qty <= 5;
          if (data.in_stock) {
            dot.style.background = low ? '#f7c34f' : '#34d98b';
            label.textContent    = low ? 'Low stock' : 'In stock';
            label.style.color    = low ? 'var(--warning)' : 'var(--success)';
            if (qtyEl) qtyEl.style.color = low ? 'var(--warning)' : 'var(--success)';
          } else {
            dot.style.background = '#f7614f';
            label.textContent    = 'Out of stock';
            label.style.color    = 'var(--danger)';
            if (qtyEl) qtyEl.style.color = 'var(--danger)';
          }
        }

        toast((parseFloat(delta) > 0 ? '+1 added' : '−1 removed') + ' · Stock: ' + data.qty_fmt, true);
      })
      .catch(function() {
        card.classList.remove('adjusting');
        card.querySelectorAll('.sl-adj-btn').forEach(function(b) { b.disabled = false; });
        toast('Network error — try again', false);
      });
  }

  // Delegate clicks from both card grid and list wrap
  ['sl-grid','sl-list-wrap'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('click', function(e) {
      var btn = e.target.closest('.sl-adj-btn');
      if (btn) handleAdjust(btn);
    });
  });

  // ── Live search debounce ──
  var searchInput = document.getElementById('sl-search');
  if (searchInput) {
    var debTimer;
    searchInput.addEventListener('input', function() {
      clearTimeout(debTimer);
      debTimer = setTimeout(function() {
        document.getElementById('sl-q-hidden').value = searchInput.value;
        document.getElementById('sl-filter-form').submit();
      }, 400);
    });
  }

  // ── Infinite scroll (works for active view) ──
  function loadMore(viewType) {
    if (loading || !hasMore) return;
    loading = true;
    var txtId = viewType === 'card' ? 'sl-loading-txt' : 'sl-loading-list-txt';
    var el = document.getElementById(txtId);
    if (el) el.textContent = 'Loading…';

    currentPage++;
    var p = new URLSearchParams(currentParams.toString());
    p.set('page', currentPage);
    p.set('format', 'json');
    p.set('list_partial', viewType === 'list' ? '1' : '0');

    fetch(baseUrl + '?' + p.toString(), { headers: { 'Accept': 'application/json' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        loading  = false;
        hasMore  = data.has_more;

        if (viewType === 'card') {
          document.getElementById('sl-grid').insertAdjacentHTML('beforeend', data.html);
        } else {
          var tbody = document.querySelector('#sl-list-wrap table tbody');
          if (tbody) tbody.insertAdjacentHTML('beforeend', data.list_html || '');
        }

        var shownEl = document.getElementById('sl-shown-count');
        if (shownEl) shownEl.textContent = parseInt(shownEl.textContent) + 50;

        if (!hasMore) {
          var s = document.getElementById(viewType === 'card' ? 'sl-sentinel' : 'sl-sentinel-list');
          if (s) s.remove();
        } else if (el) {
          el.textContent = 'Loading more…';
        }
      })
      .catch(function() { loading = false; });
  }

  function observeSentinel(id, viewType) {
    var el = document.getElementById(id);
    if (!el || typeof IntersectionObserver === 'undefined') return;
    var obs = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) { obs.unobserve(el); loadMore(viewType); }
    }, { rootMargin: '200px' });
    obs.observe(el);
  }

  observeSentinel('sl-sentinel',      'card');
  observeSentinel('sl-sentinel-list', 'list');
})();
</script>
