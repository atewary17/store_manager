<%# app/views/inventory/stock_levels/index.html.erb %>
<% content_for :title, "Stock Levels" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Inventory</span>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Stock Levels</span>
<% end %>

<div class="page-header">
  <div>
    <div class="page-title">Stock Levels</div>
    <div class="page-subtitle"><%= @organisation.name %></div>
  </div>
  <div class="actions">
    <%= link_to new_inventory_opening_stock_path, class: 'btn btn-primary' do %>
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Enter Opening Stock
    <% end %>
  </div>
</div>

<%# ── Stats ── %>
<div class="stats-row" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-label">Total Products</div>
    <div class="stat-value accent"><%= @total_products %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">In Stock</div>
    <div class="stat-value" style="color:var(--success)"><%= @in_stock_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Out of Stock</div>
    <div class="stat-value" style="color:var(--danger)"><%= @out_of_stock_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Stock Value (₹)</div>
    <div class="stat-value" style="font-size:20px">
      <%= number_with_delimiter(@total_value.round(0)) %>
    </div>
  </div>
</div>

<%# ── Filters ── %>
<%= form_with url: inventory_stock_levels_path, method: :get, local: true,
      style: "display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:20px" do |f| %>

  <%= f.select :category_id,
        options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
        { include_blank: 'All Categories' },
        { class: 'form-control', style: 'width:180px' } %>

  <%= f.select :brand_id,
        options_from_collection_for_select(@brands, :id, :name, params[:brand_id]),
        { include_blank: 'All Brands' },
        { class: 'form-control', style: 'width:160px' } %>

  <%= f.select :stock_status,
        [['All Stock', ''], ['In Stock', 'in_stock'], ['Out of Stock', 'out_of_stock']],
        { selected: params[:stock_status] },
        { class: 'form-control', style: 'width:140px' } %>

  <%= f.submit 'Filter', class: 'btn btn-secondary' %>
  <% if params[:category_id].present? || params[:brand_id].present? || params[:stock_status].present? %>
    <%= link_to 'Clear', inventory_stock_levels_path, class: 'btn btn-secondary' %>
  <% end %>
<% end %>

<%# ── Table ── %>
<div class="table-wrap">
  <% if @levels.any? %>
    <table>
      <thead>
        <tr>
          <th>Product</th>
          <th>Brand</th>
          <th>Category</th>
          <th>UOM</th>
          <th style="text-align:right">Qty on Hand</th>
          <th style="text-align:right">Avg Cost (₹)</th>
          <th style="text-align:right">Stock Value (₹)</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @levels.each do |level| %>
          <% p = level.product %>
          <tr>
            <td>
              <div style="font-weight:500"><%= p.description %></div>
              <% if p.pack_code.present? %>
                <div style="font-size:11px;color:var(--text-dim);font-family:var(--mono)">
                  <%= p.pack_code %>
                </div>
              <% end %>
            </td>
            <td style="color:var(--text-dim);font-size:13px">
              <%= p.brand&.name || '—' %>
            </td>
            <td>
              <span class="badge badge-plan" style="font-size:10px">
                <%= p.product_category&.name %>
              </span>
            </td>
            <td style="font-family:var(--mono);font-size:12px">
              <%= p.base_uom&.short_name %>
            </td>
            <td style="text-align:right;font-family:var(--mono);font-weight:600;
                       color:<%= level.in_stock? ? 'var(--text)' : 'var(--danger)' %>">
              <%= number_with_precision(level.quantity, precision: 3, strip_insignificant_zeros: true) %>
            </td>
            <td style="text-align:right;font-family:var(--mono);color:var(--text-dim)">
              <%= level.avg_cost.present? && level.avg_cost > 0 ?
                    number_with_precision(level.avg_cost, precision: 2) : '—' %>
            </td>
            <td style="text-align:right;font-family:var(--mono)">
              <%= level.stock_value > 0 ?
                    number_with_delimiter(level.stock_value.round(0)) : '—' %>
            </td>
            <td>
              <% if level.in_stock? %>
                <span class="badge badge-active">In Stock</span>
              <% else %>
                <span class="badge badge-inactive">Out</span>
              <% end %>
            </td>
            <td>
              <%= link_to 'Ledger',
                    ledger_inventory_opening_stock_path(product_id: p.id),
                    class: 'btn btn-secondary btn-sm' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <p>No stock data yet.</p>
      <div style="margin-top:16px">
        <%= link_to 'Enter Opening Stock', new_inventory_opening_stock_path, class: 'btn btn-primary' %>
      </div>
    </div>
  <% end %>
</div>
