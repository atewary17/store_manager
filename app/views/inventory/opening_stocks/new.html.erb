<%# app/views/inventory/opening_stocks/new.html.erb %>
<% content_for :title, "Opening Stock" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Inventory</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Stock Levels', inventory_stock_levels_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Opening Stock Entry</span>
<% end %>

<div class="page-header">
  <div>
    <div class="page-title">Opening Stock Entry</div>
    <div class="page-subtitle">
      <%= @organisation.name %> —
      Enter quantities for products that already have physical stock.
      Leave quantity blank to skip a product.
    </div>
  </div>
</div>

<% if @products.empty? %>
  <div class="table-wrap">
    <div class="empty-state">
      <p>All active products already have opening stock entries.</p>
      <div style="margin-top:16px">
        <%= link_to 'View Stock Levels', inventory_stock_levels_path, class: 'btn btn-primary' %>
      </div>
    </div>
  </div>
<% else %>

  <%# ── Filter bar (client-side) ── %>
  <div style="display:flex;gap:10px;align-items:center;margin-bottom:20px;flex-wrap:wrap">
    <input type="text" id="productFilter"
           placeholder="Filter by product, brand, category…"
           oninput="filterRows(this.value)"
           style="background:var(--surface);border:1px solid var(--border);border-radius:6px;
                  padding:8px 12px;color:var(--text);font-size:13px;outline:none;width:280px">

    <select id="categoryFilter" onchange="filterRows()"
            style="background:var(--surface);border:1px solid var(--border);border-radius:6px;
                   padding:8px 12px;color:var(--text);font-size:13px;outline:none;width:180px">
      <option value="">All Categories</option>
      <% @categories.each do |cat| %>
        <option value="<%= cat.id %>"><%= cat.name %></option>
      <% end %>
    </select>

    <select id="brandFilter" onchange="filterRows()"
            style="background:var(--surface);border:1px solid var(--border);border-radius:6px;
                   padding:8px 12px;color:var(--text);font-size:13px;outline:none;width:160px">
      <option value="">All Brands</option>
      <% @brands.each do |b| %>
        <option value="<%= b.id %>"><%= b.name %></option>
      <% end %>
    </select>

    <span style="font-family:var(--mono);font-size:12px;color:var(--text-dim)">
      <span id="visibleCount"><%= @products.count %></span> of <%= @products.count %> products
    </span>
  </div>

  <%= form_with url: inventory_opening_stock_path, method: :post, local: true do |f| %>
    <div class="table-wrap">
      <table id="openingStockTable">
        <thead>
          <tr>
            <th>Product</th>
            <th>Brand</th>
            <th>Category</th>
            <th>UOM</th>
            <th style="width:130px">Opening Qty *</th>
            <th style="width:140px">Unit Cost (₹)</th>
            <th style="width:200px">Notes</th>
          </tr>
        </thead>
        <tbody>
          <% @products.each do |product| %>
            <tr data-product="<%= product.description.downcase %>"
                data-brand="<%= product.brand&.name&.downcase %>"
                data-brand-id="<%= product.brand_id %>"
                data-category-id="<%= product.product_category_id %>">
              <td>
                <div style="font-weight:500"><%= product.description %></div>
                <% if product.pack_code.present? %>
                  <div style="font-size:11px;color:var(--text-dim);font-family:var(--mono)">
                    <%= product.pack_code %>
                  </div>
                <% end %>
              </td>
              <td style="color:var(--text-dim);font-size:13px">
                <%= product.brand&.name || '—' %>
              </td>
              <td>
                <span class="badge badge-plan" style="font-size:10px">
                  <%= product.product_category&.name %>
                </span>
              </td>
              <td style="font-family:var(--mono);font-size:12px">
                <%= product.base_uom&.short_name %>
              </td>
              <td>
                <input type="number"
                       name="entries[<%= product.id %>][quantity]"
                       placeholder="0"
                       min="0"
                       step="0.001"
                       style="width:100%;background:var(--bg);border:1px solid var(--border);
                              border-radius:5px;padding:7px 10px;color:var(--text);
                              font-family:var(--mono);font-size:13px;outline:none"
                       onfocus="this.style.borderColor='var(--accent)'"
                       onblur="this.style.borderColor='var(--border)'">
              </td>
              <td>
                <input type="number"
                       name="entries[<%= product.id %>][unit_cost]"
                       placeholder="0.00"
                       min="0"
                       step="0.01"
                       style="width:100%;background:var(--bg);border:1px solid var(--border);
                              border-radius:5px;padding:7px 10px;color:var(--text);
                              font-family:var(--mono);font-size:13px;outline:none"
                       onfocus="this.style.borderColor='var(--accent)'"
                       onblur="this.style.borderColor='var(--border)'">
              </td>
              <td>
                <input type="text"
                       name="entries[<%= product.id %>][notes]"
                       placeholder="Optional note"
                       style="width:100%;background:var(--bg);border:1px solid var(--border);
                              border-radius:5px;padding:7px 10px;color:var(--text);
                              font-size:13px;outline:none"
                       onfocus="this.style.borderColor='var(--accent)'"
                       onblur="this.style.borderColor='var(--border)'">
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div style="margin-top:20px;display:flex;gap:12px;align-items:center">
      <%= f.submit 'Save Opening Stock', class: 'btn btn-primary' %>
      <%= link_to 'Cancel', inventory_stock_levels_path, class: 'btn btn-secondary' %>
      <span style="font-size:12px;color:var(--text-dim)">
        Only rows with a quantity entered will be saved.
      </span>
    </div>
  <% end %>

<% end %>

<script>
  function filterRows(val) {
    var text     = document.getElementById('productFilter').value.toLowerCase();
    var catId    = document.getElementById('categoryFilter').value;
    var brandId  = document.getElementById('brandFilter').value;
    var rows     = document.querySelectorAll('#openingStockTable tbody tr');
    var visible  = 0;

    rows.forEach(function(row) {
      var matchText  = !text    || row.dataset.product.includes(text) || (row.dataset.brand||'').includes(text);
      var matchCat   = !catId   || row.dataset.categoryId === catId;
      var matchBrand = !brandId || row.dataset.brandId === brandId;
      var show = matchText && matchCat && matchBrand;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    document.getElementById('visibleCount').textContent = visible;
  }
</script>
