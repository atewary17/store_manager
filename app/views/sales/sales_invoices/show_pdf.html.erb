<%# app/views/sales/sales_invoices/show_pdf.html.erb
    Clean PDF-only invoice template. No CSS variables, no dark theme,
    no nav buttons. Rendered by wicked_pdf via layouts/pdf.html.erb.
%>
<%
  inv   = @invoice
  org   = inv.organisation
  cust  = inv.customer
  items = inv.sales_invoice_items.order(:id)

  subtotal  = inv.computed_taxable_total.to_f + inv.computed_tax_total.to_f
  taxable   = inv.computed_taxable_total.to_f
  tax_total = inv.computed_tax_total.to_f
  discount  = inv.overall_discount_amount.to_f
  grand     = inv.computed_grand_total.to_f
%>

<%# ── Invoice header: org left, INVOICE title right ── %>
<table style="width:100%;border-collapse:collapse;margin-bottom:18px">
  <tr>
    <td style="vertical-align:top;padding:0">
      <div style="font-size:19px;font-weight:700;color:#1a1f2e;letter-spacing:-0.3px">
        <%= org.name %>
      </div>
      <% if org.respond_to?(:gstin) && org.gstin.present? %>
        <div style="font-size:10px;color:#6b7280;margin-top:3px;font-family:'Courier New',monospace">
          GSTIN: <%= org.gstin %>
        </div>
      <% end %>
      <% addr = org.try(:address).presence || org.try(:metadata)&.dig('address') %>
      <% if addr.present? %>
        <div style="font-size:10px;color:#6b7280;margin-top:2px;line-height:1.5"><%= addr %></div>
      <% end %>
    </td>
    <td style="vertical-align:top;text-align:right;padding:0">
      <div style="font-size:24px;font-weight:700;color:#1a1f2e;letter-spacing:3px;text-transform:uppercase">
        Invoice
      </div>
      <div style="font-family:'Courier New',monospace;font-size:13px;color:#374151;margin-top:4px;font-weight:600">
        <%= inv.display_number %>
      </div>
      <div style="font-size:11px;color:#6b7280;margin-top:3px">
        <%= inv.invoice_date&.strftime('%d %b %Y') %>
      </div>
      <% if inv.confirmed? %>
        <div style="display:inline-block;margin-top:6px;padding:2px 10px;background:#dcfce7;
                    color:#15803d;border-radius:3px;font-size:10px;font-weight:700;letter-spacing:0.06em">
          CONFIRMED
        </div>
      <% else %>
        <div style="display:inline-block;margin-top:6px;padding:2px 10px;background:#fef9c3;
                    color:#a16207;border-radius:3px;font-size:10px;font-weight:700;letter-spacing:0.06em">
          DRAFT
        </div>
      <% end %>
    </td>
  </tr>
</table>

<div style="border-top:2px solid #1a1f2e;margin-bottom:16px"></div>

<%# ── Bill-to / invoice-meta strip ── %>
<table style="width:100%;border-collapse:collapse;margin-bottom:18px;
              background:#f8f9fd;border:1px solid #e5e7eb;border-radius:5px">
  <tr>
    <td style="padding:10px 14px;vertical-align:top;width:55%">
      <div style="font-size:9px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;
                  color:#9ca3af;margin-bottom:4px">Bill To</div>
      <div style="font-size:13px;font-weight:600;color:#1a1f2e">
        <%= cust&.name || 'Walk-in Customer' %>
      </div>
      <% if cust&.phone.present? %>
        <div style="font-size:10px;color:#6b7280;font-family:'Courier New',monospace;margin-top:2px">
          <%= cust.phone %>
        </div>
      <% end %>
      <% if cust&.gstin.present? %>
        <div style="font-size:10px;color:#6b7280;font-family:'Courier New',monospace;margin-top:1px">
          GSTIN: <%= cust.gstin %>
        </div>
      <% end %>
      <% cust_addr = cust&.try(:address).presence || cust&.try(:metadata)&.dig('address') %>
      <% if cust_addr.present? %>
        <div style="font-size:10px;color:#6b7280;margin-top:2px;line-height:1.5"><%= cust_addr %></div>
      <% end %>
    </td>
    <td style="padding:10px 14px;vertical-align:top;border-left:1px solid #e5e7eb">
      <table style="width:100%;border-collapse:collapse">
        <% [
          ['Invoice No.',   inv.invoice_number.presence  || '—'],
          ['Date',          inv.invoice_date&.strftime('%d %b %Y') || '—'],
          ['Payment',       inv.payment_mode&.titleize   || '—'],
        ].each do |lbl, val| %>
          <tr>
            <td style="font-size:10px;color:#9ca3af;padding:2px 0;font-weight:600;
                       letter-spacing:0.04em;text-transform:uppercase"><%= lbl %></td>
            <td style="font-size:11px;color:#1a1f2e;font-family:'Courier New',monospace;
                       text-align:right;padding:2px 0;font-weight:600"><%= val %></td>
          </tr>
        <% end %>
      </table>
    </td>
  </tr>
</table>

<%# ── Line items table ── %>
<table style="width:100%;border-collapse:collapse;margin-bottom:0">
  <thead>
    <tr style="background:#1a1f2e">
      <th style="padding:7px 10px;text-align:left;font-size:9px;font-weight:600;
                 color:#fff;letter-spacing:0.07em;text-transform:uppercase">#</th>
      <th style="padding:7px 10px;text-align:left;font-size:9px;font-weight:600;
                 color:#fff;letter-spacing:0.07em;text-transform:uppercase">Item / Shade</th>
      <th style="padding:7px 10px;text-align:center;font-size:9px;font-weight:600;
                 color:#fff;letter-spacing:0.07em;text-transform:uppercase">Type</th>
      <th style="padding:7px 8px;text-align:right;font-size:9px;font-weight:600;
                 color:#fff;letter-spacing:0.07em;text-transform:uppercase">Qty</th>
      <th style="padding:7px 8px;text-align:right;font-size:9px;font-weight:600;
                 color:#fff;letter-spacing:0.07em;text-transform:uppercase">Rate</th>
      <th style="padding:7px 8px;text-align:right;font-size:9px;font-weight:600;
                 color:#fff;letter-spacing:0.07em;text-transform:uppercase">Taxable</th>
      <th style="padding:7px 8px;text-align:center;font-size:9px;font-weight:600;
                 color:#fff;letter-spacing:0.07em;text-transform:uppercase">GST</th>
      <th style="padding:7px 10px;text-align:right;font-size:9px;font-weight:600;
                 color:#fff;letter-spacing:0.07em;text-transform:uppercase">Amount</th>
    </tr>
  </thead>
  <tbody>
    <% items.each_with_index do |item, i| %>
      <tr style="border-bottom:1px solid #e5e7eb;<%= item.paint? ? 'background:#fffbeb' : (i.even? ? '' : 'background:#fafafa') %>">
        <td style="padding:7px 10px;font-size:10px;color:#9ca3af;font-family:'Courier New',monospace">
          <%= i + 1 %>
        </td>
        <td style="padding:7px 10px;vertical-align:top">
          <% if item.paint? %>
            <div style="font-size:11px;font-weight:600;color:#1a1f2e"><%= item.shade_display %></div>
            <% shade_meta = [item.metadata['colour_family'], item.base_product&.pack_code&.prepend('Base: ')].compact_blank.join(' · ') %>
            <% if shade_meta.present? %>
              <div style="font-size:9px;color:#9ca3af;font-family:'Courier New',monospace;margin-top:1px"><%= shade_meta %></div>
            <% end %>
          <% elsif item.adhoc? %>
            <div style="font-size:11px;font-weight:600;color:#1a1f2e"><%= item.description.presence || 'Ad-hoc charge' %></div>
          <% else %>
            <div style="font-size:11px;font-weight:600;color:#1a1f2e"><%= item.product&.display_name || '—' %></div>
            <% if item.product&.material_code.present? %>
              <div style="font-size:9px;color:#9ca3af;font-family:'Courier New',monospace;margin-top:1px">
                <%= item.product.material_code %>
              </div>
            <% end %>
          <% end %>
        </td>
        <td style="padding:7px 8px;text-align:center;vertical-align:top">
          <span style="font-size:8px;font-family:'Courier New',monospace;font-weight:700;
                       padding:2px 5px;border-radius:3px;letter-spacing:0.05em;
                       background:<%= item.paint? ? '#fef3c7' : (item.adhoc? ? '#d1fae5' : '#dbeafe') %>;
                       color:<%= item.paint? ? '#92400e' : (item.adhoc? ? '#065f46' : '#1e40af') %>">
            <%= item.line_type.upcase %>
          </span>
        </td>
        <td style="padding:7px 8px;text-align:right;font-size:11px;
                   font-family:'Courier New',monospace;vertical-align:top">
          <%= number_with_precision(item.quantity, precision: 3, strip_insignificant_zeros: true) %>
          <% uom = item.product&.base_uom&.short_name || (item.paint? ? 'Ltr' : '') %>
          <% if uom.present? %><div style="font-size:9px;color:#9ca3af"><%= uom %></div><% end %>
        </td>
        <td style="padding:7px 8px;text-align:right;font-size:11px;
                   font-family:'Courier New',monospace;vertical-align:top">
          <%= number_with_precision(item.unit_rate, precision: 2) %>
        </td>
        <td style="padding:7px 8px;text-align:right;font-size:11px;
                   font-family:'Courier New',monospace;vertical-align:top">
          <%= number_with_precision(item.taxable_amount, precision: 2) %>
        </td>
        <td style="padding:7px 8px;text-align:center;font-size:10px;
                   font-family:'Courier New',monospace;color:#6b7280;vertical-align:top">
          <% gst = item.cgst_percent.to_f + item.sgst_percent.to_f %>
          <%= gst > 0 ? "#{gst.to_i}%" : '—' %>
        </td>
        <td style="padding:7px 10px;text-align:right;font-size:12px;font-weight:700;
                   font-family:'Courier New',monospace;vertical-align:top;color:#1a1f2e">
          <%= number_with_precision(item.total_amount, precision: 2) %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%# ── Totals ── %>
<table style="width:100%;border-collapse:collapse;border-top:2px solid #1a1f2e">
  <tr>
    <td style="padding:0;vertical-align:top;width:55%">
      <%# Left: notes / blank for signature later %>
    </td>
    <td style="padding:0;vertical-align:top">
      <table style="width:100%;border-collapse:collapse">
        <tr>
          <td style="padding:6px 10px;font-size:11px;color:#6b7280">Subtotal</td>
          <td style="padding:6px 10px;text-align:right;font-size:11px;
                     font-family:'Courier New',monospace;color:#1a1f2e">
            Rs. <%= number_with_precision(subtotal, precision: 2, delimiter: ',') %>
          </td>
        </tr>
        <tr>
          <td style="padding:6px 10px;font-size:11px;color:#6b7280">Taxable</td>
          <td style="padding:6px 10px;text-align:right;font-size:11px;
                     font-family:'Courier New',monospace;color:#1a1f2e">
            Rs. <%= number_with_precision(taxable, precision: 2, delimiter: ',') %>
          </td>
        </tr>
        <tr>
          <td style="padding:6px 10px;font-size:11px;color:#6b7280">GST</td>
          <td style="padding:6px 10px;text-align:right;font-size:11px;
                     font-family:'Courier New',monospace;color:#1a1f2e">
            Rs. <%= number_with_precision(tax_total, precision: 2, delimiter: ',') %>
          </td>
        </tr>
        <% if discount > 0 %>
          <tr style="border-top:1px solid #e5e7eb">
            <td style="padding:6px 10px;font-size:11px;color:#d97706">Discount</td>
            <td style="padding:6px 10px;text-align:right;font-size:11px;
                       font-family:'Courier New',monospace;color:#d97706">
              &minus; Rs. <%= number_with_precision(discount, precision: 2, delimiter: ',') %>
            </td>
          </tr>
        <% end %>
        <tr style="background:#1a1f2e">
          <td style="padding:9px 10px;font-size:13px;font-weight:700;color:#fff">
            Grand Total
          </td>
          <td style="padding:9px 10px;text-align:right;font-size:13px;font-weight:700;
                     font-family:'Courier New',monospace;color:#fff">
            Rs. <%= number_with_precision(grand, precision: 2, delimiter: ',') %>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<%# ── Footer ── %>
<div style="margin-top:24px;padding-top:12px;border-top:1px solid #e5e7eb;
            display:flex;justify-content:space-between;align-items:flex-end">
  <div style="font-size:9px;color:#9ca3af;line-height:1.6">
    Generated on <%= Date.today.strftime('%d %b %Y') %><br>
    <%= org.name %>
  </div>
  <div style="text-align:right">
    <div style="margin-bottom:30px;font-size:9px;color:#9ca3af">Authorised Signatory</div>
    <div style="border-top:1px solid #9ca3af;padding-top:4px;width:160px;
                font-size:9px;color:#9ca3af;text-align:center">
      <%= org.name %>
    </div>
  </div>
</div>
