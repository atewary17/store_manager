<%# app/views/sales/sales_invoices/show.html.erb %>
<% content_for :title, @invoice.display_number %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Sales</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Invoices', sales_sales_invoices_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current"><%= @invoice.display_number %></span>
<% end %>

<%
  ps       = @invoice.payment_status   # 'paid' | 'partial' | 'unpaid'
  is_paid  = @invoice.fully_paid?
  overdue  = @invoice.overdue?
  can_edit_due = !@invoice.voided? && !is_paid
%>

<style>
  /* ── Page layout ── */
  .inv-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 20px;
    align-items: start;
  }
  .inv-main  { display: flex; flex-direction: column; gap: 20px; }
  .inv-aside { display: flex; flex-direction: column; gap: 16px; }

  /* ── Shared card ── */
  .inv-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }
  .inv-card-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
  }
  .inv-card-label {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--text-dim); font-weight: 500;
  }

  /* ── Status strip (top of page) ── */
  .inv-status-strip {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 18px 24px;
    position: relative; overflow: hidden;
  }
  .inv-status-strip::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
  }
  .strip-confirmed::before { background: linear-gradient(90deg, var(--success), rgba(52,217,139,0.3)); }
  .strip-draft::before     { background: linear-gradient(90deg, var(--warning), rgba(247,195,79,0.3)); }
  .strip-voided::before    { background: linear-gradient(90deg, var(--danger),  rgba(247,97,79,0.3)); }
  .strip-overdue::before   { background: linear-gradient(90deg, var(--danger),  rgba(247,97,79,0.3)); }

  .inv-number { font-size: 20px; font-weight: 700; letter-spacing: -0.02em; }
  .inv-number-sub { font-family: var(--mono); font-size: 11px; color: var(--text-dim); margin-top: 3px; }

  .status-badges { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .s-badge {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: var(--mono); font-size: 10px; font-weight: 600;
    letter-spacing: 0.07em; text-transform: uppercase;
    padding: 4px 11px; border-radius: 100px;
  }
  .s-badge-confirmed { background: rgba(52,217,139,0.12); color: var(--success); border: 1px solid rgba(52,217,139,0.2); }
  .s-badge-draft     { background: rgba(247,195,79,0.12); color: var(--warning); border: 1px solid rgba(247,195,79,0.2); }
  .s-badge-voided    { background: rgba(247,97,79,0.12);  color: var(--danger);  border: 1px solid rgba(247,97,79,0.2); }
  .s-badge-paid      { background: rgba(52,217,139,0.12); color: var(--success); border: 1px solid rgba(52,217,139,0.2); }
  .s-badge-partial   { background: rgba(247,195,79,0.12); color: var(--warning); border: 1px solid rgba(247,195,79,0.2); }
  .s-badge-unpaid    { background: rgba(247,97,79,0.12);  color: var(--danger);  border: 1px solid rgba(247,97,79,0.2); }
  .s-badge-overdue   { background: rgba(247,97,79,0.18);  color: var(--danger);  border: 1px solid rgba(247,97,79,0.3); }

  .inv-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }

  /* ── Detail grid ── */
  .detail-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
  .dg-field {
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
  }
  .dg-field:nth-child(even) { border-right: none; }
  .dg-field:nth-last-child(-n+2) { border-bottom: none; }
  .dg-label {
    font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-dim); margin-bottom: 5px;
    font-weight: 500;
  }
  .dg-value { font-size: 13px; font-weight: 500; }
  .dg-value.mono { font-family: var(--mono); }
  .dg-sub { font-family: var(--mono); font-size: 10.5px; color: var(--text-dim); margin-top: 2px; }

  /* ── Due date form ── */
  .due-date-form {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
  }
  .due-date-input {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 7px; padding: 6px 10px;
    color: var(--text); font-family: var(--mono); font-size: 12px;
    outline: none; color-scheme: dark;
    transition: border-color 0.15s;
  }
  .due-date-input:focus { border-color: var(--accent); }
  .due-date-input.overdue { border-color: rgba(247,97,79,0.5); color: var(--danger); }
  .due-save-btn {
    background: var(--accent-dim); border: 1px solid rgba(79,142,247,0.35);
    color: var(--accent); border-radius: 7px; padding: 6px 12px;
    font-size: 11px; font-family: var(--mono); cursor: pointer;
    transition: background 0.15s;
  }
  .due-save-btn:hover { background: rgba(79,142,247,0.2); }
  .due-readonly {
    font-family: var(--mono); font-size: 12px;
    color: var(--text-dim); padding: 6px 0;
  }

  /* ── Summary aside card ── */
  .sum-stat {
    display: flex; flex-direction: column;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
  }
  .sum-stat:last-child { border-bottom: none; }
  .sum-stat-label {
    font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-dim); margin-bottom: 5px;
  }
  .sum-stat-val {
    font-family: var(--mono); font-size: 22px; font-weight: 700;
    letter-spacing: -0.02em;
  }
  .sum-stat-sub { font-size: 11px; color: var(--text-dim); margin-top: 3px; }

  /* ── Line items table ── */
  .li-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  .li-table th {
    background: var(--bg);
    padding: 10px 14px;
    text-align: left; font-family: var(--mono);
    font-size: 9.5px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--text-dim);
    font-weight: 500; border-bottom: 1px solid var(--border);
  }
  .li-table td {
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .li-table tr:last-child td { border-bottom: none; }
  .li-table tr:hover td { background: rgba(79,142,247,0.02); }
  .li-product { font-weight: 500; font-size: 13px; }
  .li-sub { font-family: var(--mono); font-size: 10px; color: var(--text-dim); margin-top: 3px; }
  .li-type {
    font-family: var(--mono); font-size: 9.5px; font-weight: 600;
    padding: 2px 8px; border-radius: 4px; text-transform: uppercase;
    white-space: nowrap;
  }
  .type-paint   { background: rgba(247,195,79,0.12); color: var(--warning); }
  .type-product { background: rgba(79,142,247,0.1);  color: var(--accent); }
  .type-adhoc   { background: rgba(52,217,139,0.1);  color: var(--success); }
  .tr { text-align: right; }

  /* ── Payments card ── */
  .pmt-summary {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-bottom: 1px solid var(--border);
  }
  .pmt-cell {
    padding: 14px 18px;
    border-right: 1px solid var(--border);
  }
  .pmt-cell:last-child { border-right: none; }
  .pmt-cell-label {
    font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-dim); margin-bottom: 6px;
  }
  .pmt-cell-val {
    font-family: var(--mono); font-size: 17px; font-weight: 700;
  }
  .pmt-cell-sub { font-size: 10px; margin-top: 3px; color: var(--text-dim); }

  .pmt-row {
    display: grid;
    grid-template-columns: 1fr 100px 90px 110px 80px 80px 32px;
    align-items: center;
    padding: 10px 18px;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
    gap: 8px;
  }
  .pmt-head { background: var(--bg); }
  .pmt-head span {
    font-family: var(--mono); font-size: 9px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-dim);
  }
  .pmt-row:last-child { border-bottom: none; }
  .pmt-row:not(.pmt-head):hover { background: rgba(79,142,247,0.02); }
  .mode-badge {
    font-family: var(--mono); font-size: 9.5px; font-weight: 600;
    padding: 2px 8px; border-radius: 4px; text-transform: uppercase;
    background: var(--accent-dim); color: var(--accent);
  }

  /* ── Record payment form ── */
  .pmt-form-wrap {
    padding: 18px 20px;
    border-top: 2px solid var(--border);
    background: rgba(79,142,247,0.02);
  }
  .pmt-form-title {
    font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--text-dim);
    margin-bottom: 14px; font-weight: 600;
  }
  .pmt-form-row { display: flex; flex-wrap: wrap; gap: 12px; align-items: flex-end; }
  .pmt-form-field { display: flex; flex-direction: column; gap: 5px; }
  .pmt-form-label {
    font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--text-dim); font-weight: 500;
  }

  /* ── Referrer card ── */
  .ref-card { border-left: 3px solid var(--accent); }

  /* ── Flash cards ── */
  .flash-stock {
    background: rgba(52,217,139,0.05);
    border: 1px solid rgba(52,217,139,0.25);
    border-radius: 12px; padding: 16px 20px; margin-bottom: 20px;
  }
  .flash-void {
    background: rgba(247,97,79,0.05);
    border: 1px solid rgba(247,97,79,0.25);
    border-radius: 12px; padding: 16px 20px; margin-bottom: 20px;
  }
  .flash-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-top: 10px; }
  .flash-table th {
    text-align: left; padding: 4px 10px;
    font-family: var(--mono); font-size: 9px; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--text-dim);
  }
  .flash-table td { padding: 6px 10px; border-top: 1px solid var(--border); }

  @media (max-width: 900px) {
    .inv-layout { grid-template-columns: 1fr; }
    .detail-grid-2 { grid-template-columns: 1fr; }
    .dg-field { border-right: none; }
    .dg-field:nth-last-child(-n+2) { border-bottom: 1px solid var(--border); }
    .dg-field:last-child { border-bottom: none; }
    .pmt-summary { grid-template-columns: 1fr 1fr; }
    .pmt-cell:nth-child(2) { border-right: none; }
    .pmt-cell:nth-child(3) { grid-column: span 2; border-right: none; border-top: 1px solid var(--border); }
  }
</style>

<%# ── Stock deduction flash ── %>
<% if flash[:stock_lines].present? %>
  <div class="flash-stock">
    <div style="font-size:13px;font-weight:600;color:var(--success)">&#10003; Invoice confirmed — stock deducted</div>
    <table class="flash-table">
      <thead><tr>
        <th>Product</th><th style="text-align:right">Before</th>
        <th style="text-align:right">Deducted</th><th style="text-align:right">After</th>
      </tr></thead>
      <tbody>
        <% flash[:stock_lines].each do |line| %>
          <tr>
            <td style="font-weight:500"><%= line[:product] %></td>
            <td style="text-align:right;font-family:var(--mono)"><%= line[:before] %></td>
            <td style="text-align:right;font-family:var(--mono);color:var(--danger)">− <%= line[:deducted] %></td>
            <td style="text-align:right;font-family:var(--mono);font-weight:700;
                       color:<%= line[:after].to_f < 0 ? 'var(--danger)' : line[:after].to_f < 5 ? 'var(--warning)' : 'var(--success)' %>">
              <%= line[:after] %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%# ── Void reversal flash ── %>
<% if flash[:reversed_lines].present? %>
  <div class="flash-void">
    <div style="font-size:13px;font-weight:600;color:var(--danger)">&#10005; Invoice voided — stock restored</div>
    <table class="flash-table">
      <thead><tr>
        <th>Product</th><th style="text-align:right">Before</th>
        <th style="text-align:right">Restored</th><th style="text-align:right">After</th>
      </tr></thead>
      <tbody>
        <% flash[:reversed_lines].each do |line| %>
          <tr>
            <td style="font-weight:500"><%= line[:product] %></td>
            <td style="text-align:right;font-family:var(--mono)"><%= line[:before] %></td>
            <td style="text-align:right;font-family:var(--mono);color:var(--success)">+ <%= line[:restored] %></td>
            <td style="text-align:right;font-family:var(--mono);font-weight:700;color:var(--success)"><%= line[:after] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%# ── Status Strip ── %>
<div class="inv-status-strip <%= @invoice.voided? ? 'strip-voided' : overdue ? 'strip-overdue' : @invoice.confirmed? ? 'strip-confirmed' : 'strip-draft' %>"
     style="margin-bottom:20px">
  <div>
    <div class="inv-number"><%= @invoice.display_number %></div>
    <div class="inv-number-sub">
      <%= @invoice.invoice_date&.strftime('%d %b %Y') || '—' %>
      &nbsp;·&nbsp; <%= @invoice.customer&.name || 'Walk-in' %>
    </div>
  </div>
  <div class="status-badges">
    <% if @invoice.voided? %>
      <span class="s-badge s-badge-voided">Voided</span>
      <span style="font-family:var(--mono);font-size:10px;color:var(--text-dim)">
        <%= @invoice.voided_at&.strftime('%d %b %Y, %H:%M') %>
      </span>
    <% elsif @invoice.confirmed? %>
      <span class="s-badge s-badge-confirmed">Confirmed</span>
      <span class="s-badge s-badge-<%= ps %>"><%= ps.upcase %></span>
      <% if overdue %><span class="s-badge s-badge-overdue">Overdue</span><% end %>
    <% else %>
      <span class="s-badge s-badge-draft">Draft</span>
    <% end %>
  </div>
  <div class="inv-actions">
    <%= link_to sales_sales_invoice_path(@invoice, format: :pdf), class: 'btn btn-secondary btn-sm', target: '_blank' do %>
      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
      PDF
    <% end %>
    <% if @invoice.draft? %>
      <%= link_to '← Edit', edit_sales_sales_invoice_path(@invoice), class: 'btn btn-secondary btn-sm' %>
      <%= link_to 'Review &amp; Confirm →', preview_sales_sales_invoice_path(@invoice), class: 'btn btn-primary btn-sm' %>
    <% end %>
    <% if @invoice.confirmed? && !is_paid %>
      <%= button_to 'Mark as Paid',
            mark_as_paid_sales_sales_invoice_path(@invoice),
            method: :post,
            data: { confirm: "Record full payment of ₹#{@invoice.outstanding_amount} as cash?" },
            class: 'btn btn-primary btn-sm' %>
    <% end %>
    <% if @invoice.confirmed? && !@invoice.fully_paid? %>
      <%= button_to 'Void',
            void_sales_sales_invoice_path(@invoice),
            method: :post,
            data: { confirm: "Void this invoice? Stock deductions will be reversed." },
            style: "background:none;border:1px solid var(--danger);color:var(--danger);
                    padding:6px 12px;border-radius:7px;font-size:12px;cursor:pointer;
                    font-family:var(--sans);font-weight:500" %>
    <% end %>
  </div>
</div>

<%# ── Two-column layout ── %>
<div class="inv-layout">

  <%# ══════ MAIN COLUMN ══════ %>
  <div class="inv-main">

    <%# ── Invoice Details card ── %>
    <div class="inv-card">
      <div class="inv-card-head">
        <span class="inv-card-label">Invoice Details</span>
      </div>
      <div class="detail-grid-2">
        <div class="dg-field">
          <div class="dg-label">Customer</div>
          <div class="dg-value"><%= @invoice.customer&.name || 'Walk-in' %></div>
          <% if @invoice.customer&.phone.present? %>
            <div class="dg-sub"><%= @invoice.customer.phone %></div>
          <% end %>
        </div>
        <div class="dg-field">
          <div class="dg-label">Invoice Number</div>
          <div class="dg-value mono"><%= @invoice.invoice_number.presence || '—' %></div>
        </div>
        <div class="dg-field">
          <div class="dg-label">Invoice Date</div>
          <div class="dg-value mono"><%= @invoice.invoice_date&.strftime('%d %b %Y') || '—' %></div>
        </div>
        <div class="dg-field">
          <div class="dg-label">Payment Mode</div>
          <div class="dg-value"><%= @invoice.payment_mode&.titleize || '—' %></div>
        </div>
        <div class="dg-field">
          <div class="dg-label">Entered By</div>
          <div class="dg-value"><%= @invoice.user&.full_name %></div>
        </div>
        <% if @invoice.confirmed? %>
          <div class="dg-field">
            <div class="dg-label">Confirmed At</div>
            <div class="dg-value mono" style="font-size:12px">
              <%= @invoice.confirmed_at&.strftime('%d %b %Y, %H:%M') || '—' %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Referrer card (only when set) ── %>
    <% if @invoice.referrer %>
      <div class="inv-card ref-card">
        <div class="inv-card-head">
          <span class="inv-card-label" style="color:var(--accent)">Referred By</span>
        </div>
        <div class="detail-grid-2">
          <div class="dg-field">
            <div class="dg-label">Name</div>
            <div class="dg-value">
              <%= link_to @invoice.referrer.name, sales_referrer_path(@invoice.referrer),
                    style: "color:var(--accent);font-weight:600" %>
            </div>
          </div>
          <div class="dg-field">
            <div class="dg-label">Trade</div>
            <div class="dg-value"><%= @invoice.referrer.display_trade %></div>
          </div>
          <div class="dg-field">
            <div class="dg-label">Mobile</div>
            <div class="dg-value mono"><%= @invoice.referrer.phone.presence || '—' %></div>
          </div>
          <div class="dg-field">
            <div class="dg-label">Area</div>
            <div class="dg-value"><%= @invoice.referrer.area.presence || '—' %></div>
          </div>
        </div>
      </div>
    <% end %>

    <%# ── Line Items ── %>
    <div class="inv-card">
      <div class="inv-card-head">
        <span class="inv-card-label">Line Items</span>
        <span style="font-family:var(--mono);font-size:10px;color:var(--text-dim)">
          <%= @invoice.sales_invoice_items.size %> item<%= @invoice.sales_invoice_items.size == 1 ? '' : 's' %>
        </span>
      </div>
      <table class="li-table">
        <thead>
          <tr>
            <th>Product / Description</th>
            <th>Type</th>
            <th>UOM</th>
            <th class="tr">Qty</th>
            <th class="tr">Rate (&#8377;)</th>
            <th class="tr">Taxable</th>
            <th class="tr">GST</th>
            <th class="tr">Total (&#8377;)</th>
          </tr>
        </thead>
        <tbody>
          <% @invoice.sales_invoice_items.each do |item| %>
            <tr>
              <td>
                <% if item.paint? %>
                  <div class="li-product"><%= item.shade_display %></div>
                  <% paint_sub = [item.metadata['colour_family'].presence,
                                  item.base_product.present? ? "Base: #{item.base_product.display_name}" : nil
                                 ].compact.join(' · ') %>
                  <% if paint_sub.present? %>
                    <div class="li-sub"><%= paint_sub %></div>
                  <% end %>
                <% elsif item.adhoc? %>
                  <div class="li-product"><%= item.description.presence || 'Ad-hoc charge' %></div>
                <% else %>
                  <div class="li-product"><%= item.product&.display_name || '—' %></div>
                  <% if item.product&.material_code.present? %>
                    <div class="li-sub"><%= item.product.material_code %></div>
                  <% end %>
                <% end %>
              </td>
              <td>
                <span class="li-type <%= item.paint? ? 'type-paint' : item.adhoc? ? 'type-adhoc' : 'type-product' %>">
                  <%= item.line_type.upcase %>
                </span>
              </td>
              <td style="font-family:var(--mono);font-size:11px;color:var(--text-dim)">
                <%= item.product&.base_uom&.short_name || '—' %>
              </td>
              <td class="tr" style="font-family:var(--mono)">
                <%= number_with_precision(item.quantity, precision: 3, strip_insignificant_zeros: true) %>
              </td>
              <td class="tr" style="font-family:var(--mono)">
                <%= number_with_precision(item.unit_rate, precision: 2) %>
              </td>
              <td class="tr" style="font-family:var(--mono)">
                <%= number_with_precision(item.taxable_amount, precision: 2) %>
              </td>
              <td class="tr" style="font-family:var(--mono);font-size:11px;color:var(--text-dim)">
                <% igst = item.metadata['igst_percent'].to_f %>
                <% gst  = item.cgst_percent.to_f + item.sgst_percent.to_f %>
                <%= igst > 0 ? "#{igst.to_i}%" : gst > 0 ? "#{gst.to_i}%" : '—' %>
              </td>
              <td class="tr" style="font-family:var(--mono);font-weight:600;color:var(--accent)">
                <%= number_with_precision(item.total_amount, precision: 2) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# ── Payments card (confirmed invoices only) ── %>
    <% if @invoice.confirmed? %>
      <div class="inv-card">
        <div class="inv-card-head">
          <span class="inv-card-label">Payments</span>
          <span class="s-badge s-badge-<%= ps %>" style="font-size:9.5px;padding:3px 10px"><%= ps.upcase %></span>
        </div>

        <div class="pmt-summary">
          <div class="pmt-cell">
            <div class="pmt-cell-label">Invoice Total</div>
            <div class="pmt-cell-val" style="color:var(--text)">
              &#8377; <%= number_with_delimiter(@invoice.computed_grand_total.round(2)) %>
            </div>
          </div>
          <div class="pmt-cell">
            <div class="pmt-cell-label">Collected</div>
            <div class="pmt-cell-val" style="color:var(--success)">
              &#8377; <%= number_with_delimiter(@invoice.total_paid) %>
            </div>
          </div>
          <div class="pmt-cell">
            <div class="pmt-cell-label">Outstanding</div>
            <div class="pmt-cell-val" style="color:<%= is_paid ? 'var(--success)' : 'var(--danger)' %>">
              &#8377; <%= number_with_delimiter(@invoice.outstanding_amount) %>
            </div>
            <% if !is_paid && @invoice.payment_due_date.present? %>
              <div class="pmt-cell-sub" style="color:<%= overdue ? 'var(--danger)' : 'var(--text-dim)' %>">
                Due <%= @invoice.payment_due_date.strftime('%d %b %Y') %>
                <%= overdue ? ' · OVERDUE' : '' %>
              </div>
            <% end %>
          </div>
        </div>

        <% if @invoice.sale_payments.any? %>
          <div class="pmt-row pmt-head">
            <span>Receipt</span><span>Date</span><span>Mode</span>
            <span>Ref #</span><span style="text-align:right">Amount</span>
            <span style="text-align:center">Receipt</span><span></span>
          </div>
          <% @invoice.sale_payments.recent.each do |pmt| %>
            <div class="pmt-row">
              <div style="font-family:var(--mono);font-size:11.5px;font-weight:600"><%= pmt.receipt_label %></div>
              <div style="font-family:var(--mono);font-size:11px;color:var(--text-dim)">
                <%= pmt.payment_date.strftime('%d %b %Y') %>
              </div>
              <div><span class="mode-badge"><%= pmt.payment_mode.upcase %></span></div>
              <div style="font-family:var(--mono);font-size:11px;color:var(--text-dim)">
                <%= pmt.reference_number.presence || '—' %>
              </div>
              <div style="font-family:var(--mono);font-size:13px;font-weight:600;
                          color:var(--success);text-align:right">
                &#8377; <%= number_with_delimiter(pmt.amount) %>
              </div>
              <div style="text-align:center">
                <%= link_to sales_sales_invoice_sale_payment_path(@invoice, pmt, format: :pdf),
                      target: '_blank',
                      style: "font-family:var(--mono);font-size:10px;color:var(--accent);
                              text-decoration:none;padding:3px 9px;
                              border:1px solid var(--accent-dim);border-radius:4px" do %>
                  &#11015; PDF
                <% end %>
              </div>
              <% unless is_paid %>
              <div>
                <button type="button"
                        onclick="confirmDeletePayment('<%= sales_sales_invoice_sale_payment_path(@invoice, pmt) %>', '<%= j pmt.receipt_label %>', '&#8377;&nbsp;<%= number_with_delimiter(pmt.amount) %>')"
                        style="background:none;border:none;color:var(--danger);
                               cursor:pointer;font-size:13px;padding:2px 5px;
                               border-radius:4px;line-height:1">&#10005;</button>
              </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div style="padding:20px 20px;color:var(--text-dim);font-size:13px">
            No payments recorded yet.
          </div>
        <% end %>

        <% unless is_paid || @invoice.voided? %>
          <div class="pmt-form-wrap">
            <div class="pmt-form-title">Record Payment</div>
            <%= form_with model: SalePayment.new,
                  url: sales_sales_invoice_sale_payments_path(@invoice),
                  local: true do |f| %>
              <div class="pmt-form-row">
                <div class="pmt-form-field">
                  <label class="pmt-form-label">Date</label>
                  <%= f.date_field :payment_date, value: Date.today, class: 'form-control', style: 'width:140px' %>
                </div>
                <div class="pmt-form-field">
                  <label class="pmt-form-label">
                    Amount (&#8377;)
                    <span style="font-weight:400;text-transform:none;letter-spacing:0;color:var(--text-dim)">
                      — due: &#8377;<%= number_with_delimiter(@invoice.outstanding_amount) %>
                    </span>
                  </label>
                  <%= f.number_field :amount, placeholder: @invoice.outstanding_amount,
                        step: '0.01', min: '0.01', class: 'form-control', style: 'width:140px' %>
                </div>
                <div class="pmt-form-field">
                  <label class="pmt-form-label">Mode</label>
                  <%= f.select :payment_mode,
                        SalePayment::PAYMENT_MODES.map { |m| [m.titleize, m] },
                        {}, class: 'form-control', style: 'width:140px' %>
                </div>
                <div class="pmt-form-field">
                  <label class="pmt-form-label">Ref # <span style="font-weight:400">(optional)</span></label>
                  <%= f.text_field :reference_number, placeholder: 'Cheque no. / UTR',
                        class: 'form-control', style: 'width:150px' %>
                </div>
                <div class="pmt-form-field" style="flex:1;min-width:140px">
                  <label class="pmt-form-label">Notes <span style="font-weight:400">(optional)</span></label>
                  <%= f.text_field :notes, placeholder: 'e.g. advance',
                        class: 'form-control' %>
                </div>
                <div style="padding-bottom:1px">
                  <%= f.submit 'Add Payment', class: 'btn btn-primary', style: 'height:38px;white-space:nowrap' %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>

      </div>
    <% end %>

  </div><%# /inv-main %>

  <%# ══════ ASIDE COLUMN ══════ %>
  <div class="inv-aside">

    <%# ── Totals card ── %>
    <div class="inv-card">
      <div class="inv-card-head">
        <span class="inv-card-label">Totals</span>
      </div>
      <div class="sum-stat">
        <div class="sum-stat-label">Taxable Amount</div>
        <div class="sum-stat-val" style="font-size:16px;color:var(--text)">
          &#8377; <%= number_with_delimiter(@invoice.computed_taxable_total.round(2)) %>
        </div>
      </div>
      <div class="sum-stat">
        <div class="sum-stat-label">Tax (GST)</div>
        <div class="sum-stat-val" style="font-size:16px;color:var(--text-dim)">
          &#8377; <%= number_with_delimiter(@invoice.computed_tax_total.round(2)) %>
        </div>
      </div>
      <% total_disc = @invoice.computed_discount_total %>
      <% if total_disc > 0 %>
        <div class="sum-stat">
          <div class="sum-stat-label">Discount</div>
          <div class="sum-stat-val" style="font-size:16px;color:var(--warning)">
            − &#8377; <%= number_with_delimiter(total_disc) %>
          </div>
        </div>
      <% end %>
      <div class="sum-stat" style="border-bottom:none">
        <div class="sum-stat-label">Grand Total</div>
        <div class="sum-stat-val" style="color:var(--accent)">
          &#8377; <%= number_with_delimiter(@invoice.computed_grand_total.round(2)) %>
        </div>
      </div>
    </div>

    <%# ── Due Date card (non-voided invoices) ── %>
    <% unless @invoice.voided? %>
      <div class="inv-card">
        <div class="inv-card-head">
          <span class="inv-card-label">Payment Due Date</span>
          <% if overdue && !is_paid %>
            <span class="s-badge s-badge-overdue" style="font-size:9px;padding:2px 8px">Overdue</span>
          <% end %>
        </div>
        <div style="padding:16px 20px">
          <% if can_edit_due %>
            <%# Editable — invoice is not void and not fully paid %>
            <%= form_with url: update_due_date_sales_sales_invoice_path(@invoice),
                  method: :patch, local: true do |f| %>
              <div class="due-date-form">
                <%= f.date_field :payment_due_date,
                      value: @invoice.payment_due_date,
                      name: 'sales_invoice[payment_due_date]',
                      class: "due-date-input#{overdue ? ' overdue' : ''}" %>
                <button type="submit" class="due-save-btn">Save</button>
              </div>
            <% end %>
            <div style="font-size:11px;color:var(--text-dim);margin-top:8px;line-height:1.5">
              Sets a reminder for credit collection. Leave blank for cash sales.
            </div>
            <% if @invoice.payment_due_date.present? && !overdue && !is_paid %>
              <% days_left = (@invoice.payment_due_date - Date.today).to_i %>
              <% if days_left >= 0 %>
                <div style="margin-top:8px;font-family:var(--mono);font-size:11px;
                            color:<%= days_left <= 3 ? 'var(--warning)' : 'var(--success)' %>">
                  <%= days_left == 0 ? 'Due today' : "#{days_left} day#{'s' if days_left != 1} remaining" %>
                </div>
              <% end %>
            <% end %>
          <% else %>
            <%# Read-only — fully paid or voided %>
            <div class="due-readonly">
              <%= @invoice.payment_due_date&.strftime('%d %b %Y') || '—' %>
            </div>
            <% if is_paid %>
              <div style="font-size:11px;color:var(--success);margin-top:6px">
                &#10003; Fully paid — due date is locked
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  </div><%# /inv-aside %>

</div><%# /inv-layout %>

<%# ── Delete Payment Confirmation Modal ── %>
<div id="del-pmt-modal"
     style="display:none;position:fixed;inset:0;z-index:1000;
            background:rgba(0,0,0,0.45);align-items:center;justify-content:center">
  <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;
              padding:28px 28px 22px;width:360px;max-width:90vw;box-shadow:0 8px 32px rgba(0,0,0,0.18)">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px">
      <span style="font-size:22px;color:var(--danger)">&#9888;</span>
      <span style="font-size:15px;font-weight:700;color:var(--text)">Delete Payment</span>
    </div>
    <p style="font-size:13px;color:var(--text-dim);margin:0 0 6px">
      Are you sure you want to delete payment
    </p>
    <p style="font-size:13px;font-weight:600;color:var(--text);font-family:var(--mono);margin:0 0 4px"
       id="del-pmt-label"></p>
    <p style="font-size:13px;color:var(--danger);font-family:var(--mono);margin:0 0 20px"
       id="del-pmt-amount"></p>
    <p style="font-size:12px;color:var(--text-dim);margin:0 0 20px">
      This cannot be undone and the amount will be removed from the payment history.
    </p>
    <div style="display:flex;gap:10px;justify-content:flex-end">
      <button type="button" onclick="closeDeletePaymentModal()"
              style="padding:8px 18px;border:1px solid var(--border);border-radius:7px;
                     background:var(--bg);color:var(--text);font-size:13px;cursor:pointer;
                     font-family:var(--sans)">Cancel</button>
      <form id="del-pmt-form" method="post" style="margin:0">
        <input type="hidden" name="_method" value="delete">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit"
                style="padding:8px 18px;border:none;border-radius:7px;
                       background:var(--danger);color:#fff;font-size:13px;
                       font-weight:600;cursor:pointer;font-family:var(--sans)">
          Delete
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  function confirmDeletePayment(url, label, amount) {
    document.getElementById('del-pmt-label').textContent  = label;
    document.getElementById('del-pmt-amount').innerHTML   = amount;
    document.getElementById('del-pmt-form').action        = url;
    var modal = document.getElementById('del-pmt-modal');
    modal.style.display = 'flex';
  }
  function closeDeletePaymentModal() {
    document.getElementById('del-pmt-modal').style.display = 'none';
  }
  document.getElementById('del-pmt-modal').addEventListener('click', function(e) {
    if (e.target === this) closeDeletePaymentModal();
  });
</script>

<%# ── Post-confirm tinting prompt ── %>
<% if flash[:tinting_prompt] %>
<%
  _tinting_brand_id = flash[:tinting_brand_id]
  _tinting_action   = flash[:tinting_action].to_s.presence || 'new_tab'
  _tinting_url      = _tinting_brand_id.present? ?
                        inventory_tinting_machine_brand_path(brand_id: _tinting_brand_id, modal: 1) :
                        inventory_tinting_machine_path(modal: 1)
%>
<div id="tint-prompt"
     style="position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:800;
            display:flex;align-items:center;justify-content:center">
  <div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;
              padding:32px 36px;max-width:440px;width:100%;
              box-shadow:0 24px 60px rgba(0,0,0,0.5);text-align:center">
    <div style="font-size:36px;margin-bottom:12px">🎨</div>
    <div style="font-size:17px;font-weight:700;color:var(--text);margin-bottom:8px">
      Update Tinting Machine?
    </div>
    <div style="font-size:13px;color:var(--text-dim);margin-bottom:24px;line-height:1.6">
      You've sold enough base paint since the last tinting update.<br>
      Would you like to check or update the tinting machine levels now?
    </div>
    <div style="display:flex;gap:10px">
      <button onclick="openTinting()"
              style="flex:1;background:var(--accent);color:#fff;border:none;border-radius:9px;
                     padding:12px 20px;font-size:14px;font-weight:700;cursor:pointer">
        Yes, Update Now
      </button>
      <button onclick="dismissTintPrompt('skip')"
              style="flex:1;background:transparent;color:var(--text-dim);
                     border:1.5px solid var(--border);border-radius:9px;
                     padding:12px 20px;font-size:14px;cursor:pointer">
        Skip
      </button>
    </div>
    <button onclick="dismissTintPrompt('remind')"
            style="margin-top:12px;background:transparent;border:none;color:var(--text-dim);
                   font-size:12px;cursor:pointer;text-decoration:underline">
      Remind me next time
    </button>
  </div>
</div>

<script>
  function openTinting() {
    document.getElementById('tint-prompt').style.display = 'none';
    var url = '<%= j _tinting_url %>';
    <% if _tinting_action == 'popup_window' %>
      window.open(url, 'TintingMachine',
        'width=1280,height=820,resizable=yes,scrollbars=yes,toolbar=no,menubar=no,location=no');
    <% else %>
      window.open(url, '_blank');
    <% end %>
  }

  function dismissTintPrompt(type) {
    document.getElementById('tint-prompt').style.display = 'none';
    fetch('<%= tinting_snooze_sales_sales_invoices_path %>', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: JSON.stringify({ snooze_type: type })
    });
  }
</script>
<% end %>
