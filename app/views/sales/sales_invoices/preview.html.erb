<%# app/views/sales/sales_invoices/preview.html.erb %>
<% content_for :title, "Review — #{@invoice.display_number}" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Sales</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Invoices', sales_sales_invoices_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Preview</span>
<% end %>

<style>
  .pv-wrap { max-width: 860px; margin: 0 auto; }
  .pv-banner {
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border: 2px solid #f59e0b;
    border-radius: 12px;
    padding: 18px 24px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .pv-banner-icon { font-size: 28px; }
  .pv-banner-text { flex: 1; }
  .pv-banner-title { font-size: 15px; font-weight: 700; color: #92400e; }
  .pv-banner-sub   { font-size: 13px; color: #b45309; margin-top: 3px; }
  .pv-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 20px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }
  .pv-card-header {
    padding: 14px 24px;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #64748b;
  }
  .pv-info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    padding: 0;
  }
  .pv-info-cell {
    padding: 16px 24px;
    border-right: 1px solid #f1f5f9;
  }
  .pv-info-cell:last-child { border-right: none; }
  .pv-info-label { font-size: 11px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 5px; }
  .pv-info-val   { font-size: 14px; font-weight: 500; color: #1e293b; }
  .pv-info-sub   { font-size: 12px; color: #64748b; margin-top: 2px; font-family: monospace; }

  /* Items table */
  .pv-table { width: 100%; border-collapse: collapse; }
  .pv-table th {
    background: #f8fafc;
    padding: 10px 20px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #94a3b8;
    border-bottom: 1px solid #e2e8f0;
  }
  .pv-table td {
    padding: 14px 20px;
    font-size: 13.5px;
    color: #1e293b;
    border-bottom: 1px solid #f8fafc;
    vertical-align: middle;
  }
  .pv-table tr:last-child td { border-bottom: none; }
  .pv-table tr:hover td { background: #fafbff; }
  .mono { font-family: monospace; }
  .right { text-align: right; }
  .center { text-align: center; }

  .pv-type-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 5px;
    text-transform: uppercase;
  }
  .badge-product { background: #eff6ff; color: #2563eb; }
  .badge-paint   { background: #fffbeb; color: #d97706; }
  .badge-adhoc   { background: #f0fdf4; color: #16a34a; }

  /* Totals */
  .pv-totals {
    padding: 20px 24px;
    border-top: 1px solid #e2e8f0;
    background: #f8fafc;
  }
  .pv-totals-grid {
    display: flex;
    justify-content: flex-end;
    gap: 28px;
  }
  .pv-total-col { text-align: right; }
  .pv-total-label { font-size: 11px; font-weight: 600; color: #94a3b8; text-transform: uppercase; margin-bottom: 4px; }
  .pv-total-val   { font-size: 18px; font-weight: 600; color: #334155; font-family: monospace; }
  .pv-total-val.grand { font-size: 26px; font-weight: 800; color: #2563eb; }

  /* Actions */
  .pv-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 20px 0;
  }
  .pv-confirm-btn {
    background: #16a34a;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 13px 32px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pv-confirm-btn:hover { background: #15803d; }
  .pv-edit-btn {
    background: #fff;
    color: #475569;
    border: 1.5px solid #cbd5e1;
    border-radius: 8px;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: all 0.15s;
  }
  .pv-edit-btn:hover { background: #f1f5f9; }
  .pv-warn {
    font-size: 12px;
    color: #92400e;
    background: #fef3c7;
    border: 1px solid #fde68a;
    border-radius: 7px;
    padding: 8px 14px;
  }
</style>

<div class="pv-wrap">
  <div class="pv-banner">
    <div class="pv-banner-icon">👀</div>
    <div class="pv-banner-text">
      <div class="pv-banner-title">Review before confirming</div>
      <div class="pv-banner-sub">Once confirmed, stock will be deducted and the invoice cannot be edited.</div>
    </div>
  </div>

  <%# Header info %>
  <div class="pv-card">
    <div class="pv-card-header">Invoice Information</div>
    <div class="pv-info-grid">
      <div class="pv-info-cell">
        <div class="pv-info-label">Customer</div>
        <div class="pv-info-val"><%= @invoice.customer&.name || 'Walk-in' %></div>
        <% if @invoice.customer&.phone.present? %>
          <div class="pv-info-sub"><%= @invoice.customer.phone %></div>
        <% end %>
      </div>
      <div class="pv-info-cell">
        <div class="pv-info-label">Invoice Number</div>
        <div class="pv-info-val mono"><%= @invoice.invoice_number.presence || '— auto on confirm' %></div>
      </div>
      <div class="pv-info-cell">
        <div class="pv-info-label">Invoice Date</div>
        <div class="pv-info-val"><%= @invoice.invoice_date&.strftime('%d %b %Y') || '—' %></div>
      </div>
      <div class="pv-info-cell">
        <div class="pv-info-label">Payment Mode</div>
        <div class="pv-info-val"><%= @invoice.payment_mode&.titleize || '—' %></div>
      </div>
      <div class="pv-info-cell">
        <div class="pv-info-label">Reverse Charge</div>
        <div class="pv-info-val" style="color:<%= @invoice.reverse_charge? ? '#dc2626' : '#16a34a' %>">
          <%= @invoice.reverse_charge? ? 'Yes — RCM' : 'No' %>
        </div>
      </div>
      <div class="pv-info-cell">
        <div class="pv-info-label">Entered By</div>
        <div class="pv-info-val"><%= @invoice.user&.full_name %></div>
      </div>
    </div>
  </div>

  <%# Line items %>
  <div class="pv-card">
    <div class="pv-card-header">Line Items — <%= @invoice.sales_invoice_items.size %> item(s)</div>
    <table class="pv-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Item</th>
          <th class="center">Type</th>
          <th class="right">Qty</th>
          <th class="right">Rate (₹)</th>
          <th class="right">Taxable (₹)</th>
          <th class="center">GST</th>
          <th class="right">Total (₹)</th>
        </tr>
      </thead>
      <tbody>
        <% @invoice.sales_invoice_items.each_with_index do |item, i| %>
          <tr>
            <td class="mono" style="color:#94a3b8"><%= i + 1 %></td>
            <td>
              <div style="font-weight:600"><%= item.line_display %></div>
              <% if item.paint? && item.base_product.present? %>
                <div style="font-size:11.5px;color:#64748b;margin-top:2px">
                  Base: <%= item.base_product.display_name %>
                </div>
              <% end %>
              <% if item.product? && item.product&.material_code.present? %>
                <div style="font-size:11.5px;color:#94a3b8;font-family:monospace;margin-top:2px">
                  <%= item.product.material_code %>
                </div>
              <% end %>
            </td>
            <td class="center">
              <span class="pv-type-badge badge-<%= item.line_type %>"><%= item.line_type %></span>
            </td>
            <td class="right mono"><%= item.quantity.to_f %></td>
            <td class="right mono"><%= number_with_precision(item.unit_rate, precision: 2) %></td>
            <td class="right mono"><%= number_with_precision(item.taxable_amount, precision: 2) %></td>
            <td class="center" style="font-size:12px;color:#64748b">
              <% if item.gst_percent > 0 %>
                C:<%= item.cgst_percent %>% + S:<%= item.sgst_percent %>%
              <% else %>—<% end %>
            </td>
            <td class="right mono" style="font-weight:700;color:#1e293b">
              ₹ <%= number_with_precision(item.total_amount, precision: 2) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div class="pv-totals">
      <% if @invoice.overall_discount_amount.to_f > 0 %>
        <div style="text-align:right;margin-bottom:10px;font-size:13px;color:#92400e">
          Overall Discount: − ₹<%= number_with_precision(@invoice.overall_discount_amount, precision: 2) %>
        </div>
      <% end %>
      <div class="pv-totals-grid">
        <div class="pv-total-col">
          <div class="pv-total-label">Taxable (₹)</div>
          <div class="pv-total-val"><%= number_with_precision(@invoice.computed_taxable_total, precision: 2, delimiter: ',') %></div>
        </div>
        <div class="pv-total-col">
          <div class="pv-total-label">Tax (₹)</div>
          <div class="pv-total-val"><%= number_with_precision(@invoice.computed_tax_total, precision: 2, delimiter: ',') %></div>
        </div>
        <div class="pv-total-col">
          <div class="pv-total-label">Grand Total (₹)</div>
          <div class="pv-total-val grand">₹ <%= number_with_precision(@invoice.computed_grand_total, precision: 2, delimiter: ',') %></div>
        </div>
      </div>
    </div>
  </div>

  <%# Stock impact preview %>
  <% items_with_stock = @invoice.sales_invoice_items.select { |i| i.product? || i.paint? } %>
  <% if items_with_stock.any? %>
    <div class="pv-card">
      <div class="pv-card-header">Stock Impact — will be deducted on confirm</div>
      <table class="pv-table">
        <thead>
          <tr>
            <th>Product</th>
            <th class="right">Current Stock</th>
            <th class="right">Deduct</th>
            <th class="right">Stock After</th>
            <th class="center">Status</th>
          </tr>
        </thead>
        <tbody>
          <% items_with_stock.each do |item| %>
            <% deduct_product = item.paint? ? item.base_product : item.product %>
            <% next if deduct_product.nil? %>
            <% level = StockLevel.find_by(organisation: @invoice.organisation, product: deduct_product) %>
            <% current = level&.quantity.to_f %>
            <% deduct  = item.quantity.to_f %>
            <% after   = (current - deduct).round(3) %>
            <tr>
              <td>
                <div style="font-weight:500"><%= deduct_product.display_name %></div>
                <% if item.paint? %>
                  <div style="font-size:11.5px;color:#d97706;margin-top:2px">for shade: <%= item.shade_display %></div>
                <% end %>
              </td>
              <td class="right mono"><%= number_with_precision(current, precision: 3, strip_insignificant_zeros: true) %></td>
              <td class="right mono" style="color:#ef4444">− <%= number_with_precision(deduct, precision: 3, strip_insignificant_zeros: true) %></td>
              <td class="right mono" style="font-weight:700;color:<%= after < 0 ? '#ef4444' : after < 5 ? '#f59e0b' : '#16a34a' %>">
                <%= number_with_precision(after, precision: 3, strip_insignificant_zeros: true) %>
              </td>
              <td class="center">
                <% if after < 0 %>
                  <span style="font-size:11px;font-weight:700;color:#ef4444;background:#fef2f2;padding:3px 9px;border-radius:5px">⚠ OVER</span>
                <% elsif after < 5 %>
                  <span style="font-size:11px;font-weight:700;color:#d97706;background:#fffbeb;padding:3px 9px;border-radius:5px">Low</span>
                <% else %>
                  <span style="font-size:11px;font-weight:600;color:#16a34a;background:#f0fdf4;padding:3px 9px;border-radius:5px">OK</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <%# Action buttons %>
  <div class="pv-actions">
    <%= button_to confirm_sales_sales_invoice_path(@invoice), method: :post,
          class: 'pv-confirm-btn',
          data: { turbo_confirm: 'Confirm and deduct stock? This cannot be undone.' } do %>
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
      Confirm &amp; Deduct Stock
    <% end %>
    <%= link_to edit_sales_sales_invoice_path(@invoice), class: 'pv-edit-btn' do %>
      ← Edit Invoice
    <% end %>
    <div class="pv-warn">
      ⚠ Stock will be deducted immediately on confirm. Invoices cannot be edited after confirmation.
    </div>
  </div>
</div>
