<% content_for :title, "Edit #{@referrer.name}" %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Sales</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Referrers', sales_referrers_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <%= link_to @referrer.name, sales_referrer_path(@referrer), style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current">Edit</span>
<% end %>

<div class="page-header">
  <div>
    <div class="page-title">Edit Referrer</div>
    <div class="page-subtitle"><%= @referrer.name %></div>
  </div>
</div>

<div class="form-card">
  <%= form_with model: [:sales, @referrer], local: true do |f| %>
    <%= render 'form', referrer: @referrer, f: f %>
    <div class="form-actions">
      <%= f.submit 'Save Changes', class: 'btn btn-primary' %>
      <%= link_to 'Cancel', sales_referrer_path(@referrer), class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
