<% content_for :title, "Dashboard" %>
<% content_for :breadcrumb do %>
  <span class="breadcrumb-current">Dashboard</span>
<% end %>

<script src="https://cdnjs.cloudflare.com/ajax/libs/echarts/5.4.3/echarts.min.js"></script>

<style>
  /* ── WELCOME BAR ── */
  .welcome-bar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 28px; padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .welcome-greeting { font-size: 21px; font-weight: 600; letter-spacing: -0.02em; }
  .welcome-greeting span { color: var(--accent); }
  .welcome-meta {
    font-size: 12px; color: var(--text-dim); margin-top: 5px;
    display: flex; align-items: center; gap: 10px;
  }

  /* ── LAYOUT GRID ── */
  .dash-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 20px;
    align-items: start;
  }
  .dash-main { display: flex; flex-direction: column; gap: 20px; }
  .dash-side  { display: flex; flex-direction: column; gap: 20px; }

  /* ── SHARED CARD ── */
  .d-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }
  .d-card-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 20px 0;
  }
  .d-card-title {
    font-size: 13px; font-weight: 600; letter-spacing: -0.01em;
    display: flex; align-items: center; gap: 8px;
  }
  .d-card-title .icon {
    width: 28px; height: 28px; border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .icon-blue   { background: rgba(79,142,247,0.12); color: var(--accent); }
  .icon-teal   { background: rgba(52,217,139,0.12); color: var(--success); }
  .icon-amber  { background: rgba(245,158,11,0.12);  color: var(--warning); }
  .icon-red    { background: rgba(247,97,79,0.12);   color: var(--danger); }
  .icon-purple { background: rgba(155,124,247,0.12); color: #9b7cf7; }
  .icon-gray   { background: rgba(122,131,153,0.12); color: var(--text-dim); }

  .d-card-badge {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em;
    padding: 3px 9px; border-radius: 100px;
    background: rgba(79,142,247,0.08); color: var(--accent);
    border: 1px solid rgba(79,142,247,0.18);
  }
  .d-card-body { padding: 16px 20px 20px; }

  /* ── SHORTCUTS CARD ── */
  .shortcuts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 10px;
  }
  .sc-link {
    display: flex; flex-direction: column; align-items: flex-start;
    gap: 10px; padding: 14px;
    border: 1px solid var(--border); border-radius: 10px;
    background: var(--bg); text-decoration: none; color: var(--text);
    transition: border-color 0.15s, background 0.15s, transform 0.15s;
  }
  .sc-link:hover {
    border-color: rgba(79,142,247,0.4);
    background: rgba(79,142,247,0.04);
    transform: translateY(-1px);
  }
  .sc-link-dot {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    margin-top: 2px;
  }
  .sc-link-label { font-size: 12px; font-weight: 500; line-height: 1.35; }
  .sc-link-group { font-size: 10px; color: var(--text-dim); font-family: var(--mono); margin-top: auto; }

  .dot-teal   { background: var(--success); box-shadow: 0 0 6px rgba(52,217,139,0.5); }
  .dot-amber  { background: var(--warning); box-shadow: 0 0 6px rgba(245,158,11,0.5); }
  .dot-red    { background: var(--danger);  box-shadow: 0 0 6px rgba(247,97,79,0.4); }
  .dot-purple { background: #9b7cf7;        box-shadow: 0 0 6px rgba(155,124,247,0.4); }
  .dot-blue   { background: var(--accent);  box-shadow: 0 0 6px rgba(79,142,247,0.4); }

  .shortcuts-empty {
    min-height: 140px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 8px; color: var(--text-dim);
    border: 2px dashed var(--border);
    border-radius: 10px;
  }
  .shortcuts-empty-label { font-size: 13px; font-weight: 500; }
  .shortcuts-empty-sub   { font-size: 11px; opacity: 0.7; }

  /* ── CHART CARDS ── */
  .charts-row {
    display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
  }
  .chart-total {
    font-family: var(--mono); font-size: 22px; font-weight: 600;
    letter-spacing: -0.02em; margin: 4px 0 2px;
  }
  .chart-sub { font-size: 11px; color: var(--text-dim); }
  .chart-area { height: 150px; margin-top: 12px; }

  /* ── ORG CARD ── */
  .org-logo {
    width: 44px; height: 44px; border-radius: 10px;
    background: var(--accent-dim); display: flex; align-items: center; justify-content: center;
    font-size: 20px; font-weight: 700; color: var(--accent); flex-shrink: 0;
    font-family: var(--mono);
  }
  .org-name  { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .org-sub   { font-size: 11px; color: var(--text-dim); margin-top: 2px; }
  .org-divider { margin: 16px 0; border: none; border-top: 1px solid var(--border); }
  .org-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .org-stat-label { font-family: var(--mono); font-size: 9.5px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-dim); margin-bottom: 4px; }
  .org-stat-val   { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .org-stat-val.accent  { color: var(--accent); }
  .org-stat-val.teal    { color: var(--success); }
  .org-stat-val.amber   { color: var(--warning); }

  /* ── NOTIFICATIONS CARD ── */
  .notif-empty {
    min-height: 110px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 8px; color: var(--text-dim);
  }
  .notif-empty-label { font-size: 12px; }

  /* ── PAYABLES CARD ── */
  .payables-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  .payables-table th {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--text-dim);
    padding: 0 10px 10px; text-align: left; font-weight: 500;
    border-bottom: 1px solid var(--border);
  }
  .payables-table td {
    padding: 10px; border-bottom: 1px solid var(--border); vertical-align: middle;
  }
  .payables-table tr:last-child td { border-bottom: none; }
  .payables-table tr:hover td { background: rgba(79,142,247,0.03); }
  .sup-name { font-weight: 500; }
  .sup-inv  { font-family: var(--mono); font-size: 10.5px; color: var(--text-dim); margin-top: 2px; }
  .due-badge {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 10.5px; font-weight: 500; padding: 2px 8px;
    border-radius: 100px; white-space: nowrap;
  }
  .due-overdue  { background: rgba(247,97,79,0.12);  color: var(--danger);  border: 1px solid rgba(247,97,79,0.2); }
  .due-today    { background: rgba(245,158,11,0.12); color: var(--warning); border: 1px solid rgba(245,158,11,0.25); }
  .due-soon     { background: rgba(52,217,139,0.10); color: var(--success); border: 1px solid rgba(52,217,139,0.2); }
  .due-later    { background: rgba(122,131,153,0.1); color: var(--text-dim); border: 1px solid var(--border); }
  .amount-val   { font-family: var(--mono); font-size: 12.5px; font-weight: 600; text-align: right; color: var(--danger); }
  .payables-empty {
    padding: 32px; text-align: center; color: var(--text-dim); font-size: 13px;
  }

  @media (max-width: 900px) {
    .dash-layout { grid-template-columns: 1fr; }
    .charts-row  { grid-template-columns: 1fr; }
  }
</style>

<!-- Welcome Bar -->
<div class="welcome-bar">
  <div>
    <div class="welcome-greeting">
      Welcome back, <span><%= current_user.full_name %></span>
    </div>
    <div class="welcome-meta">
      <span class="badge badge-role"><%= current_user.role.humanize %></span>
      <span style="color:var(--border)">·</span>
      <span style="font-family:var(--mono);font-size:11px"><%= Time.now.strftime('%A, %d %b %Y') %></span>
    </div>
  </div>
  <% if current_user.super_admin? %>
    <%= link_to organisations_path, class: 'btn btn-secondary btn-sm' do %>
      <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      </svg>
      Manage Organisations
    <% end %>
  <% end %>
</div>

<% if @organisation %>
<div class="dash-layout">

  <!-- ══════════ LEFT MAIN ══════════ -->
  <div class="dash-main">

    <!-- ① BIG SHORTCUTS CARD -->
    <%
      saved_keys     = current_user.preferences['shortcuts'].presence || []
      pinned_modules = saved_keys.map { |k| ApplicationHelper::SHORTCUT_CATALOG_BY_KEY[k] }.compact
    %>
    <div class="d-card shortcuts-card">
      <div class="d-card-head">
        <div class="d-card-title">
          <div class="icon icon-blue">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          Quick Access
        </div>
        <% if pinned_modules.any? %>
          <span class="d-card-badge"><%= pinned_modules.size %> pinned</span>
        <% else %>
          <span class="d-card-badge">Shortcuts</span>
        <% end %>
      </div>
      <div class="d-card-body">
        <% if pinned_modules.any? %>
          <div class="shortcuts-grid">
            <% pinned_modules.each do |mod| %>
              <%= link_to mod[:path], class: "sc-link" do %>
                <div class="sc-link-dot dot-<%= mod[:color] %>"></div>
                <span class="sc-link-label"><%= mod[:label] %></span>
                <span class="sc-link-group"><%= mod[:group] %></span>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="shortcuts-empty">
            <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24" style="opacity:0.35">
              <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
              <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            <div class="shortcuts-empty-label">No shortcuts yet</div>
            <% if can?(:manage, :favorites) %>
              <div class="shortcuts-empty-sub">
                <%= link_to 'Set up shortcuts', profile_path, style: 'color:var(--accent)' %> in your profile
              </div>
            <% else %>
              <div class="shortcuts-empty-sub">Ask your admin to configure shortcuts</div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- ② CHARTS ROW -->
    <div class="charts-row">

      <!-- Sales This Month -->
      <div class="d-card">
        <div class="d-card-head">
          <div class="d-card-title">
            <div class="icon icon-teal">
              <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                <polyline points="17 6 23 6 23 12"/>
              </svg>
            </div>
            Sales
          </div>
          <span style="font-family:var(--mono);font-size:10px;color:var(--text-dim)">
            <%= Date.today.strftime('%b %Y') %>
          </span>
        </div>
        <div class="d-card-body">
          <div class="chart-total" style="color:var(--success)">
            &#8377;<%= number_with_delimiter(@sales_month_total.round(0).to_i) %>
          </div>
          <div class="chart-sub">Total confirmed sales this month</div>
          <div class="chart-area" id="salesChart"></div>
        </div>
      </div>

      <!-- Purchases This Month -->
      <div class="d-card">
        <div class="d-card-head">
          <div class="d-card-title">
            <div class="icon icon-amber">
              <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/>
                <polyline points="17 18 23 18 23 12"/>
              </svg>
            </div>
            Purchases
          </div>
          <span style="font-family:var(--mono);font-size:10px;color:var(--text-dim)">
            <%= Date.today.strftime('%b %Y') %>
          </span>
        </div>
        <div class="d-card-body">
          <div class="chart-total" style="color:var(--warning)">
            &#8377;<%= number_with_delimiter(@purchase_month_total.round(0).to_i) %>
          </div>
          <div class="chart-sub">Total confirmed purchases this month</div>
          <div class="chart-area" id="purchaseChart"></div>
        </div>
      </div>

    </div><!-- .charts-row -->

    <!-- ③ PAYABLES DUE -->
    <div class="d-card">
      <div class="d-card-head">
        <div class="d-card-title">
          <div class="icon icon-red">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          Payables Due
        </div>
        <span class="d-card-badge" style="background:rgba(247,97,79,0.08);color:var(--danger);border-color:rgba(247,97,79,0.2)">
          Supplier Payments
        </span>
      </div>
      <div class="d-card-body" style="padding-top:14px">
        <% if @payables_due.any? %>
          <table class="payables-table">
            <thead>
              <tr>
                <th>Supplier / Invoice</th>
                <th>Due Date</th>
                <th style="text-align:right">Outstanding</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @payables_due.each do |inv| %>
                <% days_until = inv.payment_due_date ? (inv.payment_due_date - Date.today).to_i : nil %>
                <tr>
                  <td>
                    <div class="sup-name"><%= inv.supplier&.name || '—' %></div>
                    <div class="sup-inv"><%= inv.display_number %></div>
                  </td>
                  <td>
                    <% if inv.payment_due_date.nil? %>
                      <span class="due-badge due-later">No due date</span>
                    <% elsif days_until < 0 %>
                      <span class="due-badge due-overdue">
                        <svg width="9" height="9" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                        <%= days_until.abs %> day<%= days_until.abs == 1 ? '' : 's' %> overdue
                      </span>
                    <% elsif days_until == 0 %>
                      <span class="due-badge due-today">Due today</span>
                    <% elsif days_until <= 7 %>
                      <span class="due-badge due-soon">Due in <%= days_until %> day<%= days_until == 1 ? '' : 's' %></span>
                    <% else %>
                      <span class="due-badge due-later"><%= inv.payment_due_date.strftime('%d %b') %></span>
                    <% end %>
                  </td>
                  <td class="amount-val">&#8377;<%= number_with_delimiter(inv.outstanding_amount.round(0).to_i) %></td>
                  <td style="text-align:right">
                    <%= link_to 'View', purchasing_purchase_invoice_path(inv),
                          style: "font-family:var(--mono);font-size:10px;color:var(--accent);
                                  text-decoration:none;padding:3px 9px;
                                  border:1px solid var(--accent-dim);border-radius:4px;
                                  white-space:nowrap" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="payables-empty">
            <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24" style="opacity:0.3;margin-bottom:8px">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <div>No outstanding payables</div>
            <div style="font-size:11px;margin-top:4px;opacity:0.7">All supplier invoices are settled</div>
          </div>
        <% end %>
      </div>
    </div>

  </div><!-- .dash-main -->

  <!-- ══════════ RIGHT SIDEBAR ══════════ -->
  <div class="dash-side">

    <!-- ④ ORGANISATION CARD -->
    <div class="d-card">
      <div class="d-card-head">
        <div class="d-card-title">
          <div class="icon icon-blue">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            </svg>
          </div>
          Organisation
        </div>
        <span class="badge <%= @organisation.active? ? 'badge-active' : 'badge-inactive' %>" style="font-size:10px">
          <%= @organisation.status %>
        </span>
      </div>
      <div class="d-card-body">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:4px">
          <div class="org-logo"><%= @organisation.name.first.upcase %></div>
          <div>
            <div class="org-name"><%= @organisation.name %></div>
            <div class="org-sub">Active workspace</div>
          </div>
        </div>
        <hr class="org-divider">
        <div class="org-stats">
          <div>
            <div class="org-stat-label">Users</div>
            <div class="org-stat-val accent"><%= @organisation.users.count %></div>
            <div style="font-size:10px;color:var(--text-dim);margin-top:1px"><%= @organisation.users.active.count %> active</div>
          </div>
          <div>
            <div class="org-stat-label">Plan</div>
            <div class="org-stat-val amber"><%= @organisation.subscription_plan&.capitalize || 'Basic' %></div>
            <div style="font-size:10px;color:var(--text-dim);margin-top:1px">Current subscription</div>
          </div>
          <div style="grid-column:span 2;margin-top:4px">
            <div class="org-stat-label">Member Since</div>
            <div class="org-stat-val teal" style="font-size:13px">
              <%= @organisation.created_at.strftime('%d %b %Y') %>
            </div>
            <div style="font-size:10px;color:var(--text-dim);margin-top:1px">
              <%= (Date.today - @organisation.created_at.to_date).to_i %> days with us
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ⑤ NOTIFICATIONS CARD -->
    <div class="d-card">
      <div class="d-card-head">
        <div class="d-card-title">
          <div class="icon icon-purple">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
          </div>
          Notifications
        </div>
        <span class="d-card-badge" style="background:rgba(155,124,247,0.08);color:#9b7cf7;border-color:rgba(155,124,247,0.2)">0 new</span>
      </div>
      <div class="d-card-body">
        <div class="notif-empty">
          <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24" style="opacity:0.3">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
          <div class="notif-empty-label" style="font-size:12px;opacity:0.6">No notifications yet</div>
        </div>
      </div>
    </div>

  </div><!-- .dash-side -->

</div><!-- .dash-layout -->

<script>
(function() {
  var ACCENT  = '#4f8ef7';
  var SUCCESS = '#34d98b';
  var WARNING = '#f59e0b';
  var DIM     = 'rgba(122,131,153,0.4)';
  var TEXT_DIM= '#6b7799';
  var GRID_C  = 'rgba(79,142,247,0.06)';

  function mkChart(el) {
    return echarts.init(el, null, { renderer: 'canvas' });
  }

  function baseOption(labels, values, color, gradientColor) {
    return {
      grid: { top: 8, right: 8, bottom: 24, left: 44 },
      xAxis: {
        type: 'category',
        data: labels,
        axisLine:  { lineStyle: { color: DIM } },
        axisTick:  { show: false },
        axisLabel: { color: TEXT_DIM, fontSize: 10, interval: Math.floor(labels.length / 5) }
      },
      yAxis: {
        type: 'value',
        axisLabel: {
          color: TEXT_DIM, fontSize: 10,
          formatter: function(v) {
            if (v >= 100000) return '₹' + (v/100000).toFixed(0) + 'L';
            if (v >= 1000)   return '₹' + (v/1000).toFixed(0) + 'k';
            return v === 0 ? '' : '₹' + v;
          }
        },
        splitLine: { lineStyle: { color: GRID_C } },
        axisLine:  { show: false },
        axisTick:  { show: false }
      },
      tooltip: {
        trigger: 'axis',
        backgroundColor: '#181c27',
        borderColor: '#252a38',
        textStyle: { color: '#dde3f4', fontSize: 12 },
        formatter: function(params) {
          return 'Day ' + params[0].name + '<br/>₹' + Number(params[0].value).toLocaleString('en-IN');
        }
      },
      series: [{
        type: 'bar',
        data: values,
        barMaxWidth: 18,
        itemStyle: {
          color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
            { offset: 0, color: color },
            { offset: 1, color: gradientColor }
          ]),
          borderRadius: [4, 4, 0, 0]
        },
        emphasis: { itemStyle: { color: color } }
      }]
    };
  }

  // Sales chart
  var salesData   = <%= raw @sales_chart_data.to_json %>;
  var salesLabels = salesData.map(function(d) { return d[0]; });
  var salesVals   = salesData.map(function(d) { return d[1]; });
  var sc = mkChart(document.getElementById('salesChart'));
  sc.setOption(baseOption(salesLabels, salesVals, SUCCESS, 'rgba(52,217,139,0.15)'));

  // Purchase chart
  var purchaseData   = <%= raw @purchase_chart_data.to_json %>;
  var purchaseLabels = purchaseData.map(function(d) { return d[0]; });
  var purchaseVals   = purchaseData.map(function(d) { return d[1]; });
  var pc = mkChart(document.getElementById('purchaseChart'));
  pc.setOption(baseOption(purchaseLabels, purchaseVals, WARNING, 'rgba(245,158,11,0.15)'));

  window.addEventListener('resize', function() { sc.resize(); pc.resize(); });
})();
</script>
<% end %>
