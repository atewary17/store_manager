<%# app/views/customers/show.html.erb %>
<% content_for :title, @customer.name %>
<% content_for :breadcrumb do %>
  <span style="color:var(--text-dim)">Trade Relations</span>
  <span class="breadcrumb-sep">/</span>
  <%= link_to 'Customers', customers_path, style: "color:var(--text-dim)" %>
  <span class="breadcrumb-sep">/</span>
  <span class="breadcrumb-current"><%= @customer.name %></span>
<% end %>

<div class="page-header">
  <div style="display:flex;align-items:center;gap:16px">
    <div style="width:52px;height:52px;border-radius:50%;background:rgba(52,217,139,0.12);
                color:var(--success);display:flex;align-items:center;justify-content:center;
                font-size:20px;font-weight:600;border:2px solid rgba(52,217,139,0.3)">
      <%= @customer.name[0].upcase %>
    </div>
    <div>
      <div class="page-title"><%= @customer.name %></div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:6px">
        <span class="badge <%= @customer.active? ? 'badge-active' : 'badge-inactive' %>">
          <%= @customer.active? ? 'Active' : 'Inactive' %>
        </span>
        <% if @customer.gstin.present? %>
          <span class="badge badge-plan">B2B</span>
        <% else %>
          <span class="badge" style="background:rgba(122,131,153,0.12);color:var(--text-dim)">B2C</span>
        <% end %>
      </div>
    </div>
  </div>
  <div class="actions">
    <%= link_to 'Edit', edit_customer_path(@customer), class: 'btn btn-secondary' %>
    <%= link_to '+ New Invoice', new_sales_sales_invoice_path, class: 'btn btn-primary' %>
  </div>
</div>

<%# Stats %>
<div class="stats-row" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px">
  <div class="stat-card">
    <div class="stat-label">Confirmed Invoices</div>
    <div class="stat-value accent"><%= @invoice_count %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Invoiced</div>
    <div class="stat-value" style="font-size:18px">
      ₹<%= number_with_delimiter(@total_invoiced.round(0)) %>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Paid</div>
    <div class="stat-value success" style="font-size:18px">
      ₹<%= number_with_delimiter(@total_paid.round(0)) %>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Outstanding</div>
    <div class="stat-value" style="font-size:18px;color:<%= @total_outstanding > 0 ? 'var(--warning)' : 'var(--success)' %>">
      ₹<%= number_with_delimiter(@total_outstanding.round(0)) %>
    </div>
  </div>
</div>

<%# Contact details %>
<div class="detail-card" style="margin-bottom:24px">
  <div class="detail-section">
    <div class="detail-section-title">Contact Details</div>
    <div class="detail-grid">
      <div class="detail-field">
        <label>Name</label>
        <div class="value"><%= @customer.name %></div>
      </div>
      <div class="detail-field">
        <label>Phone</label>
        <div class="value mono"><%= @customer.phone.presence || '—' %></div>
      </div>
      <div class="detail-field">
        <label>GSTIN</label>
        <div class="value mono"><%= @customer.gstin.presence || '—' %></div>
      </div>
      <div class="detail-field">
        <label>PAN</label>
        <div class="value mono"><%= @customer.pan.presence || '—' %></div>
      </div>
      <div class="detail-field">
        <label>State</label>
        <div class="value">
          <%= @customer.state.presence || '—' %>
          <% if @customer.state_code.present? %>
            <span style="font-family:var(--mono);font-size:11px;color:var(--text-dim);margin-left:6px">
              Code: <%= @customer.state_code %>
            </span>
          <% end %>
        </div>
      </div>
      <div class="detail-field">
        <label>Last Invoice</label>
        <div class="value">
          <%= @last_invoice&.strftime('%d %b %Y') || '—' %>
        </div>
      </div>
      <% if @customer.address.present? %>
        <div class="detail-field" style="grid-column:span 2">
          <label>Address</label>
          <div class="value"><%= @customer.address %></div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# Invoice history %>
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
  <div style="font-size:15px;font-weight:600">
    Invoice History
    <span style="font-family:var(--mono);font-size:12px;color:var(--text-dim);font-weight:400;margin-left:8px">
      <%= @invoice_count %> confirmed
      <% if @draft_count > 0 %>
        · <%= @draft_count %> draft
      <% end %>
    </span>
  </div>
  <%= link_to 'View All →', sales_sales_invoices_path,
        style: "font-size:12px;color:var(--accent);text-decoration:none" %>
</div>

<div class="table-wrap">
  <% if @invoices.any? %>
    <table>
      <thead>
        <tr>
          <th>Invoice</th>
          <th>Date</th>
          <th style="text-align:right">Amount</th>
          <th style="text-align:right">Paid</th>
          <th style="text-align:right">Outstanding</th>
          <th>Payment</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @invoices.each do |inv| %>
          <tr>
            <td><%= link_to inv.display_number, sales_sales_invoice_path(inv) %></td>
            <td style="font-size:12px;color:var(--text-dim);font-family:var(--mono)">
              <%= inv.invoice_date&.strftime('%d %b %Y') %>
            </td>
            <td style="text-align:right;font-family:var(--mono)">
              ₹<%= number_with_delimiter(inv.total_amount.to_f.round(0)) %>
            </td>
            <td style="text-align:right;font-family:var(--mono);color:var(--success)">
              ₹<%= number_with_delimiter(inv.total_paid.to_f.round(0)) %>
            </td>
            <td style="text-align:right;font-family:var(--mono);
                       color:<%= inv.outstanding_amount.to_f > 0 ? 'var(--warning)' : 'var(--text-dim)' %>">
              ₹<%= number_with_delimiter(inv.outstanding_amount.to_f.round(0)) %>
            </td>
            <td>
              <% ps = inv.payment_status %>
              <span style="font-family:var(--mono);font-size:10px;font-weight:600;
                           padding:2px 8px;border-radius:10px;
                           background:<%= ps=='paid' ? 'rgba(52,217,139,0.12)' : ps=='partial' ? 'rgba(247,195,79,0.12)' : 'rgba(247,97,79,0.12)' %>;
                           color:<%= ps=='paid' ? 'var(--success)' : ps=='partial' ? 'var(--warning)' : 'var(--danger)' %>">
                <%= ps.upcase %>
              </span>
            </td>
            <td>
              <%= link_to 'View', sales_sales_invoice_path(inv), class: 'btn btn-secondary btn-sm' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <p>No confirmed invoices for this customer yet.</p>
    </div>
  <% end %>
</div>

<div style="margin-top:20px">
  <%= link_to '← Back to Customers', customers_path, class: 'btn btn-secondary' %>
</div>
