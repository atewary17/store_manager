<% content_for :title, @organisation.name %>
<% content_for :breadcrumb do %>
  <% if current_user.super_admin? %>
    <%= link_to 'Organisations', organisations_path %>
    <span class="breadcrumb-sep">/</span>
  <% end %>
  <span class="breadcrumb-current"><%= @organisation.name %></span>
<% end %>

<%
  cfg          = @organisation.settings
  inv_prefix   = cfg['invoice_number_prefix'].to_s
  inv_format   = cfg['invoice_number_format'].presence || 'serial_only'
  inv_start    = cfg['invoice_number_start'].presence || '1'
  inv_counter  = cfg['invoice_number_counter']
  org_ai       = cfg['ai_provider'].to_s
  global_ai    = ENV['INVOICE_AI_PROVIDER'] || 'gemini'

  tinting_enabled   = cfg['tinting_prompt_enabled'] == true
  tinting_threshold = cfg['tinting_prompt_threshold_litres'].presence || '8'
  tinting_action    = cfg['tinting_prompt_action'].presence || 'popup'
%>

<style>
  /* ── org-show layout ─────────────────────────────────────── */
  .os-layout      { display:grid; grid-template-columns:1fr 340px; gap:24px; align-items:start; }
  .os-main        { display:flex; flex-direction:column; gap:20px; }
  .os-aside       { display:flex; flex-direction:column; gap:20px; }

  /* ── cards ───────────────────────────────────────────────── */
  .os-card        { background:var(--surface); border:1px solid var(--border);
                    border-radius:12px; overflow:hidden; }
  .os-card-head   { display:flex; align-items:center; justify-content:space-between;
                    padding:14px 18px 12px; border-bottom:1px solid var(--border); }
  .os-card-title  { display:flex; align-items:center; gap:9px;
                    font-size:13px; font-weight:600; color:var(--text); }
  .os-card-body   { padding:18px; }

  /* ── detail grid ─────────────────────────────────────────── */
  .os-grid        { display:grid; grid-template-columns:1fr 1fr; gap:14px 20px; }
  .os-grid.span1  { grid-template-columns:1fr; }
  .os-field label { display:block; font-size:10px; font-weight:600; letter-spacing:.07em;
                    text-transform:uppercase; color:var(--text-dim); margin-bottom:4px; }
  .os-field .val  { font-size:13px; color:var(--text); line-height:1.4; }
  .os-field .val.mono { font-family:var(--mono); }
  .os-field .val.warn { color:var(--danger); font-size:12px; }

  /* ── config section ──────────────────────────────────────── */
  .os-section-label {
    font-size:10px; font-weight:700; letter-spacing:.08em; text-transform:uppercase;
    color:var(--text-dim); padding:0 0 10px; margin-bottom:12px;
    border-bottom:1px solid var(--border);
  }
  .os-row         { display:flex; align-items:center; gap:12px; margin-bottom:14px; }
  .os-row:last-child { margin-bottom:0; }
  .os-row label   { font-size:12px; font-weight:500; color:var(--text-dim);
                    white-space:nowrap; min-width:110px; }
  .os-input       { flex:1; padding:7px 10px; background:var(--bg);
                    border:1px solid var(--border); border-radius:7px;
                    font-size:13px; color:var(--text); font-family:var(--mono);
                    min-width:0; }
  .os-input:focus { outline:none; border-color:var(--accent); }
  .os-input.sm    { max-width:90px; }

  /* ── format radio pills ──────────────────────────────────── */
  .fmt-pills      { display:flex; flex-direction:column; gap:8px; flex:1; }
  .fmt-pill       { display:flex; align-items:flex-start; gap:10px; padding:10px 12px;
                    border:1px solid var(--border); border-radius:8px; cursor:pointer;
                    transition:border-color .15s, background .15s; }
  .fmt-pill:hover { border-color:var(--accent-dim); }
  .fmt-pill input[type=radio] { margin-top:2px; accent-color:var(--accent); flex-shrink:0; }
  .fmt-pill.active { border-color:var(--accent); background:rgba(var(--accent-rgb),.05); }
  .fmt-pill-title { font-size:12px; font-weight:600; color:var(--text); }
  .fmt-pill-eg    { font-size:11px; color:var(--text-dim); font-family:var(--mono); margin-top:2px; }

  /* ── preview badge ───────────────────────────────────────── */
  .inv-preview    { display:inline-flex; align-items:center; gap:8px; margin-top:12px;
                    padding:7px 12px; background:var(--bg); border:1px solid var(--border);
                    border-radius:7px; font-size:12px; color:var(--text-dim); }
  .inv-preview strong { font-family:var(--mono); font-size:13px; color:var(--accent); }

  /* ── save bar ────────────────────────────────────────────── */
  .os-save-row    { display:flex; align-items:center; gap:10px; margin-top:16px;
                    padding-top:14px; border-top:1px solid var(--border); }
  .os-toast       { font-size:12px; color:var(--success); font-weight:500; opacity:0;
                    transition:opacity .3s; }

  /* ── AI options ──────────────────────────────────────────── */
  .ai-opt         { display:flex; align-items:flex-start; gap:10px; padding:10px 12px;
                    border:1px solid var(--border); border-radius:8px; cursor:pointer;
                    transition:border-color .15s; margin-bottom:8px; }
  .ai-opt:last-child { margin-bottom:0; }
  .ai-opt:hover   { border-color:var(--accent-dim); }
  .ai-opt.active  { border-color:var(--accent); background:rgba(var(--accent-rgb),.05); }
  .ai-opt input   { margin-top:2px; accent-color:var(--accent); flex-shrink:0; }
  .ai-opt-title   { font-size:12px; font-weight:600; color:var(--text); }
  .ai-opt-desc    { font-size:11px; color:var(--text-dim); margin-top:2px; }
  .badge-free     { font-size:9px; font-weight:700; padding:1px 6px; border-radius:100px;
                    background:rgba(16,185,129,.12); color:var(--success);
                    border:1px solid rgba(16,185,129,.2); margin-left:4px; }

  /* ── icon blobs ──────────────────────────────────────────── */
  .c-icon         { width:28px; height:28px; border-radius:7px; display:flex;
                    align-items:center; justify-content:center; flex-shrink:0; }
  .ci-teal        { background:rgba(20,184,166,.12); color:#14b8a6; }
  .ci-blue        { background:rgba(99,102,241,.12); color:#6366f1; }
  .ci-amber       { background:rgba(245,158,11,.12); color:var(--warning); }
  .ci-purple      { background:rgba(168,85,247,.12); color:#a855f7; }

  /* ── counter pill ────────────────────────────────────────── */
  .counter-pill   { display:inline-flex; align-items:center; gap:5px; padding:3px 9px;
                    border-radius:100px; font-size:11px; font-family:var(--mono);
                    background:rgba(var(--accent-rgb),.08); color:var(--accent);
                    border:1px solid rgba(var(--accent-rgb),.15); }

  /* ── team table ──────────────────────────────────────────── */
  .member-avatar  { width:30px; height:30px; border-radius:50%; background:var(--accent-dim);
                    color:var(--accent); display:flex; align-items:center; justify-content:center;
                    font-family:var(--mono); font-size:11px; font-weight:500; flex-shrink:0; }

  @media (max-width:900px) {
    .os-layout { grid-template-columns:1fr; }
  }
</style>

<%# ── Page header ── %>
<div class="page-header">
  <div>
    <div class="page-title"><%= @organisation.name %></div>
    <div style="display:flex;align-items:center;gap:8px;margin-top:6px">
      <span class="badge <%= @organisation.active? ? 'badge-active' : 'badge-inactive' %>">
        <%= @organisation.status %>
      </span>
      <% if @organisation.subscription_plan.present? %>
        <span class="badge badge-plan"><%= @organisation.subscription_plan.capitalize %></span>
      <% end %>
      <% if inv_counter.present? %>
        <span class="counter-pill">&#9654; Last invoice #<%= inv_counter %></span>
      <% end %>
    </div>
  </div>
  <div class="actions">
    <% if current_user.super_admin? || current_user.owner? || current_user.admin? %>
      <%= link_to 'Edit', edit_organisation_path(@organisation), class: 'btn btn-secondary' %>
    <% end %>
    <%= link_to '+ Add User', new_organisation_user_path(@organisation), class: 'btn btn-primary' %>
  </div>
</div>

<div class="os-layout">

  <%# ═══════════════════════════════════════════════════════ MAIN COLUMN %>
  <div class="os-main">

    <%# ── Card: Identity ── %>
    <div class="os-card">
      <div class="os-card-head">
        <div class="os-card-title">
          <div class="c-icon ci-teal">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
          Identity &amp; Tax
        </div>
      </div>
      <div class="os-card-body">
        <div class="os-grid" style="margin-bottom:16px">
          <div class="os-field">
            <label>GSTIN</label>
            <div class="val mono"><%= @organisation.gst_number.presence || '—' %></div>
          </div>
          <div class="os-field">
            <label>PAN</label>
            <div class="val mono"><%= @organisation.pan.presence || '—' %></div>
          </div>
          <div class="os-field">
            <label>State</label>
            <% if @organisation.state.blank? %>
              <div class="val warn">&#9888; Not set — GST defaults to intra-state</div>
            <% else %>
              <div class="val"><%= @organisation.state %></div>
            <% end %>
          </div>
          <div class="os-field">
            <label>State Code</label>
            <div class="val mono"><%= @organisation.state_code.presence || '—' %></div>
          </div>
        </div>
        <div class="os-grid">
          <div class="os-field">
            <label>Subscription</label>
            <div class="val"><%= @organisation.subscription_plan&.capitalize || '—' %></div>
          </div>
          <div class="os-field">
            <label>Status</label>
            <span class="badge <%= @organisation.active? ? 'badge-active' : 'badge-inactive' %>">
              <%= @organisation.status %>
            </span>
          </div>
          <div class="os-field" style="grid-column:span 2">
            <label>Registered Address</label>
            <div class="val"><%= @organisation.address.presence || '—' %></div>
          </div>
        </div>
      </div>
    </div>

    <% if current_user.super_admin? %>

    <%# ── Card: Invoice Numbering ── %>
    <div class="os-card" id="inv-config-card">
      <div class="os-card-head">
        <div class="os-card-title">
          <div class="c-icon ci-amber">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
              <rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/>
            </svg>
          </div>
          Invoice Numbering
        </div>
        <span style="font-family:var(--mono);font-size:10px;padding:2px 8px;border-radius:100px;
                     background:rgba(245,158,11,.1);color:var(--warning);
                     border:1px solid rgba(245,158,11,.2)">Super Admin</span>
      </div>
      <div class="os-card-body">

        <div class="os-section-label">Format</div>
        <div class="fmt-pills" id="fmt-pills">
          <label class="fmt-pill <%= inv_format == 'prefix_date_serial' ? 'active' : '' %>">
            <input type="radio" name="inv_format" value="prefix_date_serial"
                   <%= 'checked' if inv_format == 'prefix_date_serial' %>>
            <div>
              <div class="fmt-pill-title">Prefix + Date + Serial</div>
              <div class="fmt-pill-eg" id="eg-prefix_date_serial">
                e.g. IPH&#8209;<span id="eg-date-1"><%= Date.today.strftime('%d%m%y') %></span>&#8209;00001
              </div>
            </div>
          </label>
          <label class="fmt-pill <%= inv_format == 'prefix_serial' ? 'active' : '' %>">
            <input type="radio" name="inv_format" value="prefix_serial"
                   <%= 'checked' if inv_format == 'prefix_serial' %>>
            <div>
              <div class="fmt-pill-title">Prefix + Serial</div>
              <div class="fmt-pill-eg">e.g. IPH&#8209;00001</div>
            </div>
          </label>
          <label class="fmt-pill <%= inv_format == 'serial_only' ? 'active' : '' %>">
            <input type="radio" name="inv_format" value="serial_only"
                   <%= 'checked' if inv_format == 'serial_only' %>>
            <div>
              <div class="fmt-pill-title">Serial Only</div>
              <div class="fmt-pill-eg">e.g. 00001</div>
            </div>
          </label>
        </div>

        <div class="os-section-label" style="margin-top:20px">Settings</div>

        <div class="os-row">
          <label>Prefix</label>
          <input type="text" id="inv-prefix" class="os-input"
                 value="<%= inv_prefix %>"
                 placeholder="e.g. IPH"
                 maxlength="10"
                 style="max-width:140px;text-transform:uppercase">
          <span style="font-size:11px;color:var(--text-dim)">Used in Prefix + Date / Prefix + Serial formats</span>
        </div>

        <div class="os-row">
          <label>Start from</label>
          <input type="number" id="inv-start" class="os-input sm"
                 value="<%= inv_start %>" min="1" step="1">
          <% if inv_counter.present? %>
            <span style="font-size:11px;color:var(--warning)">
              &#9888; Counter is at <strong><%= inv_counter %></strong>.
              Changing this will reset the sequence.
            </span>
          <% else %>
            <span style="font-size:11px;color:var(--text-dim)">First serial number for new invoices</span>
          <% end %>
        </div>

        <div class="inv-preview">
          Next invoice will look like:&nbsp;
          <strong id="inv-preview-val"><%= @organisation.invoice_number_preview %></strong>
        </div>

        <div class="os-save-row">
          <button class="btn btn-primary btn-sm" onclick="saveInvConfig()">Save Configuration</button>
          <span class="os-toast" id="inv-toast">&#10003; Saved</span>
        </div>
      </div>
    </div>

    <%# ── Card: AI Provider ── %>
    <div class="os-card" id="ai-config-card">
      <div class="os-card-head">
        <div class="os-card-title">
          <div class="c-icon ci-purple">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/>
            </svg>
          </div>
          AI Provider — Invoice Scanning
        </div>
        <span style="font-family:var(--mono);font-size:10px;padding:2px 8px;border-radius:100px;
                     background:rgba(245,158,11,.1);color:var(--warning);
                     border:1px solid rgba(245,158,11,.2)">Super Admin</span>
      </div>
      <div class="os-card-body">
        <p style="font-size:12px;color:var(--text-dim);margin:0 0 14px">
          Sets the default AI provider for all users in this organisation.
          Individual users can override this in their profile.
          Global server default is <strong><%= global_ai.upcase %></strong>.
        </p>

        <div id="ai-opts">
          <label class="ai-opt <%= org_ai.blank? ? 'active' : '' %>">
            <input type="radio" name="org_ai" value="">
            <div>
              <div class="ai-opt-title">
                Use global server default
                <span style="font-size:11px;font-weight:400;color:var(--text-dim);margin-left:4px">
                  (currently: <%= global_ai.upcase %>)
                </span>
              </div>
              <div class="ai-opt-desc">Follows the server environment variable</div>
            </div>
          </label>
          <label class="ai-opt <%= org_ai == 'groq' ? 'active' : '' %>">
            <input type="radio" name="org_ai" value="groq" <%= 'checked' if org_ai == 'groq' %>>
            <div>
              <div class="ai-opt-title">Groq — Llama 4 Scout <span class="badge-free">FREE</span></div>
              <div class="ai-opt-desc">Fast free tier, up to ~14,400 requests/day. Best for most orgs.</div>
            </div>
          </label>
          <label class="ai-opt <%= org_ai == 'openrouter' ? 'active' : '' %>">
            <input type="radio" name="org_ai" value="openrouter" <%= 'checked' if org_ai == 'openrouter' %>>
            <div>
              <div class="ai-opt-title">OpenRouter — Llama 3.2 Vision <span class="badge-free">FREE</span></div>
              <div class="ai-opt-desc">
                Requires <code style="font-family:var(--mono)">OPENROUTER_API_KEY</code> on the server.
              </div>
            </div>
          </label>
        </div>

        <div class="os-save-row">
          <button class="btn btn-primary btn-sm" onclick="saveAiConfig()">Save Provider</button>
          <span class="os-toast" id="ai-toast">&#10003; Saved</span>
        </div>
      </div>
    </div>

    <%# ── Card: Tinting Machine ── %>
    <div class="os-card" id="tinting-config-card">
      <div class="os-card-head">
        <div class="os-card-title">
          <div class="c-icon ci-teal">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/>
            </svg>
          </div>
          Tinting Machine
        </div>
        <span style="font-family:var(--mono);font-size:10px;padding:2px 8px;border-radius:100px;
                     background:rgba(245,158,11,.1);color:var(--warning);
                     border:1px solid rgba(245,158,11,.2)">Super Admin</span>
      </div>
      <div class="os-card-body">

        <div class="os-section-label">Post-Sale Prompt</div>

        <%# Toggle: enabled %>
        <div style="display:flex;align-items:center;justify-content:space-between;
                    padding:12px 14px;background:var(--bg);border:1px solid var(--border);
                    border-radius:8px;margin-bottom:12px">
          <div>
            <div style="font-size:13px;font-weight:500;color:var(--text)">
              Prompt to update tinting machine after paint sales
            </div>
            <div style="font-size:11px;color:var(--text-dim);margin-top:2px">
              When enabled, a prompt appears after confirming invoices with tinted paint
            </div>
          </div>
          <label style="position:relative;display:inline-block;width:40px;height:22px;flex-shrink:0;margin-left:16px">
            <input type="checkbox" id="tinting-enabled-toggle"
                   <%= 'checked' if tinting_enabled %>
                   style="opacity:0;width:0;height:0;position:absolute"
                   onchange="onTintingToggle(this)">
            <span id="tinting-enabled-slider"
                  style="position:absolute;cursor:pointer;inset:0;border-radius:22px;
                         transition:.2s;background:<%= tinting_enabled ? 'var(--accent)' : 'var(--border)' %>">
              <span style="position:absolute;content:'';height:16px;width:16px;left:3px;bottom:3px;
                           background:#fff;border-radius:50%;transition:.2s;
                           transform:<%= tinting_enabled ? 'translateX(18px)' : 'translateX(0)' %>"
                    id="tinting-knob"></span>
            </span>
          </label>
        </div>

        <%# Threshold + action — shown/hidden by toggle %>
        <div id="tinting-sub-settings" style="<%= tinting_enabled ? '' : 'display:none' %>">

          <div class="os-row">
            <label>Trigger threshold</label>
            <input type="number" id="tinting-threshold" class="os-input sm"
                   value="<%= tinting_threshold %>" min="0.5" step="0.5">
            <span style="font-size:11px;color:var(--text-dim)">litres sold since last machine update</span>
          </div>

          <div class="os-section-label" style="margin-top:16px">Action when threshold reached</div>

          <div style="display:flex;flex-direction:column;gap:8px">
            <label class="fmt-pill <%= %w[new_tab popup].include?(tinting_action) ? 'active' : '' %>">
              <input type="radio" name="tinting_action" value="new_tab"
                     <%= 'checked' if %w[new_tab popup].include?(tinting_action) %>
                     onchange="onTintingActionChange(this)">
              <div>
                <div class="fmt-pill-title">Navigate to tinting page</div>
                <div class="fmt-pill-eg">
                  Opens the brand's tinting machine in a new browser tab after invoice confirmation
                </div>
              </div>
            </label>
            <label class="fmt-pill <%= %w[popup_window redirect].include?(tinting_action) ? 'active' : '' %>">
              <input type="radio" name="tinting_action" value="popup_window"
                     <%= 'checked' if %w[popup_window redirect].include?(tinting_action) %>
                     onchange="onTintingActionChange(this)">
              <div>
                <div class="fmt-pill-title">Show popup window</div>
                <div class="fmt-pill-eg">
                  Opens the brand's tinting machine in a focused browser popup window (1280×820)
                </div>
              </div>
            </label>
          </div>

        </div><%# /tinting-sub-settings %>

        <div class="os-save-row">
          <button class="btn btn-primary btn-sm" onclick="saveTintingConfig()">Save Configuration</button>
          <span class="os-toast" id="tinting-toast">&#10003; Saved</span>
        </div>

      </div>
    </div>

    <% end %><%# /super_admin %>

  </div><%# /os-main %>

  <%# ═══════════════════════════════════════════════════════ ASIDE COLUMN %>
  <div class="os-aside">

    <%# ── Card: Team Members ── %>
    <div class="os-card">
      <div class="os-card-head">
        <div class="os-card-title">
          <div class="c-icon ci-blue">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          Team
          <span style="font-family:var(--mono);font-size:11px;font-weight:400;
                       color:var(--text-dim);margin-left:2px">(<%= @users.count %>)</span>
        </div>
        <div class="search-input-wrap" style="max-width:160px">
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input type="text" class="search-input" placeholder="Search..." id="memberSearch"
                 style="font-size:12px">
        </div>
      </div>
      <div style="max-height:420px;overflow-y:auto">
        <table id="membersTable" style="width:100%;border-collapse:collapse">
          <tbody>
            <% @users.each do |user| %>
              <tr style="border-bottom:1px solid var(--border)">
                <td style="padding:10px 16px">
                  <div style="display:flex;align-items:center;gap:10px">
                    <div class="member-avatar"><%= user.initials %></div>
                    <div>
                      <div style="font-size:13px;font-weight:500">
                        <%= link_to user.full_name, organisation_user_path(@organisation, user),
                              style: 'color:var(--text);text-decoration:none' %>
                        <% if user == current_user %>
                          <span style="font-size:10px;color:var(--text-dim);font-family:var(--mono)">(you)</span>
                        <% end %>
                      </div>
                      <div style="font-size:11px;color:var(--text-dim)"><%= user.email %></div>
                    </div>
                  </div>
                </td>
                <td style="padding:10px 16px;text-align:right;vertical-align:middle">
                  <span class="badge badge-role" data-role="<%= user.role %>">
                    <%= user.role.humanize %>
                  </span>
                  <div style="margin-top:4px">
                    <span class="badge <%= user.active? ? 'badge-active' : 'badge-inactive' %>">
                      <%= user.status %>
                    </span>
                  </div>
                  <div style="margin-top:6px;display:flex;justify-content:flex-end;gap:4px">
                    <%= link_to 'View', organisation_user_path(@organisation, user),
                          class: 'btn btn-secondary btn-sm',
                          style: 'font-size:11px;padding:3px 8px' %>
                    <% if current_user.super_admin? || current_user.owner? || current_user.admin? %>
                      <%= link_to 'Edit', edit_organisation_user_path(@organisation, user),
                            class: 'btn btn-secondary btn-sm',
                            style: 'font-size:11px;padding:3px 8px' %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div style="padding:12px 16px;border-top:1px solid var(--border)">
        <%= link_to '+ Add User', new_organisation_user_path(@organisation),
              class: 'btn btn-primary btn-sm', style: 'width:100%;text-align:center' %>
      </div>
    </div>

  </div><%# /os-aside %>

</div><%# /os-layout %>

<% if current_user.super_admin? %>
<script>
  const SETTINGS_URL = '<%= settings_organisation_path(@organisation) %>';
  const CSRF_TOKEN   = '<%= form_authenticity_token %>';

  // ── highlight active format pill ──────────────────────────
  document.querySelectorAll('.fmt-pill input[type=radio]').forEach(r => {
    r.addEventListener('change', () => {
      document.querySelectorAll('.fmt-pill').forEach(p => p.classList.remove('active'));
      r.closest('.fmt-pill').classList.add('active');
      updatePreview();
    });
  });

  // ── highlight active AI option ────────────────────────────
  document.querySelectorAll('#ai-opts .ai-opt input[type=radio]').forEach(r => {
    r.addEventListener('change', () => {
      document.querySelectorAll('#ai-opts .ai-opt').forEach(o => o.classList.remove('active'));
      r.closest('.ai-opt').classList.add('active');
    });
  });

  // ── live preview ──────────────────────────────────────────
  function updatePreview() {
    const prefix  = (document.getElementById('inv-prefix').value || '').toUpperCase().trim();
    const start   = parseInt(document.getElementById('inv-start').value) || 1;
    const fmt     = document.querySelector('.fmt-pill input[type=radio]:checked')?.value || 'serial_only';
    const serial  = String(start).padStart(5, '0');
    const today   = '<%= Date.today.strftime('%d%m%y') %>';
    let   preview = '';

    if (fmt === 'prefix_date_serial') {
      preview = prefix ? `${prefix}-${today}-${serial}` : `${today}-${serial}`;
    } else if (fmt === 'prefix_serial') {
      preview = prefix ? `${prefix}-${serial}` : serial;
    } else {
      preview = serial;
    }
    document.getElementById('inv-preview-val').textContent = preview;
  }

  document.getElementById('inv-prefix').addEventListener('input', updatePreview);
  document.getElementById('inv-start').addEventListener('input', updatePreview);
  updatePreview();

  // ── save invoice config ───────────────────────────────────
  function saveInvConfig() {
    const prefix = (document.getElementById('inv-prefix').value || '').toUpperCase().trim();
    const start  = parseInt(document.getElementById('inv-start').value) || 1;
    const fmt    = document.querySelector('.fmt-pill input[type=radio]:checked')?.value || 'serial_only';

    patchSettings({
      'invoice_number_prefix': prefix,
      'invoice_number_format': fmt,
      'invoice_number_start':  start
    }, 'inv-toast', data => {
      if (data.preview) {
        document.getElementById('inv-preview-val').textContent = data.preview;
      }
    });
  }

  // ── save AI config ────────────────────────────────────────
  function saveAiConfig() {
    const provider = document.querySelector('#ai-opts input[type=radio]:checked')?.value || '';
    patchSettings({ 'ai_provider': provider }, 'ai-toast');
  }

  // ── Tinting config ────────────────────────────────────────
  function onTintingToggle(cb) {
    const slider  = document.getElementById('tinting-enabled-slider');
    const knob    = document.getElementById('tinting-knob');
    const sub     = document.getElementById('tinting-sub-settings');
    const on      = cb.checked;
    slider.style.background  = on ? 'var(--accent)' : 'var(--border)';
    knob.style.transform     = on ? 'translateX(18px)' : 'translateX(0)';
    sub.style.display        = on ? '' : 'none';
  }

  function onTintingActionChange(radio) {
    document.querySelectorAll('#tinting-config-card .fmt-pill').forEach(p => p.classList.remove('active'));
    radio.closest('.fmt-pill').classList.add('active');
  }

  function saveTintingConfig() {
    const enabled   = document.getElementById('tinting-enabled-toggle').checked;
    const threshold = parseFloat(document.getElementById('tinting-threshold')?.value) || 8;
    const action    = document.querySelector('#tinting-config-card input[name="tinting_action"]:checked')?.value || 'popup';
    patchSettings({
      'tinting_prompt_enabled':          enabled,
      'tinting_prompt_threshold_litres': threshold,
      'tinting_prompt_action':           action
    }, 'tinting-toast');
  }

  // ── shared PATCH helper ───────────────────────────────────
  function patchSettings(data, toastId, onSuccess) {
    const body = new URLSearchParams();
    body.append('authenticity_token', CSRF_TOKEN);
    Object.entries(data).forEach(([k, v]) => body.append(`settings[${k}]`, v));

    fetch(SETTINGS_URL, {
      method:  'PATCH',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded',
                 'X-CSRF-Token':  CSRF_TOKEN },
      body:    body.toString()
    })
    .then(r => r.json())
    .then(d => {
      if (d.ok) {
        const toast = document.getElementById(toastId);
        toast.style.opacity = '1';
        setTimeout(() => toast.style.opacity = '0', 2500);
        if (onSuccess) onSuccess(d);
      } else {
        alert('Error: ' + (d.error || 'Unknown error'));
      }
    })
    .catch(() => alert('Network error — please try again.'));
  }

  // ── member search ─────────────────────────────────────────
  document.getElementById('memberSearch').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('#membersTable tbody tr').forEach(row => {
      row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  });
</script>
<% else %>
<script>
  document.getElementById('memberSearch').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('#membersTable tbody tr').forEach(row => {
      row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  });
</script>
<% end %>
