          <% end %>
        </div>
      </div>

      <%# ── Trade Relations (Customers + Creditors) ── %>
      <div class="nav-section" id="ns-trade"
           data-section="trade"
           data-active="<%= %w[customers creditors].include?(controller_name) %>">
        <div class="nav-section-header" onclick="expandAndToggle(event,'trade')" data-tooltip="Trade Relations">
          <div class="nav-section-header-left">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="nav-section-icon">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            <span class="nav-section-label">Trade Relations</span>
          </div>
          <svg class="nav-section-chevron" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </div>
        <div class="nav-section-children">
          <%= link_to customers_path,
                class: "nav-link #{controller_name == 'customers' ? 'active' : ''}", data: { tooltip: 'Customers' } do %>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
            </svg>
            Customers
          <% end %>
          <%= link_to sales_creditors_path,
                class: "nav-link #{controller_name == 'creditors' ? 'active' : ''}", data: { tooltip: 'Creditors' } do %>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="2" y="5" width="20" height="14" rx="2"/>
              <line x1="2" y1="10" x2="22" y2="10"/>
            </svg>
            Creditors
          <% end %>
        </div>
      </div>

      <%# ── Reports (coming soon) ── %>
      <div class="nav-section" id="ns-reports" data-section="reports" data-active="false">
        <div class="nav-section-header" data-tooltip="Reports (soon)" style="opacity:0.45;cursor:default">
          <div class="nav-section-header-left">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="nav-section-icon">
              <line x1="18" y1="20" x2="18" y2="10"/>
              <line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6" y1="20" x2="6" y2="14"/>
              <line x1="2" y1="20" x2="22" y2="20"/>
            </svg>
            <span class="nav-section-label">Reports</span>
          </div>
          <span style="font-family:var(--mono);font-size:9px;background:var(--border);
                       padding:2px 6px;border-radius:3px;color:var(--text-dim)">soon</span>
        </div>
      </div>

    </nav>

    <!-- Collapse toggle -->
    <button class="collapse-btn" onclick="toggleSidebar()" id="collapseBtn" title="Toggle sidebar">
      <%# Claude-style sidebar close icon: two vertical bars with arrow %>
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <rect x="3" y="3" width="4" height="18" rx="1" fill="currentColor" stroke="none" opacity="0.5"/>
        <polyline points="14 8 9 12 14 16"/>
      </svg>
      <span class="collapse-label" style="font-size:11px;letter-spacing:0.04em">Close sidebar</span>
    </button>

    <% if user_signed_in? %>
    <div class="sidebar-footer">
      <div class="user-chip">
        <div class="user-avatar"><%= current_user.initials %></div>
        <div class="user-info">
          <div class="user-name"><%= current_user.full_name %></div>
          <div class="user-role"><%= current_user.role.humanize %></div>
        </div>
      </div>
      <button class="theme-toggle" onclick="toggleTheme()" id="themeToggle"
              style="margin:8px 0 0;width:100%;border-radius:6px;justify-content:center">
        <div class="theme-toggle-track" id="themeTrack">
          <div class="theme-toggle-thumb"></div>
        </div>
        <span id="themeLabel">Light</span>
      </button>
      <%= button_to 'Sign Out', destroy_user_session_path, method: :delete,
            class: 'sign-out-link', form: { style: 'margin:0' } %>
    </div>
    <% end %>
  </aside>

  <!-- MAIN -->
  <main class="main">
    <div class="topbar">
      <div class="breadcrumb">
        <%= yield :breadcrumb %>
      </div>
    </div>

    <div class="page-content">
      <% if notice %>
        <div class="flash notice"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="flash alert"><%= alert %></div>
      <% end %>
      <%= yield %>
    </div>
  </main>

</body>
<script>
  var THEME_KEY   = 'storeerp_theme';
  var SECTION_KEY = 'storeerp_sections'; // JSON object of section open states

  // ── Section accordion ──
  function getSectionStates() {
    try { return JSON.parse(localStorage.getItem(SECTION_KEY) || '{}'); }
    catch(e) { return {}; }
  }
  function saveSectionStates(states) {
    localStorage.setItem(SECTION_KEY, JSON.stringify(states));
  }

  function toggleSection(id) {
    var el = document.getElementById('ns-' + id);
    if (!el) return;
    var isOpen = el.classList.contains('open');
    el.classList.toggle('open', !isOpen);
    var states = getSectionStates();
    states[id] = !isOpen;
    saveSectionStates(states);
  }

  // Called when clicking section headers — if sidebar is collapsed, expand it first then open section
  function expandAndToggle(event, id) {
    var sidebar = document.getElementById('mainSidebar');
    if (sidebar.classList.contains('collapsed')) {
      // Expand sidebar first
      localStorage.setItem('storeerp_sidebar', '0');
      applySidebar(false);
      // Then open the section
      var el = document.getElementById('ns-' + id);
      if (el && !el.classList.contains('open')) {
        el.classList.add('open');
        var states = getSectionStates();
        states[id] = true;
        saveSectionStates(states);
      }
    } else {
      toggleSection(id);
    }
  }

  // On load: restore section open states, and always open sections with active links
  (function() {
    var saved = getSectionStates();
    document.querySelectorAll('.nav-section').forEach(function(sec) {
      var id      = sec.dataset.section;
      var isActive = sec.dataset.active === 'true';
      var wasOpen  = saved[id] === true;
      if (isActive || wasOpen) {
        sec.classList.add('open');
        // Persist the active one as open
        if (isActive) { saved[id] = true; }
      }
    });
    saveSectionStates(saved);
  })();

  // ── Sidebar collapse ──
  function applySidebar(collapsed) {
    var sidebar = document.getElementById('mainSidebar');
    var body    = document.body;
    if (collapsed) {
      sidebar.classList.add('collapsed');
      body.classList.add('sidebar-collapsed');
    } else {
      sidebar.classList.remove('collapsed');
      body.classList.remove('sidebar-collapsed');
    }
  }
  function toggleSidebar() {
    var isCollapsed = document.getElementById('mainSidebar').classList.contains('collapsed');
    var next = !isCollapsed;
    localStorage.setItem('storeerp_sidebar', next ? '1' : '0');
    applySidebar(next);
  }

  // Nav top links (dashboard) also expand sidebar if collapsed
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.nav-top-link').forEach(function(link) {
      link.addEventListener('click', function(e) {
        var sidebar = document.getElementById('mainSidebar');
        if (sidebar.classList.contains('collapsed')) {
          // Don't navigate — just expand
          e.preventDefault();
          localStorage.setItem('storeerp_sidebar', '0');
          applySidebar(false);
        }
      });
    });
  });
  (function() {
    if (localStorage.getItem('storeerp_sidebar') === '1') applySidebar(true);
  })();

  // ── Theme ──
  function applyTheme(theme) {
    var isLight = theme === 'light';
    document.documentElement.setAttribute('data-theme', theme);
    var track = document.getElementById('themeTrack');
    var label = document.getElementById('themeLabel');
    if (track) track.classList.toggle('on', isLight);
    if (label) label.textContent = isLight ? 'Dark' : 'Light';
  }
  function toggleTheme() {
    var current = document.documentElement.getAttribute('data-theme') || 'dark';
    var next    = current === 'dark' ? 'light' : 'dark';
    localStorage.setItem(THEME_KEY, next);
    applyTheme(next);
  }
  (function() {
    var saved = localStorage.getItem(THEME_KEY) || 'dark';
    applyTheme(saved);
  })();
</script>
</html>
