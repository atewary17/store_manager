              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            Suppliers
          <% end %>
          <%= link_to purchasing_purchase_invoices_path,
                class: "nav-link #{controller_name == 'purchase_invoices' ? 'active' : ''}", data: { tooltip: 'Purchase Invoices' } do %>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="8" y1="13" x2="16" y2="13"/>
              <line x1="8" y1="17" x2="16" y2="17"/>
            </svg>
            Purchase Invoices
          <% end %>
          <%= link_to sales_sales_invoices_path,
                class: "nav-link #{controller_name == 'sales_invoices' ? 'active' : ''}", data: { tooltip: 'Sales Invoices' } do %>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <line x1="12" y1="1" x2="12" y2="23"/>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
            Sales Invoices
          <% end %>
          <%= link_to purchasing_digitise_index_path,
                class: "nav-link #{controller_name == 'digitise' ? 'active' : ''}", data: { tooltip: 'Scan Invoice (AI)' } do %>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M23 7l-7 5 7 5V7z"/>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
