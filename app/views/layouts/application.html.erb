            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </div>
        <div class="nav-section-children">
          <%= link_to inventory_stock_levels_path,
                class: "nav-link #{controller_name == 'stock_levels' ? 'active' : ''}", data: { tooltip: 'Stock Levels' } do %>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
            Stock Levels
          <% end %>
          <%= link_to new_inventory_opening_stock_path,
                class: "nav-link #{controller_name == 'opening_stocks' ? 'active' : ''}", data: { tooltip: 'Opening Stock' } do %>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <line x1="12" y1="8" x2="12" y2="16"/>
              <line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
            Opening Stock
          <% end %>
          <%= link_to purchasing_suppliers_path,
                class: "nav-link #{controller_name == 'suppliers' ? 'active' : ''}", data: { tooltip: 'Suppliers' } do %>
